---
// /examples — the example gallery (PRD §4.3). Same self-contained landing-style
// shell as index.astro (shared Nav/Footer), but the content is built entirely
// from the repo at build time via getExamples() — no hand-maintained list.
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
import '../styles/landing.css';
import Card from '../components/ds/Card.astro';
import Nav from '../components/Nav.astro';
import ThemeInit from '../components/ThemeInit.astro';
import Footer from '../components/Footer.astro';
import { REPO, ghStats } from '../lib/site';
import { getExamples, FALLBACK_EXAMPLES } from '../lib/examples';

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';
const ex = await getExamples();

const EXAMPLES_GH = REPO + '/tree/main/packages/core/examples';

const title = 'Examples — Open Multi-Agent';
const description =
  'Runnable, end-to-end examples for Open Multi-Agent — cookbook recipes framed by the problem they solve, framework and app integrations, orchestration patterns, and one example per model provider. Straight from the repo.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
  ...(ex
    ? {
        mainEntity: {
          '@type': 'ItemList',
          itemListElement: ex.cookbook.map((e, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            name: e.title,
            url: e.href,
          })),
        },
      }
    : {}),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeInit />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Open Multi-Agent" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/github-social.png', Astro.site).href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="640" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/github-social.png', Astro.site).href} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Nav current="examples" starsK={starsK} />

    <main>
      <!-- ── Page head ── -->
      <header class="ex-hero">
        <div class="container">
          <div class="eyebrow"><span class="idx">//</span> examples</div>
          <h1 class="ex-title">What you can build with OMA.</h1>
          <p class="ex-lede">
            Runnable recipes straight from the repo — each framed by the problem it solves. Browse by what you want to
            build, then open the source.
          </p>
        </div>
      </header>

      {ex ? (
        <Fragment>
          <!-- ── 1. Cookbook (primary) ── -->
          <section class="section ex-first" id="cookbook">
            <div class="container">
              <div class="section-head">
                <div class="eyebrow"><span class="idx">01</span> Cookbook</div>
                <h2 class="section-title">Recipes for real problems.</h2>
                <p class="section-sub">
                  End-to-end scripts built around a concrete task, not a single primitive — open the source to see how
                  the patterns compose on a real workflow.
                </p>
              </div>
              <div class="build-grid">
                {ex.cookbook.map((e) => (
                  <a class="case-link" href={e.href} target="_blank" rel="noreferrer" style="text-decoration:none;">
                    <Card padding="lg" interactive>
                      <div class="build-title">{e.title}</div>
                      <p class="build-desc">{e.blurb}</p>
                      <div class="build-foot">
                        <span class="text-link"><span>see source</span><span class="arrow">→</span></span>
                      </div>
                    </Card>
                  </a>
                ))}
              </div>
            </div>
          </section>

          <!-- ── 2. Integrations (primary) ── -->
          <section class="section" id="integrations">
            <div class="container">
              <div class="section-head">
                <div class="eyebrow"><span class="idx">02</span> Integrations</div>
                <h2 class="section-title">Works with your stack.</h2>
                <p class="section-sub">
                  A library, not a platform — it composes with the protocols, servers, and frameworks already in your
                  backend.
                </p>
              </div>

              {ex.reference.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">Reference integrations</div>
                  <div class="ex-list">
                    {ex.reference.map((e) => (
                      <a class="ex-row mono" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.name}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {ex.apps.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">Apps · clone and run</div>
                  <div class="ex-list">
                    {ex.apps.map((e) => (
                      <a class="ex-row" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.title}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {ex.vendor.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">Vendor integrations</div>
                  <div class="ex-list">
                    {ex.vendor.map((e) => (
                      <a class="ex-row" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.title}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </section>

          <!-- ── 3. Building blocks (secondary) ── -->
          <section class="section" id="building-blocks">
            <div class="container">
              <div class="section-head">
                <div class="eyebrow"><span class="idx">03</span> Building blocks</div>
                <h2 class="section-title">Primitives, patterns, and providers.</h2>
                <p class="section-sub">
                  The lower-level pieces the cookbook composes — start here if you're learning the API or comparing
                  models.
                </p>
              </div>

              {ex.basics.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">Basics · start here</div>
                  <div class="ex-list">
                    {ex.basics.map((e) => (
                      <a class="ex-row mono" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.name}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {ex.patterns.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">Patterns</div>
                  <div class="ex-list">
                    {ex.patterns.map((e) => (
                      <a class="ex-row mono" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.name}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {ex.providers.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">Providers · one example per model</div>
                  <div class="ex-chips">
                    {ex.providers.map((e) => (
                      <a class="ex-chip" href={e.href} target="_blank" rel="noreferrer" title={e.blurb}>{e.name}</a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </section>

          <!-- ── 4. Production pointer + provenance ── -->
          <section class="section" id="more">
            <div class="container">
              <div class="ex-callout">
                <div>
                  <div class="ex-callout-title">Production examples</div>
                  <p class="ex-callout-desc">
                    End-to-end, production-grade use cases — a higher bar, with tests and pinned models. See the
                    contribution criteria to add one.
                  </p>
                </div>
                <a class="text-link" href={ex.productionHref} target="_blank" rel="noreferrer">
                  <span>production/ on GitHub</span><span class="arrow">→</span>
                </a>
              </div>
              <p class="ex-foot">
                Generated at build time from the repo's <code>packages/core/examples</code> tree, so it always matches
                the source. <a class="text-link inline" href={ex.browseHref} target="_blank" rel="noreferrer"><span>Browse all on GitHub</span><span class="arrow">→</span></a>
              </p>
            </div>
          </section>
        </Fragment>
      ) : (
        <section class="section ex-first">
          <div class="container">
            <div class="section-head">
              <div class="eyebrow"><span class="idx">01</span> Cookbook</div>
              <h2 class="section-title">Recipes for real problems.</h2>
              <p class="section-sub">
                A few end-to-end recipes to start from. The full, always-in-sync suite — integrations, orchestration
                patterns, and one example per model provider — lives in the repo.
              </p>
            </div>
            <div class="build-grid">
              {FALLBACK_EXAMPLES.map((e) => (
                <a class="case-link" href={e.href} target="_blank" rel="noreferrer" style="text-decoration:none;">
                  <Card padding="lg" interactive>
                    <div class="build-title">{e.title}</div>
                    <p class="build-desc">{e.blurb}</p>
                    <div class="build-foot">
                      <span class="text-link"><span>see source</span><span class="arrow">→</span></span>
                    </div>
                  </Card>
                </a>
              ))}
            </div>
            <p class="ex-foot">
              <a class="text-link inline" href={EXAMPLES_GH} target="_blank" rel="noreferrer"><span>Browse all on GitHub</span><span class="arrow">→</span></a>
            </p>
          </div>
        </section>
      )}
    </main>

    <Footer />

    <style>
      .ex-hero { padding: 72px 0 8px; }
      .ex-title {
        font-size: clamp(34px, 5vw, 52px); font-weight: 600; letter-spacing: -0.03em;
        line-height: 1.05; color: var(--oma-fg-0); margin: 16px 0 0;
      }
      .ex-lede { font-size: 17px; line-height: 1.6; color: var(--oma-fg-1); margin: 18px 0 0; max-width: 640px; }
      .ex-first { padding-top: 56px; }

      .ex-group { margin-top: 32px; }
      .ex-group:first-of-type { margin-top: 0; }
      .ex-subhead {
        font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em;
        text-transform: uppercase; color: var(--oma-fg-2); margin-bottom: 6px;
      }

      .ex-list { border-top: 1px solid var(--border-subtle); }
      .ex-row {
        display: flex; align-items: baseline; gap: 18px;
        padding: 15px 4px; border-bottom: 1px solid var(--border-subtle);
        text-decoration: none; transition: background var(--duration-base) var(--ease-out);
      }
      .ex-row:hover { background: var(--oma-bg-1); }
      .ex-row .name {
        flex: none; min-width: 232px; color: var(--oma-fg-0);
        font-weight: 500; font-size: 15px; line-height: 1.35;
      }
      .ex-row.mono .name { font-family: var(--font-mono); font-size: 13px; }
      .ex-row:hover .name { color: var(--oma-accent); }
      .ex-row .desc { flex: 1; min-width: 0; color: var(--oma-fg-1); font-size: 13px; line-height: 1.5; }
      .ex-row .arr { flex: none; color: var(--oma-fg-2); transition: transform var(--duration-base) var(--ease-out); }
      .ex-row:hover .arr { color: var(--oma-accent); transform: translateX(3px); }

      .ex-chips { display: flex; flex-wrap: wrap; gap: 8px; }
      .ex-chip {
        font-family: var(--font-mono); font-size: 12px; color: var(--oma-fg-1);
        border: 1px solid var(--border-default); border-radius: var(--radius-sm);
        padding: 6px 11px; text-decoration: none;
        transition: border-color var(--duration-base) var(--ease-out), color var(--duration-base) var(--ease-out);
      }
      .ex-chip:hover { border-color: var(--border-strong); color: var(--oma-accent); }

      .ex-callout {
        display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
        padding: 22px 24px; background: var(--oma-bg-1);
        border: 1px solid var(--border-default); border-radius: var(--radius-md);
      }
      .ex-callout-title { font-size: 16px; font-weight: 600; color: var(--oma-fg-0); }
      .ex-callout-desc { font-size: 13px; line-height: 1.55; color: var(--oma-fg-2); margin: 6px 0 0; max-width: 560px; }
      .ex-foot { margin-top: 28px; font-size: 13px; line-height: 1.65; color: var(--oma-fg-2); }
      .ex-foot code { font-family: var(--font-mono); font-size: 12px; color: var(--oma-fg-1); }
      .text-link.inline { display: inline-flex; }

      @media (max-width: 640px) {
        .ex-row { flex-direction: column; gap: 4px; }
        .ex-row .name { min-width: 0; }
      }
    </style>
  </body>
</html>
