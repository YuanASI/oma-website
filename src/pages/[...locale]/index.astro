---
// OMA landing page (open-multi-agent.com homepage).
// Ported 1:1 from the Claude Design system (bfaf7892) export, with the
// fact-check corrections agreed in the handoff:
//   • §3 global nav (Product ▾ open-multi-agent + oma-forge / Docs / Architecture / Examples / Showcase / Blog / GitHub)
//   • Production-proof cases rewritten from the OMA README ecosystem section
//     (temodar = security · on Docker Hub; Engram + @agentsonar = integrations)
//   • team.ts code uses the REAL published API (AgentConfig.name, real tool names, methods)
//   • Live GitHub stats fetched at build time (no hard-coded precise numbers)
//   • "see code" links point to real cookbook examples in the repo
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../styles/tokens.css';
import '../../styles/landing.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/ds/Badge.astro';
import Card from '../../components/ds/Card.astro';
import CodeBlock from '../../components/ds/CodeBlock.astro';
import Callout from '../../components/ds/Callout.astro';
import TaskNode from '../../components/ds/TaskNode.astro';
import heroRunEn from '../../data/hero-run.json';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { REPO, NPM, ghStats, yuanasiHref } from '../../lib/site';
import { SHOWCASE } from '../../lib/showcase';
import { localeStaticPaths, toLocale, useTranslations, localizePath } from '../../i18n';

export function getStaticPaths() { return localeStaticPaths(); }
const locale = toLocale(Astro.params.locale);
const t = useTranslations(locale);
const l = t.landing;
const L = (p: string) => localizePath(p, locale);

// Hero renders a REAL captured runTeam() DAG. zh uses a Chinese-goal capture
// (src/data/hero-run.zh.json) when it exists; until that capture lands, zh falls
// back to the English run so the build stays green. Never hand-edit the JSON to
// fake a localized run (PRD §4.1 ①).
const heroRunZhFiles = import.meta.glob('../../data/hero-run.zh.json', { eager: true, import: 'default' });
const heroRun = (locale === 'zh' ? (heroRunZhFiles['../../data/hero-run.zh.json'] ?? heroRunEn) : heroRunEn) as typeof heroRunEn;

// REPO / NPM constants and ghStats() now live in ../../lib/site (shared with the
// Nav/Footer components and the /examples page). FORGE is only used by Nav.
const stats = await ghStats();
const fmt = (n: number) => n.toLocaleString('en-US');
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

// ── Hero right-visual: a REAL captured runTeam() DAG. The nodes below are
//    rendered from src/data/hero-run.json, produced by a real DeepSeek run
//    (scripts/capture-hero-dag.mjs) — no hand-built mockup (PRD §4.1 ①). The
//    snippet's goal is the exact goal that produced the DAG shown. ──
// Render the real captured goal as a real JS literal. A single-line goal (en)
// stays a double-quoted string; a multi-line goal (zh — its numbered list is
// load-bearing, the only language-agnostic decomposition signal the orchestrator
// has, see scripts/capture-hero-dag.mjs) renders as a template literal with real
// line breaks so the terminal never shows literal "\n".
const heroGoalLiteral = heroRun.goal.includes('\n')
  ? '`' + heroRun.goal + '`'
  : JSON.stringify(heroRun.goal);
const HERO_SNIPPET = `const team = oma.createTeam('api-team', { agents })

// one call: goal → task DAG → result
const result = await oma.runTeam(
  team,
  ${heroGoalLiteral},
)`;

// Group the captured tasks into dependency levels (depth = longest path from a
// root). Same-depth tasks ran in parallel; this drives the DAG layout below.
const heroById = new Map(heroRun.tasks.map((t) => [t.id, t]));
const heroDepthCache = new Map<string, number>();
const heroDepth = (t: (typeof heroRun.tasks)[number]): number => {
  const cached = heroDepthCache.get(t.id);
  if (cached !== undefined) return cached;
  const deps = (t.dependsOn ?? []).filter((id) => heroById.has(id));
  const d = deps.length === 0 ? 0 : 1 + Math.max(...deps.map((id) => heroDepth(heroById.get(id)!)));
  heroDepthCache.set(t.id, d);
  return d;
};
const heroMaxDepth = Math.max(...heroRun.tasks.map(heroDepth));
const heroLevels = Array.from({ length: heroMaxDepth + 1 }, (_, d) =>
  heroRun.tasks.filter((t) => heroDepth(t) === d),
);
const heroStatusMap: Record<string, 'done' | 'running' | 'queued' | 'failed' | 'skipped'> = {
  completed: 'done', in_progress: 'running', pending: 'queued', failed: 'failed', skipped: 'skipped', blocked: 'queued',
};
const heroDur = (ms: number | null) => (ms == null ? null : (ms / 1000).toFixed(1) + 's');
const heroNodeId = (id: string) => '#' + id.slice(0, 8);
const heroWallS = Math.round(heroRun.wallMs / 1000);

// ── Capabilities code (real v1.7.0 API — verified against the repo). ──
const TEAM_CODE = `import { OpenMultiAgent, type AgentConfig } from '@open-multi-agent/core'

const agents: AgentConfig[] = [
  { name: 'architect', model: 'claude-sonnet-4-6', tools: ['file_write'] },
  { name: 'developer', model: 'claude-sonnet-4-6', tools: ['bash', 'file_read', 'file_write', 'file_edit'] },
  { name: 'reviewer',  model: 'claude-sonnet-4-6', tools: ['file_read', 'grep'] },
]

const oma  = new OpenMultiAgent({ defaultModel: 'claude-sonnet-4-6' })
const team = oma.createTeam('api-team', { name: 'api-team', agents })

// coordinator plans the DAG, runs independents in parallel, synthesizes
const result = await oma.runTeam(team, 'Create a REST API for a todo list')`;

// ── Production-proof cases — the `featured` subset of the shared ecosystem
//    list (src/lib/showcase.ts), rendered in full on /showcase. zh desc/tag/
//    status reuse the showcase dict (same entries), keyed by pkg. ──
const CASES = SHOWCASE.filter((c) => c.featured);
const scEntries = t.showcase.entries;
const caseTr = (c: (typeof SHOWCASE)[number]) => scEntries[c.pkg] ?? { desc: c.desc, tag: c.tag, status: c.status };

// Section copy lives in the per-locale dictionary (src/i18n); the markup below
// renders it via `l`. Every API name / code identifier inside the copy stays
// verbatim (see src/i18n/en.ts for the verified-against-v1.8.0 source).
const CAPS = l.caps;
const RELIABILITY = l.reliability;

// Cookbook source URLs for the three use-case cards (the copy comes from the dict).
const BUILD_CODE = [
  REPO + '/blob/main/packages/core/examples/cookbook/contract-review-dag.ts',
  REPO + '/blob/main/packages/core/examples/cookbook/competitive-monitoring.ts',
  REPO + '/blob/main/packages/core/examples/cookbook/incident-postmortem-dag.ts',
];
const BUILDS = l.builds.map((b, i) => ({ ...b, code: BUILD_CODE[i] }));

const STACK = l.stack;
const FAQS = l.faqs;

const title = l.seo.title;
const description = l.seo.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// ── JSON-LD structured data (PRD §4.6 GEO) ──
// SoftwareApplication + Organization + FAQPage in one @graph. The FAQPage
// reuses the FAQS array above verbatim, so the markup always matches the
// visible FAQ section (Google requires structured-data ↔ on-page parity).
// No aggregateRating: there is no real rating data, and inventing one would
// violate red-line §5.1. `offers` (free/MIT) makes the entry rich-eligible.
const orgId = new URL('/#organization', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: 'YuanASI',
      alternateName: '元定义科技',
      url: 'https://yuanasi.com',
      logo: new URL('/logo-mark-dark.svg', Astro.site).href,
    },
    {
      '@type': 'SoftwareApplication',
      '@id': new URL('/#software', Astro.site).href,
      name: 'Open Multi-Agent',
      alternateName: ['OMA', '@open-multi-agent/core'],
      description,
      inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Node.js 18+',
      url: new URL('/', Astro.site).href,
      downloadUrl: NPM,
      codeRepository: REPO,
      programmingLanguage: 'TypeScript',
      license: 'https://opensource.org/licenses/MIT',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      author: { '@id': orgId },
      publisher: { '@id': orgId },
      sameAs: [REPO, NPM],
    },
    {
      '@type': 'FAQPage',
      '@id': new URL('/#faq', Astro.site).href,
      mainEntity: FAQS.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path="/">
  <!-- ── Nav (§3 global) — shared component ── -->
  <Nav current="home" starsK={starsK} locale={locale} path="/" />

    <main>
      <!-- ── 1. Hero ── -->
      <header class="hero" id="top">
        <div class="container hero-grid">
          <div>
            <div class="eyebrow"><span class="idx">//</span> {l.hero.eyebrow}</div>
            <h1>{l.hero.h1}<span class="accent">{l.hero.h1Accent}</span></h1>
            <div class="hero-meta"><b>{l.hero.meta[0]}</b><span class="sep">·</span><b>{l.hero.meta[1]}</b><span class="sep">·</span><b>{l.hero.meta[2]}</b></div>
            <div class="hero-cta">
              <button type="button" class="cmd" data-cmd="npm create oma-app@latest" data-copied={l.copied} aria-label="Copy: npm create oma-app@latest">
                <span class="prompt" aria-hidden="true">$</span><span class="text">npm create oma-app@latest</span><span class="copy" aria-hidden="true">{l.copy}</span>
              </button>
              <a class="text-link" href={L('/getting-started/quick-start/')}><span>{l.hero.quickStart}</span><span class="arrow">→</span></a>
            </div>
            <p class="hero-enterprise">{l.hero.enterprise.pre} <a href={yuanasiHref(locale)} target="_blank" rel="noreferrer">{l.hero.enterprise.link} <span class="arrow" aria-hidden="true">→</span></a></p>
          </div>
          <div>
            <div class="io-panel">
              <div class="io-cap"><span>{l.hero.ioInput}</span><span style="color:var(--oma-accent);">{l.hero.ioGoal}</span></div>
              <CodeBlock lang="ts" title="runTeam()" code={HERO_SNIPPET} copyable={false} />
              <div class="io-connector"><span class="line"></span>{l.hero.decomposesInto}<span class="line"></span></div>
              <div class="dag-stack">
                {heroLevels.map((level, li) => (
                  <Fragment>
                    {li > 0 && <div class="dag-link"></div>}
                    {level.length > 1 ? (
                      <div class="dag-parallel">
                        <span class="dag-parallel-tag">{l.hero.parallel}</span>
                        {level.map((t) => (
                          <TaskNode id={heroNodeId(t.id)} title={t.title} status={heroStatusMap[t.status] ?? 'done'} duration={heroDur(t.durationMs)} role={t.assignee} locale={locale} />
                        ))}
                      </div>
                    ) : (
                      <TaskNode id={heroNodeId(level[0].id)} title={level[0].title} status={heroStatusMap[level[0].status] ?? 'done'} duration={heroDur(level[0].durationMs)} role={level[0].assignee} locale={locale} />
                    )}
                  </Fragment>
                ))}
              </div>
              <div class="dag-meta">
                <span class="dag-meta-dot"></span>
                <span>{l.hero.runReal} <code>runTeam()</code> · {heroRun.model} · {heroRun.tasks.length} {l.hero.runTasks} · {heroWallS}s</span>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- ── 2. Capabilities ── -->
      <section class="section" id="capabilities">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">01</span> {l.sectionCapabilities.eyebrow}</div>
            <h2 class="section-title">{l.sectionCapabilities.title}</h2>
            <p class="section-sub">{l.sectionCapabilities.sub}</p>
          </div>
          <div class="cap-grid">
            <div class="cap-list">
              {CAPS.map((c) => (
                <div class="cap-item">
                  <div class="cap-item-head"><span class="cap-num">{c.n}</span><span class="cap-title">{c.t}</span></div>
                  <p class="cap-desc">{c.d}</p>
                </div>
              ))}
            </div>
            <div class="cap-code-wrap">
              <CodeBlock lang="ts" title="team.ts" code={TEAM_CODE} copyLabel={l.copy} copiedLabel={l.copied} />
              <div style="margin-top:var(--space-4);">
                <Callout tone="accent" title={l.oneCall.title}>{l.oneCall.body}</Callout>
                <div style="margin-top:var(--space-4);display:grid;gap:10px;justify-items:start;">
                  <a class="text-link" href={L('/getting-started/three-ways-to-run/')}><span>{l.capsLinks.threeWays}</span><span class="arrow">→</span></a>
                  <a class="text-link" href={L('/architecture/')}><span>{l.capsLinks.archFlow}</span><span class="arrow">→</span></a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── 3. Built for production (reliability / control narrative) ── -->
      <section class="section" id="reliability">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">02</span> {l.sectionReliability.eyebrow}</div>
            <h2 class="section-title">{l.sectionReliability.title}</h2>
            <p class="section-sub">{l.sectionReliability.sub}</p>
          </div>
          <div class="rel-grid">
            {RELIABILITY.map((c) => (
              <Card padding="lg" accent class="rel-card">
                <div class="rel-tag">{c.tag}</div>
                <div class="rel-title">{c.t}</div>
                <p class="rel-desc">{c.parts.map((p) => (typeof p === 'string' ? p : <code>{p.c}</code>))}</p>
                <div class="rel-foot"><a class="text-link" href={L(c.ref)}><span>{c.refLabel}</span><span class="arrow">→</span></a></div>
              </Card>
            ))}
          </div>
          <figure class="dashboard-shot">
            <img src="/demo-dashboard.gif" width="1600" height="760" loading="lazy" decoding="async" alt={l.dashboard.imgAlt} />
            <figcaption>{l.dashboard.caption} <a class="text-link" href={L('/reference/observability/')}><span>{l.dashboard.obsLink}</span><span class="arrow">→</span></a></figcaption>
          </figure>
        </div>
      </section>

      <!-- ── 4. What you can build ── -->
      <section class="section" id="build">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">03</span> {l.sectionBuild.eyebrow}</div>
            <h2 class="section-title">{l.sectionBuild.title}</h2>
            <p class="section-sub">{l.sectionBuild.sub}</p>
          </div>
          <div class="build-grid">
            {BUILDS.map((b) => (
              <a class="case-link" href={b.code} target="_blank" rel="noreferrer" style="text-decoration:none;">
                <Card padding="lg" interactive class="build-card">
                  <div class="build-scenario">{b.scenario}</div>
                  <div class="build-title">{b.title}</div>
                  <p class="build-desc">{b.desc}</p>
                  <div class="build-outcome"><span class="arrow">▸</span><span>{b.outcome}</span></div>
                  <div class="build-foot"><span class="text-link"><span>{l.sectionBuild.seeCode}</span><span class="arrow">→</span></span></div>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ── 5. Works with your stack ── -->
      <section class="section" id="stack">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">04</span> {l.sectionStack.eyebrow}</div>
            <h2 class="section-title">{l.sectionStack.title}</h2>
            <p class="section-sub">{l.sectionStack.sub}</p>
          </div>
          <div class="stack-grid">
            {STACK.map((s) => (
              <div class="stack-tile">
                <div>
                  <div class="stack-name">{s.name}</div>
                  <div class="stack-note">{s.note}</div>
                </div>
                <div class="stack-count">{s.count}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── 6. Production proof ── -->
      <section class="section" id="proof">
        <div class="container">
          <div class="proof-head">
            <div class="section-head" style="margin-bottom:0;">
              <div class="eyebrow"><span class="idx">05</span> {l.sectionProof.eyebrow}</div>
              <h2 class="section-title">{l.sectionProof.title}</h2>
              <p class="section-sub">{l.sectionProof.sub}</p>
            </div>
            <div class="live-tag"><span class="live-dot"></span> {l.sectionProof.liveTag}</div>
          </div>
          <div class="stats-row">
            <div class="stat"><div class="stat-val"><span class="unit">★ </span><span data-count={stats.stars} data-live="stars">{fmt(stats.stars)}</span></div><div class="stat-key">{l.sectionProof.stats.stars}</div></div>
            <div class="stat"><div class="stat-val"><span data-count={stats.forks} data-live="forks">{fmt(stats.forks)}</span></div><div class="stat-key">{l.sectionProof.stats.forks}</div></div>
            <div class="stat"><div class="stat-val"><span data-count={stats.contributors}>{fmt(stats.contributors)}</span></div><div class="stat-key">{l.sectionProof.stats.contributors}</div></div>
            <div class="stat"><a href={REPO + '/releases'} target="_blank" rel="noreferrer" style="color:inherit;text-decoration:none;"><div class="stat-val">{stats.latestRelease}</div><div class="stat-key">{l.sectionProof.stats.latestRelease}</div></a></div>
            <div class="stat"><div class="stat-val">MIT</div><div class="stat-key">{l.sectionProof.stats.license}</div></div>
          </div>
          <div class="cases-grid">
            {CASES.map((c) => (
              <a class="case-link" href={c.href} target="_blank" rel="noreferrer" style="text-decoration:none;">
                <Card padding="lg" interactive>
                  <div class="case-pkg">{c.pkg}</div>
                  <div class="case-by">{c.by}</div>
                  <p class="case-desc">{caseTr(c).desc}</p>
                  <div class="case-foot">
                    <Badge tone={c.tone}>{caseTr(c).tag}</Badge>
                    <span class="case-dep">{caseTr(c).status}</span>
                  </div>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ── 7. FAQ ── -->
      <section class="section" id="faq">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">06</span> {l.sectionFaq.eyebrow}</div>
            <h2 class="section-title">{l.sectionFaq.title}</h2>
            <p class="section-sub">{l.sectionFaq.sub}</p>
          </div>
          <div class="faq-list">
            {FAQS.map((f, i) => (
              <div class={`faq-item${i === 0 ? ' open' : ''}`}>
                <button type="button" class="faq-q" aria-expanded={i === 0 ? 'true' : 'false'}>
                  <span>{f.q}</span><span class="faq-icon">+</span>
                </button>
                <div class="faq-a"><div class="faq-a-inner">{f.a}</div></div>
              </div>
            ))}
          </div>
          <div style="margin-top:28px;">
            <a class="text-link" href={REPO + '#how-is-this-different-from-x'} target="_blank" rel="noreferrer"><span>{l.sectionFaq.viewAll}</span><span class="arrow">→</span></a>
          </div>
        </div>
      </section>

      <!-- ── 7b. Endorsement (third-party pull-quote + clickable clip still) ── -->
      <section class="section endorse">
        <div class="container">
          <div class="endorse-grid">
            <div class="endorse-text">
              <div class="eyebrow"><span class="idx">//</span> {l.endorse.eyebrow}</div>
              <figure class="pullquote">
                <blockquote cite="https://www.youtube.com/watch?v=2cdpYJzPXWE&t=331s">{l.endorse.quote}</blockquote>
                <figcaption class="pullquote-cite">{l.endorse.cite}</figcaption>
              </figure>
            </div>
            <a class="endorse-clip" href="https://www.youtube.com/watch?v=2cdpYJzPXWE&t=331s" target="_blank" rel="noreferrer">
              <img src="/featured-githubawesome.jpg" width="1280" height="720" loading="lazy" decoding="async" alt={l.endorse.imgAlt} />
              <span class="endorse-play" aria-hidden="true"></span>
            </a>
          </div>
        </div>
      </section>

      <!-- ── 8. Final CTA ── -->
      <section class="section" id="start" style="border-top:1px solid var(--border-subtle);">
        <div class="container cta-final">
          <div class="eyebrow" style="justify-content:center;"><span class="idx">//</span> {l.ctaFinal.eyebrow}</div>
          <h2>{l.ctaFinal.title1}<br />{l.ctaFinal.title2}</h2>
          <div class="cta-actions">
            <button type="button" class="cmd" data-cmd="npm create oma-app@latest" data-copied={l.copied} aria-label="Copy: npm create oma-app@latest">
              <span class="prompt" aria-hidden="true">$</span><span class="text">npm create oma-app@latest</span><span class="copy" aria-hidden="true">{l.copy}</span>
            </button>
            <a class="text-link" href={L('/getting-started/quick-start/')}><span>{l.ctaFinal.quickStart}</span><span class="arrow">→</span></a>
          </div>
        </div>
      </section>
    </main>

    <!-- ── Footer — shared component ── -->
    <Footer locale={locale} />

    <script>
      // ── Stats count-up on scroll ──
      // 动画终点优先用客户端实时抓取的 GitHub 数(stars/forks),fetch 失败或
      // 超时则回退到构建期烤进 data-count 的值。因为动画本来就是 0→终点,把
      // 终点换成实时值不会有数字跳变 —— 滚动动画天然掩护了「构建期值 → 实时值」
      // 的差异。无 JS / 抓取失败的访客看到的就是构建期值(合理 fallback)。
      const fmt = (n: number) => Math.round(n).toLocaleString('en-US');

      type LiveCounts = { stars: number; forks: number };
      const live: Promise<LiveCounts | null> = fetch(
        'https://api.github.com/repos/open-multi-agent/open-multi-agent',
        { headers: { Accept: 'application/vnd.github+json' } },
      )
        .then((r) => (r.ok ? r.json() : null))
        .then((j: any) =>
          j && typeof j.stargazers_count === 'number'
            ? { stars: j.stargazers_count, forks: j.forks_count }
            : null,
        )
        .catch(() => null);

      // 滚到该区域时实时值还没回来,最多等 800ms 就用构建期值,避免动画卡住。
      const liveOrTimeout: Promise<LiveCounts | null> = Promise.race([
        live,
        new Promise<null>((res) => setTimeout(() => res(null), 800)),
      ]);

      document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
        const baked = parseInt(el.dataset.count || '0', 10);
        const liveKey = el.dataset.live as keyof LiveCounts | undefined;
        const io = new IntersectionObserver((entries, obs) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            obs.disconnect();
            liveOrTimeout.then((data) => {
              const fromLive = data && liveKey ? data[liveKey] : undefined;
              const target = typeof fromLive === 'number' && fromLive > 0 ? fromLive : baked;
              const dur = 1100;
              const t0 = performance.now();
              const tick = (now: number) => {
                const p = Math.min(1, (now - t0) / dur);
                const eased = 1 - Math.pow(1 - p, 3);
                el.textContent = fmt(target * eased);
                if (p < 1) requestAnimationFrame(tick);
                else el.textContent = fmt(target);
              };
              requestAnimationFrame(tick);
            });
          });
        }, { threshold: 0.4 });
        io.observe(el);
      });

      // ── FAQ accordion (single-open) ──
      const faqItems = Array.from(document.querySelectorAll<HTMLElement>('.faq-item'));
      faqItems.forEach((item) => {
        const q = item.querySelector('.faq-q');
        q?.addEventListener('click', () => {
          const isOpen = item.classList.contains('open');
          faqItems.forEach((i) => {
            i.classList.remove('open');
            i.querySelector('.faq-q')?.setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            item.classList.add('open');
            q.setAttribute('aria-expanded', 'true');
          }
        });
      });

      // ── Copy: command blocks ──
      document.querySelectorAll<HTMLElement>('.cmd').forEach((btn) => {
        btn.addEventListener('click', () => {
          const text = btn.dataset.cmd || btn.querySelector('.text')?.textContent || '';
          navigator.clipboard?.writeText(text).catch(() => {});
          btn.classList.add('copied');
          const c = btn.querySelector('.copy');
          const orig = c?.textContent;
          if (c) c.textContent = btn.dataset.copied || '✓ copied';
          setTimeout(() => { btn.classList.remove('copied'); if (c) c.textContent = orig; }, 1400);
        });
      });

      // ── Copy: code blocks ──
      document.querySelectorAll<HTMLElement>('.ds-codeblock__copy').forEach((btn) => {
        btn.addEventListener('click', () => {
          navigator.clipboard?.writeText(btn.dataset.clip || '').catch(() => {});
          btn.classList.add('copied');
          const orig = btn.textContent;
          btn.textContent = btn.dataset.copied || '✓ copied';
          setTimeout(() => { btn.classList.remove('copied'); btn.textContent = orig; }, 1400);
        });
      });
    </script>
</BaseLayout>
