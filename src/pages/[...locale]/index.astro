---
// OMA landing page (open-multi-agent.com homepage).
// Ported 1:1 from the Claude Design system (bfaf7892) export, with the
// fact-check corrections agreed in the handoff:
//   • §3 global nav (Product ▾ open-multi-agent + oma-forge / Docs / Architecture / Examples / Showcase / Blog / GitHub)
//   • Production-proof cases rewritten from the OMA README ecosystem section
//     (temodar = security · on Docker Hub; Engram + @agentsonar = integrations)
//   • team.ts code uses the REAL published API (AgentConfig.name, real tool names, methods)
//   • Live GitHub stats fetched at build time (no hard-coded precise numbers)
//   • "see code" links point to real cookbook examples in the repo
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../styles/tokens.css';
import '../../styles/landing.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/ds/Badge.astro';
import Card from '../../components/ds/Card.astro';
import TaskNode from '../../components/ds/TaskNode.astro';
import heroRunEn from '../../data/hero-run.json';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import EnterpriseLink from '../../components/EnterpriseLink.astro';
import { REPO, NPM, ghStats } from '../../lib/site';
import { SHOWCASE } from '../../lib/showcase';
import { detailSlugs, getFeaturedUseCases } from '../../lib/examples';
import { localeStaticPaths, toLocale, useTranslations, localizePath } from '../../i18n';

export function getStaticPaths() { return localeStaticPaths(); }
const locale = toLocale(Astro.params.locale);
const t = useTranslations(locale);
const l = t.landing;
const L = (p: string) => localizePath(p, locale);

// Hero renders a REAL captured runTeam() DAG. zh uses a Chinese-goal capture
// (src/data/hero-run.zh.json) when it exists; until that capture lands, zh falls
// back to the English run so the build stays green. Never hand-edit the JSON to
// fake a localized run (PRD §4.1 ①).
const heroRunZhFiles = import.meta.glob('../../data/hero-run.zh.json', { eager: true, import: 'default' });
const heroRun = (locale === 'zh' ? (heroRunZhFiles['../../data/hero-run.zh.json'] ?? heroRunEn) : heroRunEn) as typeof heroRunEn;

// REPO / NPM constants and ghStats() now live in ../../lib/site (shared with the
// Nav/Footer components and the /examples page). FORGE is only used by Nav.
const stats = await ghStats();
const fmt = (n: number) => n.toLocaleString('en-US');
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

// ── Hero right-visual: a REAL captured runTeam() DAG. The nodes below are
//    rendered from src/data/hero-run.json, produced by a real provider run
//    (scripts/capture-hero-dag.mjs) — no hand-built mockup (PRD §4.1 ①). The
//    snippet's goal is the exact goal that produced the DAG shown. ──
// The compact artifact still renders the exact captured goal. Newlines in the
// localized capture collapse to spaces only for display; the underlying run
// data and every task node remain unchanged.
const heroGoalSummary = heroRun.goal.replace(/\s+/g, ' ').trim();

// Group the captured tasks into dependency levels (depth = longest path from a
// root). Same-depth tasks ran in parallel; this drives the DAG layout below.
const heroById = new Map(heroRun.tasks.map((t) => [t.id, t]));
const heroDepthCache = new Map<string, number>();
const heroDepth = (t: (typeof heroRun.tasks)[number]): number => {
  const cached = heroDepthCache.get(t.id);
  if (cached !== undefined) return cached;
  const deps = (t.dependsOn ?? []).filter((id) => heroById.has(id));
  const d = deps.length === 0 ? 0 : 1 + Math.max(...deps.map((id) => heroDepth(heroById.get(id)!)));
  heroDepthCache.set(t.id, d);
  return d;
};
const heroMaxDepth = Math.max(...heroRun.tasks.map(heroDepth));
const heroLevels = Array.from({ length: heroMaxDepth + 1 }, (_, d) =>
  heroRun.tasks.filter((t) => heroDepth(t) === d),
);
const heroStatusMap: Record<string, 'done' | 'running' | 'queued' | 'failed' | 'skipped'> = {
  completed: 'done', in_progress: 'running', pending: 'queued', failed: 'failed', skipped: 'skipped', blocked: 'queued',
};
const heroDur = (ms: number | null) => (ms == null ? null : (ms / 1000).toFixed(1) + 's');
const heroNodeId = (id: string) => '#' + id.slice(0, 8);
const heroWallS = Math.round(heroRun.wallMs / 1000);

// ── Production proof uses the three "Built with OMA" apps from the shared
//    showcase list. The full inventory, integrations, and practitioner spotlight
//    remain on /showcase; the homepage keeps only three representative projects. ──
const CASES = SHOWCASE.filter((c) => ['temodar-agent', 'PR-Copilot', 'StuFlow'].includes(c.pkg));
const scEntries = t.showcase.entries;
const caseTr = (c: (typeof SHOWCASE)[number]) => scEntries[c.pkg] ?? { desc: c.desc, tag: c.tag, status: c.status };

// Section copy lives in the per-locale dictionary (src/i18n); the markup below
// renders it via `l`. Every API name / code identifier inside the copy stays
// verbatim (see src/i18n/en.ts; the reliability surface is verified against
// open-multi-agent core v1.12.1 and @open-multi-agent/otel v0.1.0).
const WHY = l.why;

// The first three featured Use-case Recipes come from catalog featuredOrder.
// URLs resolve from the synchronized inventory; localized editorial copy stays
// keyed by stable catalog id so ordering cannot pair the wrong claim and source.
const buildDetailSlugs = detailSlugs();
const buildCopy = l.builds as Record<string, (typeof l.builds)[keyof typeof l.builds]>;
const BUILDS = getFeaturedUseCases().flatMap((example) => {
  const copy = buildCopy[example.id];
  if (!copy) return [];
  const internal = buildDetailSlugs.has(example.id);
  return [{
    ...copy,
    slug: example.id,
    code: internal ? L(`/examples/${example.id}/`) : example.href,
    external: !internal,
  }];
});

// Keep the visible set focused on runtime decisions not already answered by the
// capability cards. In particular, the cost answer must surface maxCostBudget;
// model mixing is already covered in capability 02 and the stack section.
const FAQS = [l.faqs[0], l.faqs[3], l.faqs[5]];

const title = l.seo.title;
const description = l.seo.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// ── JSON-LD structured data (PRD §4.6 GEO) ──
// SoftwareApplication + Organization + FAQPage in one @graph. The FAQPage
// reuses the FAQS array above verbatim, so the markup always matches the
// visible FAQ section (Google requires structured-data ↔ on-page parity).
// No aggregateRating: there is no real rating data, and inventing one would
// violate red-line §5.1. `offers` (free/MIT) makes the entry rich-eligible.
const orgId = new URL('/#organization', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: 'YuanASI',
      alternateName: '元定义科技',
      url: 'https://yuanasi.com',
      logo: new URL('/logo-mark-dark.svg', Astro.site).href,
    },
    {
      '@type': 'SoftwareApplication',
      '@id': new URL('/#software', Astro.site).href,
      name: 'Open Multi-Agent',
      alternateName: ['OMA', '@open-multi-agent/core'],
      description,
      inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Node.js 18+',
      url: new URL('/', Astro.site).href,
      downloadUrl: NPM,
      codeRepository: REPO,
      programmingLanguage: 'TypeScript',
      license: 'https://opensource.org/licenses/MIT',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      author: { '@id': orgId },
      publisher: { '@id': orgId },
      sameAs: [REPO, NPM],
    },
    {
      '@type': 'FAQPage',
      '@id': new URL('/#faq', Astro.site).href,
      mainEntity: FAQS.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path="/">
  <!-- ── Nav (§3 global) — shared component ── -->
  <Nav current="home" starsK={starsK} locale={locale} path="/" />

    <main>
      <!-- ── 1. Hero ── -->
      <header class="hero" id="top">
        <div class="container hero-grid">
          <div>
            <div class="eyebrow"><span class="idx">//</span> {l.hero.eyebrow}</div>
            <h1>{l.hero.h1}<span class="accent">{l.hero.h1Accent}</span></h1>
            <p class="hero-sub" set:html={l.hero.sub}></p>
            <div class="hero-meta"><b>{l.hero.meta[0]}</b><span class="sep">·</span><b>{l.hero.meta[1]}</b><span class="sep">·</span><b>{l.hero.meta[2]}</b></div>
            <div class="hero-cta">
              <a class="btn-primary hero-cta-primary" href={L('/getting-started/quick-start/')} data-landing-event="quick-start-hero"><span>{l.hero.quickStart}</span><span class="arrow" aria-hidden="true">→</span></a>
              <div class="cmd-wrap">
                <button type="button" class="cmd" data-cmd="npm create oma-app@latest my-oma" data-copied={l.copied} data-failed={l.copyFailed} data-landing-event="copy-command-hero">
                  <span class="sr-only">{l.copy} </span><span class="prompt">$</span><span class="text">npm create oma-app@latest my-oma</span><span class="copy" aria-hidden="true" title={l.copy}><svg class="copy-i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg><svg class="check-i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span>
                </button>
                <span class="copy-feedback" aria-live="polite"></span>
                <span class="cmd-note">{l.hero.demoNote}</span>
              </div>
            </div>
          </div>
          <div>
            <div class="io-panel">
              <div class="io-cap"><span>team.ts · goal</span><span style="color:var(--oma-accent);">{l.hero.ioGoal}</span></div>
              <details class="artifact-goal">
                <summary>
                  <span class="artifact-goal-head">
                    <span class="artifact-goal-label">{l.hero.capturedGoal}</span>
                    <span class="artifact-goal-action">
                      <span class="artifact-goal-expand">{l.hero.expandGoal}</span>
                      <span class="artifact-goal-collapse">{l.hero.collapseGoal}</span>
                      <span class="artifact-goal-icon" aria-hidden="true">+</span>
                    </span>
                  </span>
                  <span class="artifact-goal-preview" aria-hidden="true">{heroGoalSummary}</span>
                </summary>
                <div class="artifact-goal-full">
                  <p>{heroRun.goal}</p>
                </div>
              </details>
              <div class="io-connector"><span class="line"></span>{l.hero.decomposesInto}<span class="line"></span></div>
              <div class="dag-desktop">
                <div class="dag-stack">
                  {heroLevels.map((level, li) => (
                    <Fragment>
                      {li > 0 && <div class="dag-link"></div>}
                      {level.length > 1 ? (
                        <div class="dag-parallel">
                          <span class="dag-parallel-tag">{l.hero.parallel}</span>
                          {level.map((t) => (
                            <TaskNode compact id={heroNodeId(t.id)} title={t.title} status={heroStatusMap[t.status] ?? 'done'} duration={heroDur(t.durationMs)} role={t.assignee} locale={locale} />
                          ))}
                        </div>
                      ) : (
                        <TaskNode compact id={heroNodeId(level[0].id)} title={level[0].title} status={heroStatusMap[level[0].status] ?? 'done'} duration={heroDur(level[0].durationMs)} role={level[0].assignee} locale={locale} />
                      )}
                    </Fragment>
                  ))}
                </div>
              </div>
              <details class="dag-mobile">
                <summary>
                  <span class="dag-mobile-task"><code>{heroNodeId(heroRun.tasks[0].id)}</code><b>{heroRun.tasks[0].title}</b></span>
                  <span class="dag-mobile-more">{l.hero.expandTasks.replace('{count}', String(heroRun.tasks.length - 1))}</span>
                </summary>
                <div class="dag-stack">
                  {heroLevels.map((level, li) => (
                    <Fragment>
                      {li > 0 && <div class="dag-link"></div>}
                      {level.length > 1 ? (
                        <div class="dag-parallel">
                          <span class="dag-parallel-tag">{l.hero.parallel}</span>
                          {level.map((t) => (
                            <TaskNode compact id={heroNodeId(t.id)} title={t.title} status={heroStatusMap[t.status] ?? 'done'} duration={heroDur(t.durationMs)} role={t.assignee} locale={locale} />
                          ))}
                        </div>
                      ) : (
                        <TaskNode compact id={heroNodeId(level[0].id)} title={level[0].title} status={heroStatusMap[level[0].status] ?? 'done'} duration={heroDur(level[0].durationMs)} role={level[0].assignee} locale={locale} />
                      )}
                    </Fragment>
                  ))}
                </div>
              </details>
              <div class="dag-meta">
                <span class="dag-meta-dot"></span>
                <span>{l.hero.runReal} <code>runTeam()</code> · {heroRun.model} · {heroRun.tasks.length} {l.hero.runTasks} · {heroWallS}s</span>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- ── 2. Why OMA: the former control, environment, and capability
           sections condensed into one decision-oriented block. ── -->
      <section class="section home-section" id="reliability">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">01</span> {l.sectionWhy.eyebrow}</div>
            <h2 class="section-title">{l.sectionWhy.title}</h2>
            <p class="section-sub">{l.sectionWhy.sub}</p>
          </div>
          <span id="capabilities" class="anchor-target" aria-hidden="true"></span>
          <span id="environment" class="anchor-target" aria-hidden="true"></span>
          <span id="stack" class="anchor-target" aria-hidden="true"></span>
          <div class="why-grid">
            {WHY.map((item, index) => (
              <Card padding="lg" class="why-card">
                <div class="why-card-top">
                  <span class="why-num">{String(index + 1).padStart(2, '0')}</span>
                  <span class="why-tag">{item.tag}</span>
                </div>
                <div class="why-title">{item.title}</div>
                <p class="why-desc">{item.desc}</p>
                <code class="why-proof">{item.proof}</code>
                <div class="why-foot"><a class="text-link" href={L(item.ref)}><span>{item.refLabel}</span><span class="arrow">→</span></a></div>
              </Card>
            ))}
          </div>
          <figure class="why-viewer">
            <figcaption class="why-viewer-copy">
              <div class="evidence-label">{l.whyViewer.eyebrow}</div>
              <h3>{l.whyViewer.title}</h3>
              <p>{l.whyViewer.body}</p>
              <ul>
                {l.whyViewer.points.map((point) => <li>{point}</li>)}
              </ul>
              <a class="text-link" href={L('/reference/observability/')}><span>{l.whyViewer.link}</span><span class="arrow">→</span></a>
            </figcaption>
            <div class="why-viewer-media">
              {/* The web-optimized MP4 is transcoded from the real Run Viewer
                  capture in public/demo-dashboard.gif. Lazy loading keeps it
                  outside the hero's critical path. */}
              <video width="1600" height="900" autoplay muted loop playsinline preload="none" aria-label={l.dashboard.imgAlt} data-lazy-video>
                <source data-src="/demo-dashboard.mp4" type="video/mp4" />
              </video>
              <noscript><img src="/demo-dashboard.gif" width="1600" height="900" loading="lazy" decoding="async" alt={l.dashboard.imgAlt} /></noscript>
            </div>
          </figure>
        </div>
      </section>

      <!-- ── 3. Representative workflows ── -->
      <section class="section home-section" id="build">
        <div class="container">
          <div class="section-head section-head-row">
            <div>
              <div class="eyebrow"><span class="idx">02</span> {l.sectionBuild.eyebrow}</div>
              <h2 class="section-title">{l.sectionBuild.title}</h2>
              <p class="section-sub">{l.sectionBuild.sub}</p>
            </div>
            <a class="text-link section-head-link" href={L('/examples/')}><span>{l.sectionBuild.viewAll}</span><span class="arrow">→</span></a>
          </div>
          <div class="build-grid">
            {BUILDS.map((b) => (
              <a class="case-link" href={b.code} target={b.external ? '_blank' : undefined} rel={b.external ? 'noreferrer' : undefined} style="text-decoration:none;">
                <Card padding="md" interactive class="build-card">
                  <div class="build-kicker"><span>{b.scenario}</span><code>{b.primitive}</code></div>
                  <div class="build-title">{b.title}</div>
                  <p class="build-desc">{b.desc}</p>
                  <div class="build-outcome"><span class="arrow">▸</span><span>{b.outcome}</span></div>
                  <div class="build-foot"><span class="text-link"><span>{l.sectionBuild.seeCode}</span><span class="arrow">→</span></span></div>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ── 4. Adoption proof: repo data, three projects, one attributed quote ── -->
      <section class="section home-section proof-section" id="proof">
        <div class="container">
          <div class="section-head section-head-row proof-head">
            <div>
              <div class="eyebrow"><span class="idx">03</span> {l.sectionProof.eyebrow}</div>
              <h2 class="section-title">{l.sectionProof.title}</h2>
              <p class="section-sub">{l.sectionProof.sub}</p>
            </div>
            <div class="proof-actions">
              <div class="live-tag"><span class="live-dot"></span> {l.sectionProof.liveTag}</div>
              <a class="text-link" href={L('/showcase/')}><span>{l.sectionEvidence.fullShowcase}</span><span class="arrow">→</span></a>
            </div>
          </div>
          <div class="stats-row">
            <div class="stat"><div class="stat-val"><span class="unit">★ </span><span data-count={stats.stars} data-live="stars">{fmt(stats.stars)}</span></div><div class="stat-key">{l.sectionProof.stats.stars}</div></div>
            <div class="stat"><div class="stat-val"><span data-count={stats.forks} data-live="forks">{fmt(stats.forks)}</span></div><div class="stat-key">{l.sectionProof.stats.forks}</div></div>
            <div class="stat"><div class="stat-val"><span data-count={stats.contributors}>{fmt(stats.contributors)}</span></div><div class="stat-key">{l.sectionProof.stats.contributors}</div></div>
            <div class="stat"><a href={REPO + '/releases'} target="_blank" rel="noreferrer" style="color:inherit;text-decoration:none;"><div class="stat-val">{stats.latestRelease}</div><div class="stat-key">{l.sectionProof.stats.latestRelease}</div></a></div>
            <div class="stat"><div class="stat-val">MIT</div><div class="stat-key">{l.sectionProof.stats.license}</div></div>
          </div>
          <div class="cases-grid proof-cases">
            {CASES.map((c) => (
              <a class="case-link" href={c.href} target="_blank" rel="noreferrer" style="text-decoration:none;">
                <Card padding="md" interactive>
                  <div class="case-pkg">{c.pkg}</div>
                  <div class="case-by">{c.by}</div>
                  <p class="case-desc">{caseTr(c).desc}</p>
                  <div class="case-foot">
                    <Badge tone={c.tone}>{caseTr(c).tag}</Badge>
                    <span class="case-dep">{caseTr(c).status}</span>
                  </div>
                </Card>
              </a>
            ))}
          </div>
          <a class="proof-quote" href="https://www.youtube.com/watch?v=2cdpYJzPXWE&t=331s" target="_blank" rel="noreferrer">
            <blockquote>{l.endorse.quote}</blockquote>
            <span class="proof-quote-cite">{l.endorse.cite}</span>
            <span class="proof-quote-action">{l.sectionProof.watchMention} →</span>
          </a>
        </div>
      </section>

      <!-- ── 5. FAQ ── -->
      <section class="section home-section" id="faq">
        <div class="container">
          <div class="faq-grid">
            <div class="section-head faq-head">
              <div class="eyebrow"><span class="idx">04</span> {l.sectionFaq.eyebrow}</div>
              <h2 class="section-title">{l.sectionFaq.title}</h2>
              <p class="section-sub">{l.sectionFaq.sub}</p>
              <div class="faq-head-foot">
                <a class="text-link" href={REPO + '#how-is-this-different-from-x'} target="_blank" rel="noreferrer"><span>{l.sectionFaq.viewAll}</span><span class="arrow">→</span></a>
                <span data-landing-event="enterprise-faq"><EnterpriseLink class="text-link" locale={locale}><span>{t.enterpriseCta.button}</span><span class="arrow" aria-hidden="true">→</span></EnterpriseLink></span>
              </div>
            </div>
            <div class="faq-list">
              {FAQS.map((f, i) => (
                <div class="faq-item">
                  <button type="button" class="faq-q" id={`faq-trigger-${i}`} aria-expanded="false" aria-controls={`faq-panel-${i}`}>
                    <span>{f.q}</span><span class="faq-icon" aria-hidden="true">+</span>
                  </button>
                  <div class="faq-a" id={`faq-panel-${i}`} role="region" aria-labelledby={`faq-trigger-${i}`} aria-hidden="true"><div class="faq-a-inner">{f.a}</div></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- ── 6. Final CTA ── -->
      <section class="section" id="start">
        <div class="container cta-final">
          <div class="eyebrow" style="justify-content:center;"><span class="idx">05</span> {l.ctaFinal.eyebrow}</div>
          <h2 class:list={['cta-final-title', { 'cta-final-title--zh': locale === 'zh' }]}>
            <span class="cta-final-title-line">{l.ctaFinal.title1}</span>
            <span class="cta-final-title-line">{l.ctaFinal.title2}</span>
          </h2>
          <div class="cta-actions">
            <a class="btn-primary" href={L('/getting-started/quick-start/')} data-landing-event="quick-start-final"><span>{l.ctaFinal.quickStart}</span><span class="arrow" aria-hidden="true">→</span></a>
            <div class="cmd-wrap">
              <button type="button" class="cmd" data-cmd="npm create oma-app@latest my-oma" data-copied={l.copied} data-failed={l.copyFailed} data-landing-event="copy-command-final">
                <span class="sr-only">{l.copy} </span><span class="prompt">$</span><span class="text">npm create oma-app@latest my-oma</span><span class="copy" aria-hidden="true" title={l.copy}><svg class="copy-i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg><svg class="check-i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span>
              </button>
              <span class="copy-feedback" aria-live="polite"></span>
              <span class="cmd-note">{l.hero.demoNote}</span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- ── Footer — shared component ── -->
    <Footer locale={locale} />

    <script>
      // ── Stats count-up on scroll ──
      // 动画终点优先用客户端实时抓取的 GitHub 数(stars/forks),fetch 失败或
      // 超时则回退到构建期烤进 data-count 的值。因为动画本来就是 0→终点,把
      // 终点换成实时值不会有数字跳变 —— 滚动动画天然掩护了「构建期值 → 实时值」
      // 的差异。无 JS / 抓取失败的访客看到的就是构建期值(合理 fallback)。
      const fmt = (n: number) => Math.round(n).toLocaleString('en-US');

      // fetch 推迟到 window load 之后才发起:模块顶层立即 fetch 会把 api.github.com
      // 拉进 Lighthouse 的关键请求链(实测占 0.9–1.3s 的 max critical path)。stats
      // 区域在首屏之下,用户滚到那里远晚于 load,所以推迟不改变动画体验。
      const afterLoad = (fn: () => void) => {
        if (document.readyState === 'complete') fn();
        else addEventListener('load', () => fn(), { once: true });
      };

      // Counterscale's current browser API records pageviews only. Keep CTA
      // measurement on the existing Baidu event channel and expose a DOM event
      // so another first-party collector can subscribe later without changing
      // the markup again.
      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element
          ? event.target.closest<HTMLElement>('[data-landing-event]')
          : null;
        const name = target?.dataset.landingEvent;
        if (!name) return;
        const detail = { name, locale: document.documentElement.lang || 'en' };
        window.dispatchEvent(new CustomEvent('oma:landing-event', { detail }));
        const baiduQueue = (window as typeof window & { _hmt?: unknown[][] })._hmt;
        baiduQueue?.push(['_trackEvent', 'landing', name, detail.locale]);
      });

      type LiveCounts = { stars: number; forks: number };
      let resolveLive: (v: LiveCounts | null) => void;
      const live: Promise<LiveCounts | null> = new Promise((res) => (resolveLive = res));
      afterLoad(() =>
        fetch('https://api.github.com/repos/open-multi-agent/open-multi-agent', {
          headers: { Accept: 'application/vnd.github+json' },
        })
          .then((r) => (r.ok ? r.json() : null))
          .then((j: any) =>
            resolveLive(
              j && typeof j.stargazers_count === 'number'
                ? { stars: j.stargazers_count, forks: j.forks_count }
                : null,
            ),
          )
          .catch(() => resolveLive(null)),
      );

      // 滚到该区域时实时值还没回来,最多等 800ms(自 fetch 发起时刻起算)就用
      // 构建期值,避免动画卡住。
      const liveOrTimeout: Promise<LiveCounts | null> = Promise.race([
        live,
        new Promise<null>((res) => afterLoad(() => setTimeout(() => res(null), 800))),
      ]);

      document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
        const baked = parseInt(el.dataset.count || '0', 10);
        const liveKey = el.dataset.live as keyof LiveCounts | undefined;
        const io = new IntersectionObserver((entries, obs) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            obs.disconnect();
            liveOrTimeout.then((data) => {
              const fromLive = data && liveKey ? data[liveKey] : undefined;
              const target = typeof fromLive === 'number' && fromLive > 0 ? fromLive : baked;
              const dur = 1100;
              const t0 = performance.now();
              const tick = (now: number) => {
                const p = Math.min(1, (now - t0) / dur);
                const eased = 1 - Math.pow(1 - p, 3);
                el.textContent = fmt(target * eased);
                if (p < 1) requestAnimationFrame(tick);
                else el.textContent = fmt(target);
              };
              requestAnimationFrame(tick);
            });
          });
        }, { threshold: 0.4 });
        io.observe(el);
      });

      // ── FAQ accordion (single-open) ──
      const faqItems = Array.from(document.querySelectorAll<HTMLElement>('.faq-item'));
      faqItems.forEach((item) => {
        const q = item.querySelector('.faq-q');
        q?.addEventListener('click', () => {
          const isOpen = item.classList.contains('open');
          faqItems.forEach((i) => {
            i.classList.remove('open');
            i.querySelector('.faq-q')?.setAttribute('aria-expanded', 'false');
            i.querySelector('.faq-a')?.setAttribute('aria-hidden', 'true');
          });
          if (!isOpen) {
            item.classList.add('open');
            q.setAttribute('aria-expanded', 'true');
            item.querySelector('.faq-a')?.setAttribute('aria-hidden', 'false');
          }
        });
      });

      // ── Copy: command blocks ──
      const copyText = async (text: string) => {
        if (!navigator.clipboard?.writeText) return false;
        try {
          await navigator.clipboard.writeText(text);
          return true;
        } catch {
          return false;
        }
      };

      document.querySelectorAll<HTMLElement>('.cmd').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const text = btn.dataset.cmd || btn.querySelector('.text')?.textContent || '';
          const feedback = btn.closest('.cmd-wrap')?.querySelector<HTMLElement>('.copy-feedback');
          const ok = await copyText(text);
          btn.classList.toggle('copied', ok);
          btn.classList.toggle('copy-failed', !ok);
          if (feedback) feedback.textContent = ok ? (btn.dataset.copied || '') : (btn.dataset.failed || '');
          setTimeout(() => {
            btn.classList.remove('copied', 'copy-failed');
            if (feedback) feedback.textContent = '';
          }, ok ? 1400 : 2800);
        });
      });

      // ── Copy: code blocks ──
      document.querySelectorAll<HTMLElement>('.ds-codeblock__copy').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const orig = btn.textContent;
          const ok = await copyText(btn.dataset.clip || '');
          const status = btn.parentElement?.querySelector<HTMLElement>('.ds-codeblock__status');
          btn.classList.toggle('copied', ok);
          btn.classList.toggle('copy-failed', !ok);
          btn.textContent = ok ? (btn.dataset.copied || '✓ copied') : (btn.dataset.failed || 'Copy failed');
          if (status) status.textContent = btn.textContent;
          setTimeout(() => {
            btn.classList.remove('copied', 'copy-failed');
            btn.textContent = orig;
            if (status) status.textContent = '';
          }, ok ? 1400 : 2800);
        });
      });

      // ── Lazy video (dashboard demo) ──
      // Sources ship with data-src only; swap in + load when the video nears the
      // viewport (400px margin ≈ in-flight before it scrolls into view). play() is
      // a belt-and-braces nudge — autoplay+muted already covers the normal path.
      document.querySelectorAll<HTMLVideoElement>('video[data-lazy-video]').forEach((v) => {
        const io = new IntersectionObserver((entries, obs) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            obs.disconnect();
            v.querySelectorAll<HTMLSourceElement>('source[data-src]').forEach((s) => {
              s.src = s.dataset.src || '';
            });
            v.load();
            v.play().catch(() => {});
          });
        }, { rootMargin: '400px' });
        io.observe(v);
      });
    </script>
</BaseLayout>
