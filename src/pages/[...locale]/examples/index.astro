---
// /examples — the example gallery (PRD §4.3). Same self-contained landing-style
// shell as index.astro (shared Nav/Footer), but the content is built entirely
// from the framework catalog via getExamples() — no hand-maintained list or
// physical-path classification. English catalog titles/descriptions are the
// fallback; the Chinese dictionary may provide faithful display overrides.
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../../styles/tokens.css';
import '../../../styles/landing.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/ds/Card.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import EnterpriseCta from '../../../components/EnterpriseCta.astro';
import EnterpriseHeadCta from '../../../components/EnterpriseHeadCta.astro';
import { REPO, ghStats } from '../../../lib/site';
import {
  detailSlugs,
  getExampleGoalGroups,
  getExamples,
  getModelsProviderExamples,
  splitGoalEntries,
  type CatalogExample,
  type ExampleGoal,
} from '../../../lib/examples';
import { localeStaticPaths, localizePath, toLocale, useTranslations } from '../../../i18n';

export function getStaticPaths() { return localeStaticPaths(); }
const locale = toLocale(Astro.params.locale);
const t = useTranslations(locale);
const ex_t = t.examples;

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';
const ex = await getExamples();
const goalGroups = getExampleGoalGroups(ex);
const modelsProviders = getModelsProviderExamples(ex);

const L = (p: string) => localizePath(p, locale);
// Entries that have a detail page (/examples/<slug>/) link in-site; the rest keep
// linking out to GitHub. detailSlugs() is empty when the source snapshot is
// missing, so this degrades gracefully to the old all-external behavior.
const dset = detailSlugs();
const hrefFor = (e: CatalogExample) =>
  dset.has(e.id) ? L(`/examples/${e.id}/`) : e.href;
const isExternal = (e: CatalogExample) => !dset.has(e.id);
const detailUrl = (e: CatalogExample) =>
  dset.has(e.id) ? new URL(L(`/examples/${e.id}/`), Astro.site).href : e.href;

// zh index overrides (short title + blurb), keyed by slug; en's map is empty so
// each entry falls back to the English title/description from the catalog.
const ent = t.examples.entries;
const entTitle = (e: CatalogExample) => ent[e.id]?.title ?? e.title;
const entDescription = (e: CatalogExample) => ent[e.id]?.blurb ?? e.description;

const legacyAnchors: Record<ExampleGoal, string[]> = {
  'start-here': ['building-blocks'],
  'use-case-recipes': ['cookbook'],
  orchestration: [],
  'production-controls': [],
  'connect-your-stack': ['integrations'],
};
const entryMeta = (entry: CatalogExample) =>
  `${ex_t.formats[entry.format]} · ${ex_t.levels[entry.level]}`;

const EXAMPLES_GH = REPO + '/tree/main/packages/core/examples';

const title = ex_t.seo.title;
const description = ex_t.seo.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
  name: title,
  description,
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
  ...(ex
    ? {
        mainEntity: {
          '@type': 'ItemList',
          itemListElement: ex.entries.map((e, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            name: entTitle(e),
            url: detailUrl(e),
          })),
        },
      }
    : {}),
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path="/examples/">
  <Nav current="examples" starsK={starsK} locale={locale} path="/examples/" />

  <main>
    <!-- ── Page head ── -->
    <header class="ex-hero">
      <div class="container">
        <div class="hero-head-row">
          <div class="hero-head-text">
            <div class="eyebrow"><span class="idx">//</span> {ex_t.hero.eyebrow}</div>
            <h1 class="ex-title">{ex_t.hero.title}</h1>
            <p class="ex-lede">{ex_t.hero.lede}</p>
          </div>
          <EnterpriseHeadCta locale={locale} />
        </div>
      </div>
    </header>

    {ex && (
      <nav class="ex-goal-nav" aria-label={ex_t.goalNav.label}>
        <div class="container">
          <div class="ex-goal-nav-label">{ex_t.goalNav.label}</div>
          <div class="ex-goal-nav-grid">
            {goalGroups.map((group, groupIndex) => {
              const label = ex_t.goals[group.goal].eyebrow;
              return (
                <a
                  class="ex-goal-nav-link"
                  href={`#${group.goal}`}
                  aria-label={`${label}: ${group.entries.length} ${ex_t.goalNav.examples}`}
                >
                  <span class="idx">{String(groupIndex + 1).padStart(2, '0')}</span>
                  <span class="label">{label}</span>
                  <span class="count">{group.entries.length}</span>
                </a>
              );
            })}
            <a
              class="ex-goal-nav-link"
              href="#models-providers"
              aria-label={`${ex_t.modelsProviders.eyebrow}: ${modelsProviders.length} ${ex_t.goalNav.examples}`}
            >
              <span class="idx">06</span>
              <span class="label">{ex_t.modelsProviders.eyebrow}</span>
              <span class="count">{modelsProviders.length}</span>
            </a>
          </div>
        </div>
      </nav>
    )}

    {ex ? (
      <Fragment>
        {goalGroups.map((group, groupIndex) => {
          const copy = ex_t.goals[group.goal];
          const { primary, remaining: more } = splitGoalEntries(group);
          return (
            <section class={`section${groupIndex === 0 ? ' ex-first' : ''}`} id={group.goal}>
              {legacyAnchors[group.goal].map((anchor) => (
                <span class="legacy-anchor" id={anchor} aria-hidden="true"></span>
              ))}
              <div class="container">
                <div class="section-head">
                  <div class="eyebrow"><span class="idx">{String(groupIndex + 1).padStart(2, '0')}</span> {copy.eyebrow}</div>
                  <h2 class="section-title">{copy.title}</h2>
                  <p class="section-sub">{copy.sub}</p>
                </div>

                <div class="build-grid ex-featured-grid">
                  {primary.map((entry) => (
                    <a class="case-link" href={hrefFor(entry)} target={isExternal(entry) ? '_blank' : undefined} rel={isExternal(entry) ? 'noreferrer' : undefined} style="text-decoration:none;">
                      <Card padding="lg" interactive>
                        <div class="ex-card-meta">{entryMeta(entry)}</div>
                        <div class="build-title">{entTitle(entry)}</div>
                        <p class="build-desc">{entDescription(entry)}</p>
                        <div class="ex-capabilities">
                          {entry.capabilities.slice(0, 3).map((capability) => <code>{capability}</code>)}
                        </div>
                        <div class="build-foot">
                          <span class="text-link"><span>{ex_t.openExample}</span><span class="arrow">→</span></span>
                        </div>
                      </Card>
                    </a>
                  ))}
                </div>

                {more.length > 0 && (
                  <div class="ex-group">
                    <div class="ex-subhead">{group.goal === 'start-here' ? ex_t.advancedComposition : ex_t.moreInGoal}</div>
                    <div class="ex-list">
                      {more.map((entry) => (
                        <a class="ex-row" href={hrefFor(entry)} target={isExternal(entry) ? '_blank' : undefined} rel={isExternal(entry) ? 'noreferrer' : undefined}>
                          <span class="name">{entTitle(entry)}</span>
                          <span class="desc">{entDescription(entry)}</span>
                          <span class="meta">{entryMeta(entry)}</span>
                          <span class="arr">→</span>
                        </a>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </section>
          );
        })}

        <section class="section" id="models-providers">
          <span class="legacy-anchor" id="more" aria-hidden="true"></span>
          <div class="container">
            <div class="section-head">
              <div class="eyebrow"><span class="idx">06</span> {ex_t.modelsProviders.eyebrow}</div>
              <h2 class="section-title">{ex_t.modelsProviders.title}</h2>
              <p class="section-sub">{ex_t.modelsProviders.sub}</p>
            </div>
            <div class="ex-provider-grid">
              {modelsProviders.map((entry) => (
                <a class="ex-provider" href={entry.href} target="_blank" rel="noreferrer" title={entDescription(entry)}>
                  <span class="name">{entTitle(entry)}</span>
                  <span class="flags">
                    {entry.capabilities.includes('local-models') && <span>{ex_t.modelsProviders.local}</span>}
                    {entry.capabilities.includes('openai-compatible') && <span>{ex_t.modelsProviders.compatible}</span>}
                  </span>
                  <span class="arr">↗</span>
                </a>
              ))}
            </div>
            <p class="ex-foot">
              {ex_t.footPre}<code>{ex_t.footCode}</code>{ex_t.footPost}<a class="text-link inline" href={ex.browseHref} target="_blank" rel="noreferrer"><span>{ex_t.browseAll}</span><span class="arrow">→</span></a>
            </p>
          </div>
        </section>
      </Fragment>
    ) : (
      <section class="section ex-first">
        <div class="container">
          <div class="ex-empty">
            <h2>{ex_t.unavailable.title}</h2>
            <p>{ex_t.unavailable.desc}</p>
            <a class="text-link inline" href={EXAMPLES_GH} target="_blank" rel="noreferrer"><span>{ex_t.browseAll}</span><span class="arrow">→</span></a>
          </div>
        </div>
      </section>
    )}

    <EnterpriseCta locale={locale} />
  </main>

  <Footer locale={locale} />
</BaseLayout>

<style>
  .ex-hero { padding: 72px 0 8px; }
  .ex-hero .hero-head-row { margin-bottom: 0; }
  .ex-title {
    font-size: clamp(34px, 5vw, 52px); font-weight: 600; letter-spacing: -0.03em;
    line-height: 1.05; color: var(--oma-fg-0); margin: 16px 0 0;
  }
  .ex-lede { font-size: 17px; line-height: 1.6; color: var(--oma-fg-1); margin: 18px 0 0; max-width: 680px; }
  .ex-first { padding-top: 56px; }
  .legacy-anchor { display: block; position: relative; top: -84px; height: 0; visibility: hidden; }
  section[id] { scroll-margin-top: 84px; }
  .section-sub { max-width: 660px; }

  .ex-goal-nav { padding-top: 36px; }
  .ex-goal-nav-label {
    color: var(--oma-fg-2); font-family: var(--font-mono); font-size: 11px;
    letter-spacing: .06em; text-transform: uppercase;
  }
  .ex-goal-nav-grid {
    display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 8px; margin-top: 10px;
  }
  .ex-goal-nav-link {
    display: grid; grid-template-columns: auto minmax(0, 1fr) auto; align-items: center; gap: 8px;
    min-height: 48px; padding: 9px 11px; border: 1px solid var(--border-default);
    border-radius: var(--radius-sm); color: var(--oma-fg-1); text-decoration: none;
    transition: border-color var(--duration-base) var(--ease-out), background var(--duration-base) var(--ease-out);
  }
  .ex-goal-nav-link:hover { border-color: var(--border-strong); background: var(--oma-bg-1); }
  .ex-goal-nav-link:focus-visible { outline: 2px solid var(--oma-accent); outline-offset: 3px; }
  .ex-goal-nav-link .idx, .ex-goal-nav-link .count {
    color: var(--oma-fg-3); font-family: var(--font-mono); font-size: 10.5px;
  }
  .ex-goal-nav-link .label {
    overflow: hidden; color: var(--oma-fg-0); font-size: 12.5px; font-weight: 500;
    line-height: 1.3; text-overflow: ellipsis;
  }
  .ex-goal-nav-link:hover .label { color: var(--oma-accent); }

  .ex-featured-grid { margin-top: 28px; }
  .ex-card-meta {
    margin-bottom: 12px; color: var(--oma-fg-3); font-family: var(--font-mono);
    font-size: 10.5px; letter-spacing: .04em; text-transform: uppercase;
  }
  .ex-capabilities { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 16px; }
  .ex-capabilities code {
    padding: 3px 7px; border: 1px solid var(--oma-border-0); border-radius: var(--radius-xs);
    background: var(--oma-bg-2); color: var(--oma-fg-2); font-family: var(--font-mono); font-size: 10.5px;
  }

  .ex-group { margin-top: 32px; }
  .ex-subhead {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--oma-fg-2); margin-bottom: 6px;
  }
  .ex-list { border-top: 1px solid var(--border-subtle); }
  .ex-row {
    display: grid; grid-template-columns: minmax(190px, .8fr) minmax(260px, 1.5fr) auto auto;
    align-items: baseline; gap: 18px; padding: 15px 4px;
    border-bottom: 1px solid var(--border-subtle); text-decoration: none;
    transition: background var(--duration-base) var(--ease-out);
  }
  .ex-row:hover { background: var(--oma-bg-1); }
  .ex-row .name { color: var(--oma-fg-0); font-weight: 500; font-size: 14px; line-height: 1.35; }
  .ex-row:hover .name { color: var(--oma-accent); }
  .ex-row .desc { min-width: 0; color: var(--oma-fg-1); font-size: 13px; line-height: 1.5; }
  .ex-row .meta { color: var(--oma-fg-3); font-family: var(--font-mono); font-size: 10.5px; white-space: nowrap; }
  .ex-row .arr, .ex-provider .arr { color: var(--oma-fg-2); transition: transform var(--duration-base) var(--ease-out); }
  .ex-row:hover .arr, .ex-provider:hover .arr { color: var(--oma-accent); transform: translateX(3px); }

  .ex-provider-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px; margin-top: 28px;
  }
  .ex-provider {
    display: grid; grid-template-columns: minmax(0, 1fr) auto auto; align-items: center; gap: 8px;
    min-height: 44px; padding: 9px 11px; border: 1px solid var(--border-default);
    border-radius: var(--radius-sm); text-decoration: none;
    transition: border-color var(--duration-base) var(--ease-out), background var(--duration-base) var(--ease-out);
  }
  .ex-provider:hover { border-color: var(--border-strong); background: var(--oma-bg-1); }
  .ex-provider .name { overflow: hidden; color: var(--oma-fg-1); font-size: 13px; font-weight: 500; text-overflow: ellipsis; white-space: nowrap; }
  .ex-provider:hover .name { color: var(--oma-accent); }
  .ex-provider .flags { display: flex; gap: 4px; }
  .ex-provider .flags span {
    padding: 2px 5px; border-radius: var(--radius-xs); background: var(--oma-bg-2);
    color: var(--oma-fg-3); font-family: var(--font-mono); font-size: 9px; text-transform: uppercase;
  }

  .ex-foot { margin-top: 28px; font-size: 13px; line-height: 1.65; color: var(--oma-fg-2); }
  .ex-foot code { font-family: var(--font-mono); font-size: 12px; color: var(--oma-fg-1); }
  .text-link.inline { display: inline-flex; }
  .ex-empty {
    padding: 28px; border: 1px solid var(--border-default); border-radius: var(--radius-md);
    background: var(--oma-bg-1);
  }
  .ex-empty h2 { margin: 0; color: var(--oma-fg-0); font-size: 20px; }
  .ex-empty p { margin: 8px 0 16px; color: var(--oma-fg-1); }

  @media (max-width: 900px) {
    .ex-goal-nav-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .ex-provider-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .ex-row { grid-template-columns: minmax(170px, .8fr) minmax(220px, 1.4fr) auto; }
    .ex-row .meta { display: none; }
  }
  @media (max-width: 640px) {
    .ex-goal-nav-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .ex-row { grid-template-columns: minmax(0, 1fr) auto; gap: 5px 12px; padding: 14px 4px; }
    .ex-row .desc { grid-column: 1 / -1; }
    .ex-row .arr { grid-column: 2; grid-row: 1; }
    .ex-provider-grid { grid-template-columns: minmax(0, 1fr); }
  }
</style>
