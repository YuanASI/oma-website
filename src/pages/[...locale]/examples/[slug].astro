---
// /examples/<slug> and /zh/examples/<slug> — one code recipe per page, one
// template for both locales. Same shape as compare/[competitor].astro:
// getStaticPaths emits the locale × recipe cross product. ALL recipe content
// (title, intent, source, run commands, APIs) is parsed from the real upstream
// file by scripts/refresh-gh-data.mjs and stays English on every locale — like
// the /examples index blurbs; only the page chrome is translated. Detail records
// exist only for the three "ours" categories (cookbook/basics/patterns).
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../../styles/tokens.css';
import '../../../styles/landing.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import EnterpriseCta from '../../../components/EnterpriseCta.astro';
import CodeBlock from '../../../components/ds/CodeBlock.astro';
import Badge from '../../../components/ds/Badge.astro';
import { REPO, ghStats } from '../../../lib/site';
import { getAllExampleDetails, type ExampleDetail } from '../../../lib/examples';
import { locales, defaultLocale, toLocale, useTranslations, localizePath, type Locale } from '../../../i18n';

export function getStaticPaths() {
  const details = getAllExampleDetails();
  return locales.flatMap((loc: Locale) =>
    details.map((d) => ({
      params: { locale: loc === defaultLocale ? undefined : loc, slug: d.name },
      props: { detail: d },
    })),
  );
}

const { detail } = Astro.props as { detail: ExampleDetail };
const locale = toLocale(Astro.params.locale);
const t = useTranslations(locale);
const dt = t.examples.detail;
const L = (p: string) => localizePath(p, locale);

// Recipe title/intent: zh overrides (dt.recipes keyed by slug) win; en's map is
// empty so it falls back to the English parsed from the upstream file. Code, API
// names, run commands, and source stay English on every locale.
const recTitle = (name: string, fallback: string) => dt.recipes[name]?.title ?? fallback;
const recIntent = (name: string, fallback: string) => dt.recipes[name]?.intent ?? fallback;
const displayTitle = recTitle(detail.name, detail.title);
const displayIntent = recIntent(detail.name, detail.intent);

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

const path = `/examples/${detail.name}/`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const title = displayTitle + dt.seoTitleSuffix;
const description =
  displayIntent.length > 175 ? displayIntent.slice(0, 172).trimEnd() + '…' : displayIntent;

const related = getAllExampleDetails()
  .filter((d) => d.category === detail.category && d.name !== detail.name)
  .slice(0, 4);

const runCode = detail.run.join('\n');
const sourceFile = `${detail.category}/${detail.name}.ts`;
const categoryLabel = dt.categories[detail.category];

// The prereqs are the upstream file's own verbatim JSDoc — some examples are
// written for Anthropic models, others are multi-provider. OMA itself is
// provider-agnostic, so add a clarifying note ONLY where the prereqs pin
// ANTHROPIC_API_KEY without already mentioning another provider — exactly where
// the raw text would otherwise read as "OMA requires Anthropic".
const prereqText = detail.prereqs.join(' ');
const showProviderNote =
  /ANTHROPIC_API_KEY/.test(prereqText) &&
  !/(OPENAI|GEMINI|GOOGLE_API_KEY|GROQ|OPENROUTER|LLM_PROVIDER|provider)/i.test(prereqText);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
  name: displayTitle,
  description,
  url: canonical,
  codeRepository: REPO,
  codeSampleType: 'full (compile ready) solution',
  programmingLanguage: 'TypeScript',
  runtimePlatform: 'Node.js',
  keywords: [...detail.apis, detail.category, 'multi-agent', 'open-multi-agent'].join(', '),
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path={path}>
  <Nav current="examples" starsK={starsK} locale={locale} path={path} />
  <main>
    <!-- Hero -->
    <section class="section exd-hero">
      <div class="container">
        <a class="exd-back" href={L('/examples/')}>{dt.backToIndex}</a>
        <div class="section-head exd-head">
          <div class="eyebrow"><span class="idx">//</span> {categoryLabel}</div>
          <h1 class="section-title">{displayTitle}</h1>
          <p class="section-sub">{displayIntent}</p>
        </div>

        <!-- At a glance: category · APIs used · size -->
        <div class="exd-glance">
          <div class="exd-glance-row">
            <span class="exd-glance-label">{dt.apisUsed}</span>
            <span class="exd-apis">
              {detail.apis.map((a) => <code class="exd-api">{a}</code>)}
            </span>
          </div>
          <div class="exd-glance-meta">
            <Badge tone="info">{categoryLabel}</Badge>
            <span class="exd-loc">{detail.loc} {dt.linesLabel}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Run it -->
    <section class="section exd-run-section">
      <div class="container container--narrow">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">01</span> {dt.runTitle}</div>
        </div>
        <p class="exd-note">{dt.runNote}</p>
        <CodeBlock
          lang="bash"
          title="terminal"
          code={runCode}
          copyLabel={t.landing.copy}
          copiedLabel={t.landing.copied}
        />
        {detail.prereqs.length > 0 && (
          <div class="exd-prereqs">
            <div class="exd-prereqs-label">{dt.prereqsTitle}</div>
            <ul>
              {detail.prereqs.map((p) => <li>{p}</li>)}
            </ul>
            {showProviderNote && (
              <p class="exd-provider-note">
                {dt.providerNote}{' '}
                <a href={L('/reference/providers/')}>{dt.providerLink} →</a>
              </p>
            )}
          </div>
        )}
      </div>
    </section>

    <!-- Full source -->
    <section class="section exd-source-section">
      <div class="container">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">02</span> {dt.sourceTitle}</div>
          <p class="section-sub">{dt.sourceNote}</p>
        </div>
        <div class="exd-source">
          <CodeBlock
            lang="ts"
            title={sourceFile}
            code={detail.source}
            copyLabel={t.landing.copy}
            copiedLabel={t.landing.copied}
          />
        </div>
        <a class="text-link exd-gh" href={detail.blob} target="_blank" rel="noreferrer">
          <span>{dt.viewOnGithub}</span><span class="arrow">↗</span>
        </a>
      </div>
    </section>

    <!-- Related examples (same category) -->
    {related.length > 0 && (
      <section class="section exd-related-section">
        <div class="container">
          <div class="eyebrow"><span class="idx">//</span> {dt.relatedTitle}</div>
          <p class="section-sub exd-related-note">{dt.relatedNote}</p>
          <div class="exd-related">
            {related.map((r) => (
              <a class="exd-related-link" href={L(`/examples/${r.name}/`)}>
                <span class="exd-related-name">{recTitle(r.name, r.title)}</span>
                <span class="exd-related-desc">{recIntent(r.name, r.intent)}</span>
                <span class="arrow">→</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Learn the concepts -->
    <section class="section exd-learn-section">
      <div class="container">
        <div class="eyebrow"><span class="idx">//</span> {dt.learnTitle}</div>
        <div class="exd-learn">
          <a class="exd-learn-link" href={L('/getting-started/quick-start/')}>
            <span class="exd-learn-name">{dt.learnQuickStart}</span><span class="arrow">→</span>
          </a>
          <a class="exd-learn-link" href={L('/getting-started/introduction/')}>
            <span class="exd-learn-name">{dt.learnDocs}</span><span class="arrow">→</span>
          </a>
          <a class="exd-learn-link" href={L('/examples/')}>
            <span class="exd-learn-name">{dt.browseAll}</span><span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <EnterpriseCta locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  /* Extra bottom room so the at-a-glance box isn't cramped against the section
     divider below it. */
  .exd-hero { padding-top: 64px; padding-bottom: 40px; }
  .exd-hero .exd-head { margin-bottom: 20px; }
  .exd-back {
    display: inline-block; margin-bottom: 18px; font-family: var(--font-mono);
    font-size: 12px; color: var(--oma-fg-3); text-decoration: none;
  }
  .exd-back:hover { color: var(--oma-accent); }
  .exd-hero .section-sub { max-width: 680px; }

  /* At a glance */
  .exd-glance {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 20px; flex-wrap: wrap; margin-top: 22px; padding: 16px 18px;
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    background: var(--oma-bg-1);
  }
  .exd-glance-row { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; min-width: 0; }
  .exd-glance-label {
    flex: none; font-family: var(--font-mono); font-size: 10.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--oma-fg-3);
    padding-top: 2px;
  }
  .exd-apis { display: flex; flex-wrap: wrap; gap: 6px; }
  .exd-api {
    font-family: var(--font-mono); font-size: 12px; color: var(--oma-accent);
    background: var(--oma-accent-soft); border: 1px solid var(--oma-accent-line);
    border-radius: var(--radius-sm); padding: 2px 8px;
  }
  .exd-glance-meta { display: flex; align-items: center; gap: 12px; flex: none; }
  .exd-loc { font-family: var(--font-mono); font-size: 12px; color: var(--oma-fg-3); }

  /* Run it */
  .exd-run-section { padding-top: 40px; }
  .exd-note { font-size: 14px; line-height: 1.6; color: var(--oma-fg-2); margin: 0 0 12px; }
  .exd-prereqs {
    margin-top: 14px; border-left: 3px solid var(--oma-border-2);
    padding: 4px 0 4px 16px;
  }
  .exd-prereqs-label {
    font-family: var(--font-mono); font-size: 10.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--oma-fg-3);
    margin-bottom: 6px;
  }
  .exd-prereqs ul { margin: 0; padding-left: 18px; }
  .exd-prereqs li { font-size: 13.5px; line-height: 1.6; color: var(--oma-fg-2); }
  .exd-provider-note { margin: 10px 0 0; font-size: 12.5px; line-height: 1.55; color: var(--oma-fg-3); }
  .exd-provider-note a { color: var(--oma-accent); text-decoration: none; white-space: nowrap; }
  .exd-provider-note a:hover { text-decoration: underline; }

  /* Full source */
  .exd-source-section { padding-top: 40px; }
  /* Cap the source height so a long file scrolls in place instead of dominating
     the page; the full text is still in the DOM (crawlable). */
  .exd-source :global(.ds-codeblock__pre) { max-height: min(72vh, 760px); }
  .exd-gh { margin-top: 16px; display: inline-flex; }

  /* Related */
  .exd-related-section { padding-top: 8px; }
  .exd-related-note { margin-bottom: 14px; }
  .exd-related { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 10px; }
  .exd-related-link {
    display: grid; grid-template-columns: 1fr auto; align-items: baseline; gap: 4px 10px;
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    padding: 14px 16px; text-decoration: none; transition: border-color var(--duration-base) var(--ease-out);
  }
  .exd-related-link:hover { border-color: var(--oma-accent-line); }
  .exd-related-name { color: var(--oma-fg-0); font-size: 14px; font-weight: 500; }
  .exd-related-link:hover .exd-related-name { color: var(--oma-accent); }
  .exd-related-desc {
    grid-column: 1 / -1; color: var(--oma-fg-2); font-size: 12.5px; line-height: 1.5;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .exd-related-link .arrow { color: var(--oma-fg-3); }
  .exd-related-link:hover .arrow { color: var(--oma-accent); }

  /* Learn */
  .exd-learn-section { padding-top: 8px; }
  .exd-learn { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-top: 14px; }
  .exd-learn-link {
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    padding: 14px 16px; text-decoration: none; color: var(--oma-fg-1);
    font-size: 14px; transition: border-color var(--duration-base) var(--ease-out);
  }
  .exd-learn-link:hover { border-color: var(--oma-accent-line); }
  .exd-learn-link .arrow { color: var(--oma-accent); }

  @media (max-width: 640px) {
    .exd-glance { flex-direction: column; gap: 14px; }
  }
</style>
