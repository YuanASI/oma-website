---
// /blog and /zh/blog — the post index. One template, both locales (the [...locale]
// rest param is empty for en at the root, `zh` for /zh/). Lists the `blog`
// collection filtered to the current locale, newest-first; the locale-aware <head>
// comes from BaseLayout. The zh index shows only posts that have a translation.
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../../styles/tokens.css';
import '../../../styles/landing.css';
import '../../../styles/blog.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/ds/Card.astro';
import Badge from '../../../components/ds/Badge.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import EnterpriseCta from '../../../components/EnterpriseCta.astro';
import EnterpriseHeadCta from '../../../components/EnterpriseHeadCta.astro';
import { ghStats } from '../../../lib/site';
import { getCollection } from 'astro:content';
import { localeStaticPaths, toLocale, useTranslations, localizePath, blogLocaleOf, blogSlugOf } from '../../../i18n';

export function getStaticPaths() { return localeStaticPaths(); }
const locale = toLocale(Astro.params.locale);
const bt = useTranslations(locale).blog;
const L = (p: string) => localizePath(p, locale);

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

const posts = (await getCollection('blog'))
  .filter((p) => blogLocaleOf(p.id) === locale)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const fmtDate = (d: Date) =>
  d.toLocaleDateString(locale === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const title = bt.seo.title;
const description = bt.seo.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: title,
  description,
  inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    datePublished: p.data.pubDate.toISOString(),
    url: new URL(L(`/blog/${blogSlugOf(p.id)}/`), Astro.site).href,
  })),
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path="/blog/">
  {locale === 'en' && (
    <Fragment slot="head">
      <link rel="alternate" type="application/rss+xml" title="Open Multi-Agent blog" href="/rss.xml" />
    </Fragment>
  )}

  <Nav current="blog" starsK={starsK} locale={locale} path="/blog/" />
  <main>
    <section class="section">
      <div class="container">
        <div class="hero-head-row">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">//</span> {bt.eyebrow}</div>
            <h1 class="section-title">{bt.title}</h1>
            <p class="section-sub">
              {bt.ledePre}{bt.ledeLink && (
                <a class="text-link" href="https://dev.to/jackchenme" target="_blank" rel="noreferrer">{bt.ledeLink}</a>
              )}{bt.ledePost}
            </p>
          </div>
          <EnterpriseHeadCta locale={locale} />
        </div>
        <div class="blog-list">
          {posts.map((p) => (
            <a class="blog-card-link" href={L(`/blog/${blogSlugOf(p.id)}/`)}>
              <Card padding="lg" interactive>
                <div class="blog-card-meta">
                  <time datetime={p.data.pubDate.toISOString()}>{fmtDate(p.data.pubDate)}</time>
                  {' · '}{p.data.readingMinutes} {bt.minRead}
                </div>
                <h2 class="blog-card-title">{p.data.title}</h2>
                <p class="blog-card-desc">{p.data.description}</p>
                <div class="blog-card-tags">
                  {p.data.tags.map((tag) => <Badge tone="neutral">{tag}</Badge>)}
                </div>
              </Card>
            </a>
          ))}
        </div>
      </div>
    </section>

    <EnterpriseCta locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
