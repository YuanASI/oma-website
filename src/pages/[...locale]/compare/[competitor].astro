---
// /compare/<slug> and /zh/compare/<slug> — one framework comparison, one template
// for both locales (§7.2). getStaticPaths emits the locale × competitor cross
// product (same shape as blog/[slug].astro). All framework copy — matrix cells
// and narrative — comes from src/lib/compare.ts (verified facts, bilingual); the
// page chrome comes from the i18n dict. {name} placeholders are interpolated with
// the competitor's name at render time.
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../../styles/tokens.css';
import '../../../styles/landing.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import EnterpriseCta from '../../../components/EnterpriseCta.astro';
import EnterpriseHeadCta from '../../../components/EnterpriseHeadCta.astro';
import { ghStats } from '../../../lib/site';
import { AXES, COMPARISONS, OMA_CAPABILITIES, type Comparison, type Loc } from '../../../lib/compare';
import { locales, defaultLocale, toLocale, useTranslations, localizePath, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return locales.flatMap((loc: Locale) =>
    COMPARISONS.map((c) => ({
      params: { locale: loc === defaultLocale ? undefined : loc, competitor: c.slug },
      props: { comp: c },
    })),
  );
}

const { comp } = Astro.props as { comp: Comparison };
const locale = toLocale(Astro.params.locale);
const t = useTranslations(locale).compare;
const L = (p: string) => localizePath(p, locale);
const pick = (o: Loc) => o[locale];
const withName = (s: string) => s.replace('{name}', comp.name);

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

const path = `/compare/${comp.slug}/`;
const title = withName(t.page.seoTitle);
const description = pick(comp.seoDescription);
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const others = COMPARISONS.filter((c) => c.slug !== comp.slug);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
  headline: title,
  description,
  url: canonical,
  keywords: comp.keywords.join(', '),
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path={path}>
  <Nav current="compare" starsK={starsK} locale={locale} path={path} />
  <main>
    <!-- Hero -->
    <section class="section compare-hero">
      <div class="container">
        <a class="compare-back" href={L('/compare/')}>← {t.page.backToHub}</a>
        <div class="hero-head-row">
          <div class="section-head compare-head">
            <div class="eyebrow"><span class="idx">//</span> {t.page.eyebrow}</div>
            <h1 class="section-title">{withName(t.page.vsTitle)}</h1>
            <p class="section-sub">{pick(comp.lede)}</p>
          </div>
          <EnterpriseHeadCta locale={locale} />
        </div>

        <div class="compare-take">
          <div class="compare-take-card">
            <div class="compare-take-label">{withName(t.hub.pickThem)}</div>
            <p>{pick(comp.chooseThem)}</p>
          </div>
          <div class="compare-take-card compare-take-card--oma">
            <div class="compare-take-label">{t.hub.pickUs}</div>
            <p>{pick(comp.chooseUs)}</p>
          </div>
        </div>

        {comp.note && <div class="compare-note" set:html={pick(comp.note)} />}
      </div>
    </section>

    <!-- At a glance: the comparison matrix -->
    <section class="section compare-matrix-section">
      <div class="container">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">01</span> {t.page.matrix.eyebrow}</div>
          <h2 class="section-title">{t.page.matrix.title}</h2>
        </div>
        <div class="compare-matrix-wrap">
          <table class="compare-matrix">
            <thead>
              <tr>
                <th scope="col">{t.page.matrix.dimension}</th>
                <th scope="col" class="col-oma">{t.page.matrix.oma}</th>
                <th scope="col">{comp.name}</th>
              </tr>
            </thead>
            <tbody>
              {AXES.map((axis) => (
                <tr>
                  <th scope="row">{pick(axis.label)}</th>
                  <td class="col-oma">{pick(axis.oma)}</td>
                  <td>{pick(comp.them[axis.key])}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- OMA's verified runtime surface, shared across every comparison. -->
    <section class="section compare-capabilities-section">
      <div class="container">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">02</span> {t.page.capabilities.eyebrow}</div>
          <h2 class="section-title">{t.page.capabilities.title}</h2>
          <p class="section-sub">{t.page.capabilities.lede}</p>
        </div>
        <div class="compare-capabilities-grid">
          {OMA_CAPABILITIES.map((capability) => (
            <article class="compare-capability-card">
              <h3>{pick(capability.title)}</h3>
              <p set:html={pick(capability.body)} />
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- How they differ -->
    <section class="section compare-prose-section">
      <div class="container container--narrow">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">03</span> {t.page.howDiffer.eyebrow}</div>
          <h2 class="section-title">{t.page.howDiffer.title}</h2>
        </div>
        <p class="compare-prose" set:html={pick(comp.howDiffer)} />
      </div>
    </section>

    <!-- The fair verdict: when each is the better choice -->
    <section class="section compare-verdict-section">
      <div class="container">
        <div class="compare-verdict">
          <div class="compare-verdict-col">
            <h2 class="compare-verdict-title">{withName(t.page.whenThemTitle)}</h2>
            <p class="compare-prose" set:html={pick(comp.whenThem)} />
            <a class="text-link" href={comp.repo} target="_blank" rel="noreferrer"><span>{withName(t.page.repoLink)}</span><span class="arrow">↗</span></a>
          </div>
          <div class="compare-verdict-col compare-verdict-col--oma">
            <h2 class="compare-verdict-title">{t.page.whenUsTitle}</h2>
            <p class="compare-prose" set:html={pick(comp.whenUs)} />
            <a class="text-link" href={L('/getting-started/quick-start/')}><span>Quick Start</span><span class="arrow">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- Enterprise support (§3.2) -->
    <EnterpriseCta locale={locale} />

    <!-- See also: the other comparisons -->
    <section class="section compare-more-section">
      <div class="container">
        <div class="eyebrow"><span class="idx">//</span> {t.page.seeAlso}</div>
        <div class="compare-more">
          {others.map((c) => (
            <a class="compare-more-link" href={L(`/compare/${c.slug}/`)}>
              <span class="compare-more-name">open-multi-agent vs {c.name}</span>
              <span class="arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />

  <script>
    // Make the matrix keyboard-scrollable only when it actually overflows, so it
    // doesn't become a useless tab stop on wide screens (axe: scrollable-region).
    document.querySelectorAll<HTMLElement>('.compare-matrix-wrap').forEach((el) => {
      if (el.scrollWidth > el.clientWidth) el.setAttribute('tabindex', '0');
    });
  </script>
</BaseLayout>

<style>
  .compare-hero { padding-top: 64px; padding-bottom: 8px; }
  .compare-hero .hero-head-row { margin-bottom: 24px; }
  .compare-back {
    display: inline-block; margin-bottom: 18px; font-family: var(--font-mono);
    font-size: 12px; color: var(--oma-fg-3); text-decoration: none;
  }
  .compare-back:hover { color: var(--oma-accent); }

  /* Quick take: two side-by-side one-liners, competitor vs OMA. */
  .compare-take {
    display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 8px;
  }
  .compare-take-card {
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    background: var(--oma-bg-1); padding: 16px 18px;
  }
  .compare-take-card--oma { border-color: var(--oma-accent-line); background: var(--oma-accent-soft); }
  .compare-take-label {
    font-family: var(--font-mono); font-size: 10.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--oma-fg-3);
    margin-bottom: 6px;
  }
  .compare-take-card--oma .compare-take-label { color: var(--oma-accent); }
  .compare-take-card p { margin: 0; font-size: 14px; line-height: 1.6; color: var(--oma-fg-2); }

  /* Up-front caveat (e.g. AutoGen maintenance mode). */
  .compare-note {
    margin-top: 16px; border-left: 3px solid var(--oma-warning);
    background: var(--oma-warning-soft); border-radius: var(--radius-sm);
    padding: 12px 16px; font-size: 13.5px; line-height: 1.65; color: var(--oma-fg-2);
  }

  /* Comparison matrix. */
  .compare-matrix-wrap { overflow-x: auto; margin-top: 8px; }
  .compare-matrix {
    width: 100%; border-collapse: collapse; font-size: 13.5px; min-width: 640px;
  }
  .compare-matrix th, .compare-matrix td {
    text-align: left; vertical-align: top; padding: 12px 16px;
    border-bottom: 1px solid var(--oma-border-1); line-height: 1.55;
  }
  .compare-matrix thead th {
    font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--oma-fg-3); border-bottom: 2px solid var(--oma-border-2);
    white-space: nowrap;
  }
  .compare-matrix tbody th {
    font-weight: 600; color: var(--oma-fg-1); width: 22%;
  }
  .compare-matrix td { color: var(--oma-fg-2); }
  .compare-matrix .col-oma { background: var(--oma-accent-soft); color: var(--oma-fg-1); }
  .compare-matrix thead th.col-oma { color: var(--oma-accent); }

  /* Verified OMA runtime surface. */
  .compare-capabilities-section { padding-top: 48px; }
  .compare-capabilities-section .section-sub { max-width: 760px; }
  .compare-capabilities-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px; margin-top: 22px;
  }
  .compare-capability-card {
    border: 1px solid var(--oma-accent-line); border-radius: var(--radius-md);
    background: var(--oma-accent-soft); padding: 18px;
  }
  .compare-capability-card h3 {
    margin: 0 0 8px; font-size: 15px; line-height: 1.4; color: var(--oma-fg-1);
  }
  .compare-capability-card p {
    margin: 0; font-size: 13.5px; line-height: 1.65; color: var(--oma-fg-2);
  }
  .compare-capability-card :global(code) {
    font-family: var(--font-mono); font-size: 0.86em;
    background: var(--oma-bg-3); padding: 1px 4px; border-radius: var(--radius-xs);
    color: var(--oma-fg-1);
  }

  /* Narrative sections. */
  .compare-prose-section { padding-top: 40px; }
  .compare-prose {
    font-size: 15px; line-height: 1.8; color: var(--oma-fg-2); margin: 0;
  }
  .compare-prose :global(code) {
    font-family: var(--font-mono); font-size: 0.88em;
    background: var(--oma-bg-3); padding: 1px 5px; border-radius: var(--radius-xs);
    color: var(--oma-fg-1);
  }
  .compare-prose :global(em) { color: var(--oma-fg-1); font-style: italic; }

  /* Verdict: two columns, the honest "when each wins". */
  .compare-verdict { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
  .compare-verdict-col {
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    padding: 22px 24px; background: var(--oma-bg-1);
  }
  .compare-verdict-col--oma { border-color: var(--oma-accent-line); }
  .compare-verdict-title { font-size: 18px; margin: 0 0 12px; line-height: 1.35; }
  .compare-verdict-col .text-link { margin-top: 16px; }

  /* See also. */
  .compare-more-section { padding-top: 8px; }
  .compare-more { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 10px; margin-top: 14px; }
  .compare-more-link {
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    padding: 14px 16px; text-decoration: none; color: var(--oma-fg-1);
    font-size: 14px; transition: border-color var(--duration-base) var(--ease-out);
  }
  .compare-more-link:hover { border-color: var(--oma-accent-line); }
  .compare-more-link .arrow { color: var(--oma-accent); }

  @media (max-width: 720px) {
    .compare-take { grid-template-columns: 1fr; }
    .compare-verdict { grid-template-columns: 1fr; gap: 16px; }
    .compare-capabilities-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 721px) and (max-width: 960px) {
    .compare-capabilities-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>
