---
// /compare/claude-dynamic-workflows and /zh/compare/claude-dynamic-workflows —
// a STANDALONE page (deliberately NOT a src/lib/compare.ts COMPARISONS entry, so
// it never renders in the competitor grid or "vs" cross-links). It captures the
// "claude dynamic workflows" search and routes it to OMA with the framing the
// repo README uses in its "vs. Claude Code's dynamic workflows" entry: the SAME
// bet (the model plans the work at runtime), a DIFFERENT form factor, and the two
// are composable over ACP.
//
// GUARDRAILS (encoded here + in the i18n copy): never call OMA an "alternative
// to" dynamic workflows — that word is reserved for the framework comparisons the
// see-also section links to; never argue who is "more dynamic" (both are
// model-driven); never assert what dynamic workflows lacks. Every "Claude dynamic
// workflows" cell states only what the official post says it does. Facts verified
// against claude.com/blog/introducing-dynamic-workflows-in-claude-code (May 2026).
//
// All copy comes from the type-checked i18n dict (t.dynamicWorkflows), so a
// missing zh key fails `pnpm check`. Page chrome reuses the shared Nav/Footer/
// BaseLayout/EnterpriseCta; the bespoke sections carry their own scoped styles
// (the /compare/[competitor] visual language, renamed dw-*).
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../../styles/tokens.css';
import '../../../styles/landing.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import EnterpriseCta from '../../../components/EnterpriseCta.astro';
import { ghStats } from '../../../lib/site';
import { localeStaticPaths, toLocale, useTranslations, localizePath } from '../../../i18n';

export function getStaticPaths() { return localeStaticPaths(); }
const locale = toLocale(Astro.params.locale);
const t = useTranslations(locale).dynamicWorkflows;
const L = (p: string) => localizePath(p, locale);

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

const path = '/compare/claude-dynamic-workflows/';
const title = t.seo.title;
const description = t.seo.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
// Anthropic's announcement — the primary source every DW claim on this page traces to.
const DW_POST = 'https://claude.com/blog/introducing-dynamic-workflows-in-claude-code';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
  headline: title,
  description,
  url: canonical,
  keywords: 'claude dynamic workflows, open source, self-hosted, any model, typescript, multi-agent orchestration, open-multi-agent',
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path={path}>
  <Nav current="compare" starsK={starsK} locale={locale} path={path} />
  <main>
    <!-- Hero: what each is (two descriptive cards, NOT a pick-them/pick-us router) -->
    <section class="section dw-hero">
      <div class="container">
        <a class="dw-back" href={L('/compare/')}>← {t.hero.backToHub}</a>
        <div class="section-head dw-head">
          <div class="eyebrow"><span class="idx">//</span> {t.hero.eyebrow}</div>
          <h1 class="section-title">{t.hero.h1}</h1>
          <p class="section-sub">{t.hero.lede}</p>
        </div>
        <div class="dw-cards">
          <div class="dw-card">
            <div class="dw-card-label">{t.cards.dwLabel}</div>
            <p>{t.cards.dwBody}</p>
            <a class="text-link" href={DW_POST} target="_blank" rel="noreferrer"><span>{t.cards.dwLink}</span><span class="arrow">↗</span></a>
          </div>
          <div class="dw-card dw-card--oma">
            <div class="dw-card-label">{t.cards.omaLabel}</div>
            <p>{t.cards.omaBody}</p>
            <a class="text-link" href={L('/getting-started/quick-start/')}><span>{t.cards.omaLink}</span><span class="arrow">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- The shared bet: both are model-driven (explicitly declines the who-is-more-dynamic argument) -->
    <section class="section dw-prose-section">
      <div class="container dw-narrow">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">01</span> {t.bet.eyebrow}</div>
          <h2 class="section-title">{t.bet.title}</h2>
        </div>
        <p class="dw-prose" set:html={t.bet.body} />
      </div>
    </section>

    <!-- The difference is form factor: a descriptive (not scored) side-by-side -->
    <section class="section dw-matrix-section">
      <div class="container">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">02</span> {t.form.eyebrow}</div>
          <h2 class="section-title">{t.form.title}</h2>
          <p class="section-sub">{t.form.intro}</p>
        </div>
        <div class="dw-matrix-wrap">
          <table class="dw-matrix">
            <thead>
              <tr>
                <th scope="col">{t.form.th.dimension}</th>
                <th scope="col">{t.form.th.dw}</th>
                <th scope="col" class="col-oma">{t.form.th.oma}</th>
              </tr>
            </thead>
            <tbody>
              {t.form.rows.map((row) => (
                <tr>
                  <th scope="row">{row.k}</th>
                  <td>{row.dw}</td>
                  <td class="col-oma">{row.oma}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Composable, not competing: OMA can run Claude Code itself over ACP -->
    <section class="section dw-prose-section">
      <div class="container dw-narrow">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">03</span> {t.compose.eyebrow}</div>
          <h2 class="section-title">{t.compose.title}</h2>
        </div>
        <p class="dw-prose" set:html={t.compose.body} />
      </div>
    </section>

    <!-- Where OMA fits (states only what OMA does; carries the long-tail terms) -->
    <section class="section dw-fit-section">
      <div class="container dw-narrow">
        <div class="section-head">
          <div class="eyebrow"><span class="idx">04</span> {t.fit.eyebrow}</div>
          <h2 class="section-title">{t.fit.title}</h2>
        </div>
        <p class="dw-prose" set:html={t.fit.body} />
        <div class="dw-fit-cta">
          <a class="text-link" href={L('/getting-started/quick-start/')}><span>{t.fit.cta}</span><span class="arrow">→</span></a>
        </div>
      </div>
    </section>

    <!-- Enterprise support (§3.2) — consistent with the /compare and /solutions pages -->
    <EnterpriseCta locale={locale} />

    <!-- See also: the framework comparisons. "Alternative" belongs here, not above. -->
    <section class="section dw-seealso-section">
      <div class="container">
        <div class="dw-seealso">
          <div class="eyebrow"><span class="idx">//</span> {t.seeAlso.eyebrow}</div>
          <h2 class="dw-seealso-title">{t.seeAlso.title}</h2>
          <p class="dw-seealso-body">{t.seeAlso.body}</p>
          <a class="text-link" href={L('/compare/')}><span>{t.seeAlso.cta}</span><span class="arrow">→</span></a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />

  <script>
    // Make the side-by-side keyboard-scrollable only when it actually overflows,
    // so it isn't a dead tab stop on wide screens (axe: scrollable-region).
    document.querySelectorAll<HTMLElement>('.dw-matrix-wrap').forEach((el) => {
      if (el.scrollWidth > el.clientWidth) el.setAttribute('tabindex', '0');
    });
  </script>
</BaseLayout>

<style>
  .dw-hero { padding-top: 64px; padding-bottom: 8px; }
  .dw-hero .dw-head { margin-bottom: 24px; }
  .dw-back {
    display: inline-block; margin-bottom: 18px; font-family: var(--font-mono);
    font-size: 12px; color: var(--oma-fg-3); text-decoration: none;
  }
  .dw-back:hover { color: var(--oma-accent); }

  /* Two descriptive cards, side by side: the feature, then the library. */
  .dw-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 8px; }
  .dw-card {
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    background: var(--oma-bg-1); padding: 18px 20px;
    display: flex; flex-direction: column; align-items: flex-start;
  }
  .dw-card--oma { border-color: var(--oma-accent-line); background: var(--oma-accent-soft); }
  .dw-card-label {
    font-family: var(--font-mono); font-size: 10.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--oma-fg-3);
    margin-bottom: 8px;
  }
  .dw-card--oma .dw-card-label { color: var(--oma-accent); }
  .dw-card p { margin: 0 0 12px; font-size: 14px; line-height: 1.65; color: var(--oma-fg-2); }
  .dw-card .text-link { margin-top: auto; }

  /* Narrow column for the prose sections. */
  .dw-narrow { max-width: 768px; }

  .dw-prose-section { padding-top: 48px; }
  .dw-prose { font-size: 15px; line-height: 1.8; color: var(--oma-fg-2); margin: 0; }
  .dw-prose :global(code) {
    font-family: var(--font-mono); font-size: 0.88em;
    background: var(--oma-bg-3); padding: 1px 5px; border-radius: var(--radius-xs);
    color: var(--oma-fg-1);
  }
  .dw-prose :global(em) { color: var(--oma-fg-1); font-style: italic; }

  /* Side-by-side: descriptive cells, OMA column softly highlighted (no scoring). */
  .dw-matrix-section { padding-top: 48px; }
  .dw-matrix-wrap { overflow-x: auto; margin-top: 8px; }
  .dw-matrix { width: 100%; border-collapse: collapse; font-size: 13.5px; min-width: 640px; }
  .dw-matrix th, .dw-matrix td {
    text-align: left; vertical-align: top; padding: 12px 16px;
    border-bottom: 1px solid var(--oma-border-1); line-height: 1.55;
  }
  .dw-matrix thead th {
    font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--oma-fg-3);
    border-bottom: 2px solid var(--oma-border-2); white-space: nowrap;
  }
  .dw-matrix tbody th { font-weight: 600; color: var(--oma-fg-1); width: 20%; }
  .dw-matrix td { color: var(--oma-fg-2); }
  .dw-matrix .col-oma { background: var(--oma-accent-soft); color: var(--oma-fg-1); }
  .dw-matrix thead th.col-oma { color: var(--oma-accent); }

  .dw-fit-section { padding-top: 48px; }
  .dw-fit-cta { margin-top: 20px; }

  /* See-also: one understated card routing the "alternative" intent to frameworks. */
  .dw-seealso-section { padding-top: 8px; }
  .dw-seealso {
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    background: var(--oma-bg-1); padding: 24px 26px; max-width: 768px;
  }
  .dw-seealso-title { font-size: 20px; margin: 10px 0 8px; line-height: 1.3; }
  .dw-seealso-body { font-size: 14.5px; line-height: 1.7; color: var(--oma-fg-2); margin: 0 0 16px; }

  @media (max-width: 720px) {
    .dw-cards { grid-template-columns: 1fr; }
  }
</style>
