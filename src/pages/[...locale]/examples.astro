---
// /examples — the example gallery (PRD §4.3). Same self-contained landing-style
// shell as index.astro (shared Nav/Footer), but the content is built entirely
// from the repo at build time via getExamples() — no hand-maintained list.
// Example titles/blurbs are fetched English from the repo README and stay English
// in every locale (upstream-sourced, like the vendored docs Reference); only the
// page chrome is translated.
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../styles/tokens.css';
import '../../styles/landing.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/ds/Card.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { REPO, ghStats } from '../../lib/site';
import { getExamples, FALLBACK_EXAMPLES } from '../../lib/examples';
import { localeStaticPaths, toLocale, useTranslations } from '../../i18n';

export function getStaticPaths() { return localeStaticPaths(); }
const locale = toLocale(Astro.params.locale);
const t = useTranslations(locale);
const ex_t = t.examples;

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';
const ex = await getExamples();

const EXAMPLES_GH = REPO + '/tree/main/packages/core/examples';

const title = ex_t.seo.title;
const description = ex_t.seo.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
  name: title,
  description,
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
  ...(ex
    ? {
        mainEntity: {
          '@type': 'ItemList',
          itemListElement: ex.cookbook.map((e, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            name: e.title,
            url: e.href,
          })),
        },
      }
    : {}),
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path="/examples/">
  <Nav current="examples" starsK={starsK} locale={locale} path="/examples/" />

  <main>
    <!-- ── Page head ── -->
    <header class="ex-hero">
      <div class="container">
        <div class="eyebrow"><span class="idx">//</span> {ex_t.hero.eyebrow}</div>
        <h1 class="ex-title">{ex_t.hero.title}</h1>
        <p class="ex-lede">{ex_t.hero.lede}</p>
      </div>
    </header>

      {ex ? (
        <Fragment>
          <!-- ── 1. Cookbook (primary) ── -->
          <section class="section ex-first" id="cookbook">
            <div class="container">
              <div class="section-head">
                <div class="eyebrow"><span class="idx">01</span> {ex_t.cookbook.eyebrow}</div>
                <h2 class="section-title">{ex_t.cookbook.title}</h2>
                <p class="section-sub">{ex_t.cookbook.sub}</p>
              </div>
              <div class="build-grid">
                {ex.cookbook.map((e) => (
                  <a class="case-link" href={e.href} target="_blank" rel="noreferrer" style="text-decoration:none;">
                    <Card padding="lg" interactive>
                      <div class="build-title">{e.title}</div>
                      <p class="build-desc">{e.blurb}</p>
                      <div class="build-foot">
                        <span class="text-link"><span>{ex_t.seeSource}</span><span class="arrow">→</span></span>
                      </div>
                    </Card>
                  </a>
                ))}
              </div>
            </div>
          </section>

          <!-- ── 2. Integrations (primary) ── -->
          <section class="section" id="integrations">
            <div class="container">
              <div class="section-head">
                <div class="eyebrow"><span class="idx">02</span> {ex_t.integrations.eyebrow}</div>
                <h2 class="section-title">{ex_t.integrations.title}</h2>
                <p class="section-sub">{ex_t.integrations.sub}</p>
              </div>

              {ex.reference.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">{ex_t.integrations.reference}</div>
                  <div class="ex-list">
                    {ex.reference.map((e) => (
                      <a class="ex-row mono" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.name}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {ex.apps.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">{ex_t.integrations.apps}</div>
                  <div class="ex-list">
                    {ex.apps.map((e) => (
                      <a class="ex-row" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.title}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {ex.vendor.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">{ex_t.integrations.vendor}</div>
                  <div class="ex-list">
                    {ex.vendor.map((e) => (
                      <a class="ex-row" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.title}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </section>

          <!-- ── 3. Building blocks (secondary) ── -->
          <section class="section" id="building-blocks">
            <div class="container">
              <div class="section-head">
                <div class="eyebrow"><span class="idx">03</span> {ex_t.buildingBlocks.eyebrow}</div>
                <h2 class="section-title">{ex_t.buildingBlocks.title}</h2>
                <p class="section-sub">{ex_t.buildingBlocks.sub}</p>
              </div>

              {ex.basics.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">{ex_t.buildingBlocks.basics}</div>
                  <div class="ex-list">
                    {ex.basics.map((e) => (
                      <a class="ex-row mono" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.name}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {ex.patterns.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">{ex_t.buildingBlocks.patterns}</div>
                  <div class="ex-list">
                    {ex.patterns.map((e) => (
                      <a class="ex-row mono" href={e.href} target="_blank" rel="noreferrer">
                        <span class="name">{e.name}</span>
                        <span class="desc">{e.blurb}</span>
                        <span class="arr">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {ex.providers.length > 0 && (
                <div class="ex-group">
                  <div class="ex-subhead">{ex_t.buildingBlocks.providers}</div>
                  <div class="ex-chips">
                    {ex.providers.map((e) => (
                      <a class="ex-chip" href={e.href} target="_blank" rel="noreferrer" title={e.blurb}>{e.name}</a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </section>

          <!-- ── 4. Production pointer + provenance ── -->
          <section class="section" id="more">
            <div class="container">
              <div class="ex-callout">
                <div>
                  <div class="ex-callout-title">{ex_t.production.title}</div>
                  <p class="ex-callout-desc">{ex_t.production.desc}</p>
                </div>
                <a class="text-link" href={ex.productionHref} target="_blank" rel="noreferrer">
                  <span>{ex_t.production.link}</span><span class="arrow">→</span>
                </a>
              </div>
              <p class="ex-foot">
                {ex_t.footPre}<code>{ex_t.footCode}</code>{ex_t.footPost}<a class="text-link inline" href={ex.browseHref} target="_blank" rel="noreferrer"><span>{ex_t.browseAll}</span><span class="arrow">→</span></a>
              </p>
            </div>
          </section>
        </Fragment>
      ) : (
        <section class="section ex-first">
          <div class="container">
            <div class="section-head">
              <div class="eyebrow"><span class="idx">01</span> {ex_t.cookbook.eyebrow}</div>
              <h2 class="section-title">{ex_t.cookbook.title}</h2>
              <p class="section-sub">{ex_t.cookbook.subFallback}</p>
            </div>
            <div class="build-grid">
              {FALLBACK_EXAMPLES.map((e) => (
                <a class="case-link" href={e.href} target="_blank" rel="noreferrer" style="text-decoration:none;">
                  <Card padding="lg" interactive>
                    <div class="build-title">{e.title}</div>
                    <p class="build-desc">{e.blurb}</p>
                    <div class="build-foot">
                      <span class="text-link"><span>{ex_t.seeSource}</span><span class="arrow">→</span></span>
                    </div>
                  </Card>
                </a>
              ))}
            </div>
            <p class="ex-foot">
              <a class="text-link inline" href={EXAMPLES_GH} target="_blank" rel="noreferrer"><span>{ex_t.browseAll}</span><span class="arrow">→</span></a>
            </p>
          </div>
        </section>
      )}
  </main>

  <Footer locale={locale} />
</BaseLayout>

<style>
      .ex-hero { padding: 72px 0 8px; }
      .ex-title {
        font-size: clamp(34px, 5vw, 52px); font-weight: 600; letter-spacing: -0.03em;
        line-height: 1.05; color: var(--oma-fg-0); margin: 16px 0 0;
      }
      .ex-lede { font-size: 17px; line-height: 1.6; color: var(--oma-fg-1); margin: 18px 0 0; max-width: 640px; }
      .ex-first { padding-top: 56px; }

      .ex-group { margin-top: 32px; }
      .ex-group:first-of-type { margin-top: 0; }
      .ex-subhead {
        font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em;
        text-transform: uppercase; color: var(--oma-fg-2); margin-bottom: 6px;
      }

      .ex-list { border-top: 1px solid var(--border-subtle); }
      .ex-row {
        display: flex; align-items: baseline; gap: 18px;
        padding: 15px 4px; border-bottom: 1px solid var(--border-subtle);
        text-decoration: none; transition: background var(--duration-base) var(--ease-out);
      }
      .ex-row:hover { background: var(--oma-bg-1); }
      .ex-row .name {
        flex: none; min-width: 232px; color: var(--oma-fg-0);
        font-weight: 500; font-size: 15px; line-height: 1.35;
      }
      .ex-row.mono .name { font-family: var(--font-mono); font-size: 13px; }
      .ex-row:hover .name { color: var(--oma-accent); }
      .ex-row .desc { flex: 1; min-width: 0; color: var(--oma-fg-1); font-size: 13px; line-height: 1.5; }
      .ex-row .arr { flex: none; color: var(--oma-fg-2); transition: transform var(--duration-base) var(--ease-out); }
      .ex-row:hover .arr { color: var(--oma-accent); transform: translateX(3px); }

      .ex-chips { display: flex; flex-wrap: wrap; gap: 8px; }
      .ex-chip {
        font-family: var(--font-mono); font-size: 12px; color: var(--oma-fg-1);
        border: 1px solid var(--border-default); border-radius: var(--radius-sm);
        padding: 6px 11px; text-decoration: none;
        transition: border-color var(--duration-base) var(--ease-out), color var(--duration-base) var(--ease-out);
      }
      .ex-chip:hover { border-color: var(--border-strong); color: var(--oma-accent); }

      .ex-callout {
        display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
        padding: 22px 24px; background: var(--oma-bg-1);
        border: 1px solid var(--border-default); border-radius: var(--radius-md);
      }
      .ex-callout-title { font-size: 16px; font-weight: 600; color: var(--oma-fg-0); }
      .ex-callout-desc { font-size: 13px; line-height: 1.55; color: var(--oma-fg-2); margin: 6px 0 0; max-width: 560px; }
      .ex-foot { margin-top: 28px; font-size: 13px; line-height: 1.65; color: var(--oma-fg-2); }
      .ex-foot code { font-family: var(--font-mono); font-size: 12px; color: var(--oma-fg-1); }
      .text-link.inline { display: inline-flex; }

      @media (max-width: 640px) {
        .ex-row { flex-direction: column; gap: 4px; }
        .ex-row .name { min-width: 0; }
      }
</style>
