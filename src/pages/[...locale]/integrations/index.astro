---
// /integrations and /zh/integrations — the integration hub. One card per entry.
// Integration copy comes from src/lib/integrations.ts; chrome from the dict. Mirrors
// compare/index.astro and solutions/index.astro.
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../../styles/tokens.css';
import '../../../styles/landing.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import EnterpriseCta from '../../../components/EnterpriseCta.astro';
import { ghStats } from '../../../lib/site';
import { INTEGRATIONS } from '../../../lib/integrations';
import { type Loc } from '../../../lib/compare';
import { localeStaticPaths, toLocale, useTranslations, localizePath } from '../../../i18n';

export function getStaticPaths() { return localeStaticPaths(); }
const locale = toLocale(Astro.params.locale);
const t = useTranslations(locale).integrations;
const L = (p: string) => localizePath(p, locale);
const pick = (o: Loc) => o[locale];

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';
const runtimeIntegrations = INTEGRATIONS.filter((it) => it.kind === 'runtime');
const providerIntegrations = INTEGRATIONS.filter((it) => it.kind === 'provider');

const path = '/integrations/';
const title = t.seo.title;
const description = t.seo.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  inLanguage: locale === 'zh' ? 'zh-CN' : 'en',
  name: title,
  description,
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: INTEGRATIONS.map((it, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: it.name,
      url: new URL(`/integrations/${it.slug}/`, Astro.site).href,
    })),
  },
};
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd} path={path}>
  <Nav current="integrations" starsK={starsK} locale={locale} path={path} />
  <main>
    <section class="section int-hub-hero">
      <div class="container">
        <div class="section-head int-hub-intro">
          <div class="eyebrow"><span class="idx">//</span> {t.hero.eyebrow}</div>
          <h1 class="section-title">{t.hero.title}</h1>
          <p class="section-sub">{t.hero.lede}</p>
        </div>

        <section class="int-hub-group" aria-labelledby="runtime-integrations-title">
          <div class="int-hub-group-head">
            <div class="int-hub-group-copy">
              <div class="int-hub-group-index"><span>01</span> / {t.hub.runtimeEyebrow}</div>
              <h2 id="runtime-integrations-title">{t.hub.runtimeTitle}</h2>
              <p>{t.hub.runtimeLede}</p>
            </div>
            <span class="int-hub-count">{runtimeIntegrations.length} {t.hub.runtimeCount}</span>
          </div>
          <div class="int-runtime-grid">
            {runtimeIntegrations.map((it) => (
              <a class="int-runtime-card" href={L(`/integrations/${it.slug}/`)}>
                <div class="int-hub-card-top">
                  <span class="int-hub-card-label">{pick(it.hubLabel)}</span>
                  <span class="int-hub-card-arrow" aria-hidden="true">↗</span>
                </div>
                <h3>{it.name}</h3>
                <p>{pick(it.lede)}</p>
              </a>
            ))}
          </div>
        </section>

        <section class="int-hub-group int-hub-group--providers" aria-labelledby="provider-integrations-title">
          <div class="int-hub-group-head">
            <div class="int-hub-group-copy">
              <div class="int-hub-group-index"><span>02</span> / {t.hub.providersEyebrow}</div>
              <h2 id="provider-integrations-title">{t.hub.providersTitle}</h2>
              <p>{t.hub.providersLede}</p>
            </div>
            <span class="int-hub-count">{providerIntegrations.length} {t.hub.providersCount}</span>
          </div>
          <div class="int-provider-grid">
            {providerIntegrations.map((it) => (
              <a class="int-provider-card" href={L(`/integrations/${it.slug}/`)}>
                <div class="int-hub-card-top">
                  <h3>{it.name}</h3>
                  <span class="int-hub-card-arrow" aria-hidden="true">→</span>
                </div>
                <p>{pick(it.lede)}</p>
                <span class="int-hub-card-label">{pick(it.hubLabel)}</span>
              </a>
            ))}
          </div>
        </section>
      </div>
    </section>

    <EnterpriseCta locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .int-hub-hero { padding-top: 64px; }
  .int-hub-intro { max-width: 760px; margin-bottom: 68px; }
  .int-hub-intro .section-sub { max-width: 680px; }

  .int-hub-group + .int-hub-group { margin-top: 72px; }
  .int-hub-group-head {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 32px;
    padding-bottom: 20px; margin-bottom: 20px;
    border-bottom: 1px solid var(--oma-border-1);
  }
  .int-hub-group-copy { max-width: 690px; }
  .int-hub-group-index {
    margin-bottom: 12px; color: var(--oma-fg-2);
    font-family: var(--font-mono); font-size: 11.5px; font-weight: 600;
    letter-spacing: var(--tracking-label); text-transform: uppercase;
  }
  .int-hub-group-index span { color: var(--oma-accent); }
  .int-hub-group h2 {
    margin: 0; color: var(--oma-fg-0); font-size: clamp(26px, 3vw, 34px);
    font-weight: 600; line-height: 1.12; letter-spacing: -0.025em;
  }
  .int-hub-group-copy > p {
    max-width: 620px; margin: 10px 0 0; color: var(--oma-fg-2);
    font-size: 14px; line-height: 1.65;
  }
  .int-hub-count {
    flex: 0 0 auto; padding-bottom: 3px; color: var(--oma-fg-2);
    font-family: var(--font-mono); font-size: 11.5px;
  }

  .int-runtime-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
  .int-provider-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }

  .int-runtime-card,
  .int-provider-card {
    position: relative; display: flex; flex-direction: column;
    border: 1px solid var(--oma-border-1); border-radius: var(--radius-md);
    background: var(--oma-bg-1); color: var(--oma-fg-1); text-decoration: none;
    transition:
      transform var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out);
  }
  .int-runtime-card {
    min-height: 220px; padding: 26px 28px 28px; overflow: hidden;
  }
  .int-runtime-card::before {
    content: ''; position: absolute; inset: 0 auto 0 0; width: 3px;
    background: var(--oma-accent); opacity: 0.9;
  }
  .int-provider-card { min-height: 176px; padding: 20px; }
  .int-runtime-card:hover,
  .int-provider-card:hover {
    transform: translateY(-2px); border-color: var(--oma-border-2); box-shadow: var(--shadow-md);
  }
  .int-runtime-card:focus-visible,
  .int-provider-card:focus-visible {
    outline: 2px solid var(--oma-accent); outline-offset: 3px;
  }
  .int-hub-card-top {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
  }
  .int-hub-card-label {
    width: fit-content; color: var(--oma-accent);
    font-family: var(--font-mono); font-size: 11px; font-weight: 600;
    letter-spacing: 0.055em; text-transform: uppercase;
  }
  .int-hub-card-arrow {
    flex: 0 0 auto; color: var(--oma-accent); font-family: var(--font-mono);
    font-size: 16px; line-height: 1;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .int-runtime-card:hover .int-hub-card-arrow { transform: translate(2px, -2px); }
  .int-provider-card:hover .int-hub-card-arrow { transform: translateX(3px); }
  .int-runtime-card h3,
  .int-provider-card h3 { margin: 0; color: var(--oma-fg-0); letter-spacing: -0.015em; }
  .int-runtime-card h3 { margin-top: auto; font-size: 24px; font-weight: 650; }
  .int-provider-card h3 { font-size: 16px; font-weight: 700; line-height: 1.3; }
  .int-runtime-card p,
  .int-provider-card p { color: var(--oma-fg-2); }
  .int-runtime-card p { max-width: 520px; margin: 10px 0 0; font-size: 14px; line-height: 1.65; }
  .int-provider-card p { margin: 14px 0 18px; font-size: 13px; line-height: 1.55; }
  .int-provider-card > .int-hub-card-label { margin-top: auto; }

  @media (max-width: 1100px) {
    .int-provider-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 700px) {
    .int-hub-hero { padding-top: 48px; }
    .int-hub-intro { margin-bottom: 52px; }
    .int-hub-group + .int-hub-group { margin-top: 56px; }
    .int-hub-group-head { align-items: flex-start; gap: 16px; }
    .int-hub-count { padding-top: 4px; }
    .int-runtime-grid,
    .int-provider-grid { grid-template-columns: 1fr; }
    .int-runtime-card { min-height: 188px; padding: 22px 22px 24px; }
    .int-provider-card { min-height: 150px; padding: 19px 20px; }
  }

  @media (max-width: 420px) {
    .int-hub-group-head { display: block; }
    .int-hub-count { display: block; margin-top: 12px; }
  }
</style>
