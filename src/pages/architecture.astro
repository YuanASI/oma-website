---
// /architecture — "How OMA works": the formal architecture diagram (Batch 6A)
// and the runTeam() execution flow (Batch 6B) from the OMA brand spec, rendered
// as the dedicated page the spec's deployment guide calls for ("/architecture
// embed architecture.svg"). The diagrams are vendored into public/ from the
// design system; their hardcoded "v1.2.0 / 9 implementations" labels were
// corrected against the framework at v1.8.0 (6 built-in tools is unchanged; the
// provider count is neutralized to "multiple" per the no-hardcoded-numbers rule).
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
import '../styles/landing.css';
import Nav from '../components/Nav.astro';
import ThemeInit from '../components/ThemeInit.astro';
import Footer from '../components/Footer.astro';
import { REPO, ghStats } from '../lib/site';

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

const title = 'How OMA works — architecture & runTeam() flow';
const description =
  'The Open Multi-Agent architecture and the runTeam() execution flow, diagrammed: a coordinator decomposes a goal into a task DAG, fans agents out in parallel over a shared MessageBus, and synthesizes the result.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Visual legend for the architecture diagram (Batch 6A.3) — one entry per shape.
const STRUCTURE_LEGEND = [
  { k: 'accent border', d: 'User entry point — the class you instantiate. Exactly one per diagram.' },
  { k: 'solid', d: 'Concrete type — a class with one implementation: Team, AgentPool, TaskQueue, Agent, AgentRunner.' },
  { k: 'dashed', d: 'Interface with multiple implementations — LLMAdapter providers, ToolRegistry tools.' },
  { k: 'arrow', d: 'Owns / contains — the source instantiates or owns the target. Read top-down.' },
];

// How to read the runTeam() flow (Batch 6B.1).
const FLOW_READ = [
  { k: 'vertical = which agent', d: 'Each agent gets its own horizontal track, like a voice in a music score.' },
  { k: 'horizontal = when', d: 'Tracks aligned at the same x run at the same logical time; a track that ends earlier finished first.' },
  { k: 'reviewer waits', d: 'The reviewer is offset right — a TaskQueue dependency on the architect and the two developers.' },
  { k: 'message bus', d: 'The dashed-emerald band is the channel any agent can publish to and subscribe from during execution.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: 'How Open Multi-Agent works',
  description,
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeInit />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Open Multi-Agent" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/github-social.png', Astro.site).href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="640" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/github-social.png', Astro.site).href} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Nav current="architecture" starsK={starsK} />

    <main>
      <!-- ── Page head ── -->
      <header class="arch-hero">
        <div class="container">
          <div class="eyebrow"><span class="idx">//</span> how it works</div>
          <h1 class="arch-title">How OMA works.</h1>
          <p class="arch-lede">
            Two diagrams, one system. The <b>architecture</b> is the structure — what OMA <i>is</i>. The
            <b>flow</b> is time — what happens when you call <code>runTeam()</code>. Same visual language,
            translated from the brand system.
          </p>
        </div>
      </header>

      <!-- ── 1. Architecture (Batch 6A) ── -->
      <section class="section">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">01</span> structure</div>
            <h2 class="section-title">The architecture.</h2>
            <p class="section-sub">
              Five layers, top to bottom: the orchestrator you call, the team it coordinates, the pool and
              queue that schedule the work, the agent that does it, and the adapter, runner, and tool
              interfaces underneath. Every box maps one-to-one to a type in the framework.
            </p>
          </div>
          <figure class="diagram">
            <img
              src="/architecture.svg"
              width="1280"
              height="900"
              loading="lazy"
              decoding="async"
              alt="OMA architecture. OpenMultiAgent is the entry point and owns a Team, which holds an AgentPool and a TaskQueue. The Agent runs through an AgentRunner conversation loop and talks to the LLMAdapter interface (multiple provider implementations) and the ToolRegistry (defineTool plus 6 built-in tools)."
            />
          </figure>
          <ul class="legend">
            {STRUCTURE_LEGEND.map((l) => (
              <li class="legend-item"><span class="legend-k">{l.k}</span><span class="legend-d">{l.d}</span></li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ── 2. runTeam() flow (Batch 6B) ── -->
      <section class="section">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">02</span> execution</div>
            <h2 class="section-title">One <code>runTeam()</code> call.</h2>
            <p class="section-sub">
              Goal in, result out. The coordinator decomposes the goal into a task DAG, fans the agents out
              in parallel, carries intermediate results over the MessageBus, and synthesizes the final
              answer. Read it left to right — the horizontal axis is time.
            </p>
          </div>
          <figure class="diagram">
            <img
              src="/flow-runteam.svg"
              width="1280"
              height="720"
              loading="lazy"
              decoding="async"
              alt="The runTeam() flow. A goal decomposes into four tasks; an architect and two developers run in parallel, the reviewer waits on them via a TaskQueue dependency, the MessageBus connects the tracks, and a typed result object is synthesized at the end."
            />
          </figure>
          <ul class="legend">
            {FLOW_READ.map((l) => (
              <li class="legend-item"><span class="legend-k">{l.k}</span><span class="legend-d">{l.d}</span></li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ── 3. Next ── -->
      <section class="section" style="border-top:1px solid var(--border-subtle);">
        <div class="container cta-final">
          <div class="eyebrow" style="justify-content:center;"><span class="idx">//</span> go deeper</div>
          <h2>From diagram to code.</h2>
          <div class="cta-actions">
            <a class="text-link" href="/getting-started/three-ways-to-run/"><span>runAgent · runTeam · runTasks</span><span class="arrow">→</span></a>
            <a class="text-link" href="/getting-started/quick-start/"><span>Quick Start</span><span class="arrow">→</span></a>
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <style>
      .arch-hero { padding: var(--space-16) 0 var(--space-8); border-bottom: 1px solid var(--border-subtle); }
      .arch-title {
        font-family: var(--font-sans); font-weight: 600; letter-spacing: -0.035em;
        font-size: clamp(34px, 5vw, 52px); line-height: 1.05; color: var(--text-strong); margin: 14px 0 0;
      }
      .arch-lede { font-size: 17px; line-height: 1.6; color: var(--text-body); margin: 18px 0 0; max-width: 640px; }
      .arch-lede code { font-family: var(--font-mono); font-size: 0.9em; color: var(--oma-accent); }

      /* Diagrams are dark-canvas SVGs — frame them as a raised dark card in both
         themes (the terminal-panel treatment the landing uses), so they read as a
         deliberate figure rather than a stray dark block on the light canvas. */
      .diagram {
        margin: 0; border: 1px solid var(--border-default); border-radius: var(--radius-lg);
        overflow: hidden; background: #0A0908; box-shadow: var(--shadow-md);
      }
      .diagram img { display: block; width: 100%; height: auto; }

      .legend {
        list-style: none; margin: var(--space-6) 0 0; padding: 0;
        display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4) var(--space-8);
      }
      .legend-item { display: flex; gap: var(--space-3); align-items: baseline; }
      .legend-k {
        font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.04em; text-transform: uppercase;
        color: var(--oma-accent); white-space: nowrap; flex: none; min-width: 124px;
      }
      .legend-d { font-size: 14px; line-height: 1.55; color: var(--text-body); }

      @media (max-width: 720px) {
        .legend { grid-template-columns: 1fr; gap: var(--space-3); }
        .legend-k { min-width: 0; }
      }
    </style>
  </body>
</html>
