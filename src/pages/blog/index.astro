---
// /blog — index of posts migrated from dev.to (src/content/blog). Same
// self-contained landing-style shell as index.astro / examples.astro (shared
// Nav/Footer), listing the `blog` collection newest-first.
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../../styles/tokens.css';
import '../../styles/landing.css';
import '../../styles/blog.css';
import Card from '../../components/ds/Card.astro';
import Badge from '../../components/ds/Badge.astro';
import Nav from '../../components/Nav.astro';
import ThemeInit from '../../components/ThemeInit.astro';
import Footer from '../../components/Footer.astro';
import { ghStats } from '../../lib/site';
import { getCollection } from 'astro:content';

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const title = 'Blog — Open Multi-Agent';
const description =
  'Writing on TypeScript multi-agent orchestration: goal-driven task DAGs, mixed-model teams, long-term memory, and lessons from the agent-framework ecosystem.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/github-social.png', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: title,
  description,
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    datePublished: p.data.pubDate.toISOString(),
    url: new URL(`/blog/${p.id}/`, Astro.site).href,
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeInit />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Open Multi-Agent blog" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Open Multi-Agent" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="640" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Nav current="blog" starsK={starsK} />
    <main>
      <section class="section">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">//</span> Blog</div>
            <h1 class="section-title">Notes on multi-agent orchestration.</h1>
            <p class="section-sub">
              Deep dives on goal-driven task DAGs, mixed-model teams, and the TypeScript agent
              ecosystem. Cross-posted from <a class="text-link" href="https://dev.to/jackchenme" target="_blank" rel="noreferrer">dev.to</a>.
            </p>
          </div>
          <div class="blog-list">
            {posts.map((p) => (
              <a class="blog-card-link" href={`/blog/${p.id}/`}>
                <Card padding="lg" interactive>
                  <div class="blog-card-meta">
                    <time datetime={p.data.pubDate.toISOString()}>{fmtDate(p.data.pubDate)}</time>
                    {' · '}{p.data.readingMinutes} min read
                  </div>
                  <h2 class="blog-card-title">{p.data.title}</h2>
                  <p class="blog-card-desc">{p.data.description}</p>
                  <div class="blog-card-tags">
                    {p.data.tags.map((t) => <Badge tone="neutral">{t}</Badge>)}
                  </div>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
