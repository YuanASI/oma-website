---
// /showcase (PRD §4.4) — projects built with OMA and tools that integrate with
// it. Same landing-style shell (shared Nav/Footer) as index/examples; the cards
// reuse the landing proof DS. Entries come from src/lib/showcase.ts (the same
// list the landing proof section features a subset of). No per-project star
// counts — the point is "who uses it", not their popularity.
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
import '../styles/landing.css';
import Card from '../components/ds/Card.astro';
import Badge from '../components/ds/Badge.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { REPO, ghStats } from '../lib/site';
import { SHOWCASE } from '../lib/showcase';

const stats = await ghStats();
const starsK = (stats.stars / 1000).toFixed(1) + 'k';

const builtWith = SHOWCASE.filter((c) => c.kind === 'built-with');
const integrations = SHOWCASE.filter((c) => c.kind === 'integration');
const DISCUSS = REPO + '/discussions';

const title = 'Showcase — Open Multi-Agent';
const description =
  'Open-source projects built with Open Multi-Agent and tools that integrate with it — from a production WordPress security platform to PR review, agent memory, and observability.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/github-social.png', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: SHOWCASE.map((c, i) => ({
      '@type': 'ListItem', position: i + 1, name: c.pkg, url: c.href,
    })),
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="640" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Nav current="showcase" starsK={starsK} />
    <main>
      <section class="section" id="top">
        <div class="container">
          <div class="section-head">
            <div class="eyebrow"><span class="idx">//</span> Showcase</div>
            <h1 class="section-title">Built on Open Multi-Agent.</h1>
            <p class="section-sub">
              Open-source projects built with the framework, and tools that integrate with it —
              drawn from the ecosystem, MIT-licensed. Building something with OMA?
              <a class="text-link" href={DISCUSS} target="_blank" rel="noreferrer"><span>Open a discussion</span><span class="arrow">→</span></a> to get listed.
            </p>
          </div>
        </div>
      </section>

      <section class="section" id="built-with" style="padding-top:0;">
        <div class="container">
          <div class="section-head"><div class="eyebrow"><span class="idx">01</span> Built with OMA</div></div>
          <div class="cases-grid">
            {builtWith.map((c) => (
              <a class="case-link" href={c.href} target="_blank" rel="noreferrer" style="text-decoration:none;">
                <Card padding="lg" interactive>
                  <div class="case-pkg">{c.pkg}</div>
                  <div class="case-by">{c.by}</div>
                  <p class="case-desc">{c.desc}</p>
                  <div class="case-foot">
                    <Badge tone={c.tone}>{c.tag}</Badge>
                    <span class="case-dep">{c.status}</span>
                  </div>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section" id="integrations" style="padding-top:0;">
        <div class="container">
          <div class="section-head"><div class="eyebrow"><span class="idx">02</span> Integrations</div></div>
          <div class="cases-grid">
            {integrations.map((c) => (
              <a class="case-link" href={c.href} target="_blank" rel="noreferrer" style="text-decoration:none;">
                <Card padding="lg" interactive>
                  <div class="case-pkg">{c.pkg}</div>
                  <div class="case-by">{c.by}</div>
                  <p class="case-desc">{c.desc}</p>
                  <div class="case-foot">
                    <Badge tone={c.tone}>{c.tag}</Badge>
                    <span class="case-dep">{c.status}</span>
                  </div>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
