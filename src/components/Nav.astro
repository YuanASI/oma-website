---
// Global top nav (§3). Shared by every custom page so the chrome stays in one
// place. `current` marks the active in-site link; `starsK` is the build-time star
// count (e.g. "6.4k"); `locale` localizes the labels and the in-site links (Blog
// is intentionally not localized — the blog stays English); `path` is this page's
// default-locale path, handed to the language switcher.
import { REPO, FORGE } from '../lib/site';
import { useTranslations, localizePath, type Locale } from '../i18n';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  current?: 'home' | 'docs' | 'architecture' | 'examples' | 'showcase' | 'blog';
  starsK: string;
  locale?: Locale;
  path?: string;
}
const { current = 'home', starsK, locale = 'en', path } = Astro.props;
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);
---

<nav class="nav">
  <div class="container nav-inner">
    <a class="brand" href={L('/')} aria-label={t.nav.brandAria}>
      <img class="brand-mark brand-mark--dark" src="/logo-mark-dark.svg" alt="" width="26" height="26" />
      <img class="brand-mark brand-mark--light" src="/logo-mark-light.svg" alt="" width="26" height="26" />
      <span class="brand-word" aria-hidden="true">open<span class="dash">-</span>multi<span class="dash">-</span>agent</span>
    </a>
    <div class="nav-links">
      <div class="nav-item">
        <button type="button" class="nav-menu-btn" aria-haspopup="true">{t.nav.product} <span class="nav-menu-caret">▾</span></button>
        <div class="nav-menu">
          <a class="nav-menu-link" href={REPO} target="_blank" rel="noreferrer">
            <span class="pkg">{t.nav.productMenu.framework.pkg} <span class="ext">↗</span></span>
            <span class="desc">{t.nav.productMenu.framework.desc}</span>
          </a>
          <a class="nav-menu-link" href={FORGE} target="_blank" rel="noreferrer">
            <span class="pkg">{t.nav.productMenu.forge.pkg} <span class="ext">↗</span></span>
            <span class="desc">{t.nav.productMenu.forge.desc}</span>
          </a>
        </div>
      </div>
      <a class="nav-link" href={L('/getting-started/introduction/')} aria-current={current === 'docs' ? 'page' : undefined}>{t.nav.docs}</a>
      <a class="nav-link" href={L('/architecture/')} aria-current={current === 'architecture' ? 'page' : undefined}>{t.nav.architecture}</a>
      <a class="nav-link" href={L('/examples/')} aria-current={current === 'examples' ? 'page' : undefined}>{t.nav.examples}</a>
      <a class="nav-link" href={L('/showcase/')} aria-current={current === 'showcase' ? 'page' : undefined}>{t.nav.showcase}</a>
      <a class="nav-link" href="/blog/" aria-current={current === 'blog' ? 'page' : undefined}>{t.nav.blog}</a>
    </div>
    <div class="nav-ghost">
      <a class="nav-github" href={REPO} target="_blank" rel="noreferrer" aria-label={`GitHub — ${starsK} ${t.nav.stars}`} title="GitHub">
        <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        <span class="nav-github-stars">★ {starsK}</span>
      </a>
      <button type="button" class="nav-theme-toggle" aria-label={t.nav.toggleThemeAria} title={t.nav.toggleThemeTitle}>
        <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      </button>
      <LangSwitcher locale={locale} path={path} />
      <button type="button" class="nav-mobile-toggle" aria-label={t.nav.menuAria}>≡</button>
    </div>
  </div>
</nav>

<script>
  // Mobile nav toggle (co-located with the markup it drives).
  const toggle = document.querySelector<HTMLElement>('.nav-mobile-toggle');
  const links = document.querySelector<HTMLElement>('.nav-links');
  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    toggle.textContent = open ? '✕' : '≡';
    // Lock background scroll while the mobile menu is open.
    document.body.style.overflow = open ? 'hidden' : '';
  });

  // Theme toggle — flips <html data-theme> and persists to the SAME key Starlight
  // uses ('starlight-theme'), so the choice syncs both ways with the docs. The
  // visible icon is CSS-driven off [data-theme] (set pre-paint by ThemeInit), so
  // there's no flash here. 2-state light/dark; Starlight keeps its own 'auto'.
  const themeToggle = document.querySelector<HTMLElement>('.nav-theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem('starlight-theme', next); } catch { /* ignore */ }
  });
</script>
