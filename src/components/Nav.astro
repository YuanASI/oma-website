---
// Global top nav (§3). Shared by every custom page so the chrome stays in one
// place. `current` marks the active in-site link; `starsK` is the build-time star
// count (e.g. "6.4k"); `locale` localizes the labels and the in-site links; `path`
// is this page's default-locale path, handed to the language switcher.
import { REPO } from '../lib/site';
import { getFeaturedUseCases, detailSlugs } from '../lib/examples';
import { SOLUTIONS } from '../lib/solutions';
import { useTranslations, localizePath, type Locale } from '../i18n';
import type { Loc } from '../lib/compare';
import LangSwitcher from './LangSwitcher.astro';
import EnterpriseLink from './EnterpriseLink.astro';

interface Props {
  current?: 'home' | 'docs' | 'architecture' | 'examples' | 'showcase' | 'blog' | 'compare' | 'solutions' | 'integrations';
  starsK: string;
  locale?: Locale;
  path?: string;
}
const { current = 'home', starsK, locale = 'en', path } = Astro.props;
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

// The catalog's first featured use-case recipes. The exhaustive goal-grouped
// inventory remains on /examples; no separate slug list is maintained here.
const useCases = getFeaturedUseCases();
const useCaseDetails = detailSlugs();
const ucTitle = (e: { id: string; title: string }) => t.examples.entries[e.id]?.title ?? e.title;
const ucHref = (e: { id: string; href: string }) => useCaseDetails.has(e.id) ? L(`/examples/${e.id}/`) : e.href;
const ucExternal = (e: { id: string }) => !useCaseDetails.has(e.id);
const pick = (o: Loc) => o[locale];
const capabilitiesCurrent = current === 'architecture' || current === 'integrations';
const whyOmaCurrent = current === 'compare' || current === 'showcase';
---

<nav class="nav">
  <div class="container nav-inner">
    <a class="brand" href={L('/')}>
      <img class="brand-mark brand-mark--dark" src="/logo-mark-dark.svg" alt="" width="26" height="26" />
      <img class="brand-mark brand-mark--light" src="/logo-mark-light.svg" alt="" width="26" height="26" />
      <span class="brand-word">open<span class="dash">-</span>multi<span class="dash">-</span>agent</span>
    </a>
    <div class="nav-links" id="primary-navigation">
      <div class="nav-item">
        <button type="button" class={`nav-menu-btn${capabilitiesCurrent ? ' is-current' : ''}`} aria-haspopup="true" aria-expanded="false" aria-controls="capabilities-menu">{t.nav.capabilities} <span class="nav-menu-caret">▾</span></button>
        <div class="nav-menu nav-menu--cols nav-menu--capabilities" id="capabilities-menu">
          <div class="nav-col">
            <div class="nav-col-head">{t.nav.capabilityCols.build}</div>
            <a class="nav-menu-link nav-menu-link--page" href={L('/getting-started/three-ways-to-run/')}>
              <span class="pkg">{t.nav.capabilityMenu.orchestration.title}</span>
              <span class="desc">{t.nav.capabilityMenu.orchestration.desc}</span>
            </a>
            <a class="nav-menu-link nav-menu-link--page" href={L('/reference/providers/')}>
              <span class="pkg">{t.nav.capabilityMenu.models.title}</span>
              <span class="desc">{t.nav.capabilityMenu.models.desc}</span>
            </a>
            <a class="nav-menu-link nav-menu-link--page" href={L('/reference/tool-configuration/')}>
              <span class="pkg">{t.nav.capabilityMenu.tools.title}</span>
              <span class="desc">{t.nav.capabilityMenu.tools.desc}</span>
            </a>
            <a class="nav-menu-link nav-menu-link--page" href={L('/integrations/external-agents/')}>
              <span class="pkg">{t.nav.capabilityMenu.externalAgents.title}</span>
              <span class="desc">{t.nav.capabilityMenu.externalAgents.desc}</span>
            </a>
            <a class="nav-menu-link nav-menu-link--page nav-menu-link--all" href={L('/integrations/')}>
              <span class="pkg">{t.nav.capabilityMenu.allIntegrations} →</span>
            </a>
          </div>
          <div class="nav-col">
            <div class="nav-col-head">{t.nav.capabilityCols.operate}</div>
            <a class="nav-menu-link nav-menu-link--page" href={L('/reference/evaluation/')}>
              <span class="pkg">{t.nav.capabilityMenu.evaluation.title}</span>
              <span class="desc">{t.nav.capabilityMenu.evaluation.desc}</span>
            </a>
            <a class="nav-menu-link nav-menu-link--page" href={L('/reference/observability/')}>
              <span class="pkg">{t.nav.capabilityMenu.observability.title}</span>
              <span class="desc">{t.nav.capabilityMenu.observability.desc}</span>
            </a>
            <a class="nav-menu-link nav-menu-link--page" href={L('/guides/production-checklist/')}>
              <span class="pkg">{t.nav.capabilityMenu.reliability.title}</span>
              <span class="desc">{t.nav.capabilityMenu.reliability.desc}</span>
            </a>
          </div>
        </div>
      </div>
      <div class="nav-item">
        <button type="button" class={`nav-menu-btn${current === 'examples' || current === 'solutions' ? ' is-current' : ''}`} aria-haspopup="true" aria-expanded="false" aria-controls="use-cases-menu">{t.nav.useCases} <span class="nav-menu-caret">▾</span></button>
        <div class="nav-menu nav-menu--cols" id="use-cases-menu">
          <div class="nav-col">
            <div class="nav-col-head">{t.nav.useCasesCols.solutions}</div>
            {SOLUTIONS.map((s) => (
              <a class="nav-menu-link nav-menu-link--page nav-menu-link--compact" href={L(`/solutions/${s.slug}/`)}>
                <span class="pkg">{pick(s.navLabel)}</span>
              </a>
            ))}
            <a class="nav-menu-link nav-menu-link--page nav-menu-link--all" href={L('/solutions/')}>
              <span class="pkg">{t.nav.viewAllSolutions} →</span>
            </a>
          </div>
          <div class="nav-col">
            <div class="nav-col-head">{t.nav.useCasesCols.examples}</div>
            {useCases.map((e) => (
              <a class="nav-menu-link nav-menu-link--page nav-menu-link--compact" href={ucHref(e)} target={ucExternal(e) ? '_blank' : undefined} rel={ucExternal(e) ? 'noreferrer' : undefined}>
                <span class="pkg">{ucTitle(e)}</span>
              </a>
            ))}
            <a class="nav-menu-link nav-menu-link--page nav-menu-link--all" href={L('/examples/')}>
              <span class="pkg">{t.examples.detail.browseAll} →</span>
            </a>
          </div>
        </div>
      </div>
      <div class="nav-item">
        <button type="button" class={`nav-menu-btn${whyOmaCurrent ? ' is-current' : ''}`} aria-haspopup="true" aria-expanded="false" aria-controls="why-oma-menu">{t.nav.whyOma} <span class="nav-menu-caret">▾</span></button>
        <div class="nav-menu" id="why-oma-menu">
          <a class="nav-menu-link nav-menu-link--page" href={L('/compare/')} aria-current={current === 'compare' ? 'page' : undefined}>
            <span class="pkg">{t.nav.compare}</span>
            <span class="desc">{t.nav.whyOmaDesc.compare}</span>
          </a>
          <a class="nav-menu-link nav-menu-link--page" href={L('/showcase/')} aria-current={current === 'showcase' ? 'page' : undefined}>
            <span class="pkg">{t.nav.showcase}</span>
            <span class="desc">{t.nav.whyOmaDesc.showcase}</span>
          </a>
        </div>
      </div>
      <a class="nav-link" href={L('/getting-started/introduction/')} aria-current={current === 'docs' ? 'page' : undefined}>{t.nav.docs}</a>
      <a class="nav-link" href={L('/blog/')} aria-current={current === 'blog' ? 'page' : undefined}>{t.nav.blog}</a>
      <EnterpriseLink class="nav-link nav-link--ext" locale={locale}>
        {t.nav.forCompanies} {locale === 'en' && <span class="ext" aria-hidden="true">↗</span>}
      </EnterpriseLink>
    </div>
    <div class="nav-ghost">
      <a class="nav-github" href={REPO} target="_blank" rel="noreferrer" aria-label={`GitHub — ${starsK} ${t.nav.stars}`} title="GitHub">
        <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        <span class="nav-github-stars">★ {starsK}</span>
      </a>
      <button type="button" class="nav-theme-toggle" aria-label={t.nav.toggleThemeAria} title={t.nav.toggleThemeTitle}>
        <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      </button>
      <LangSwitcher locale={locale} path={path} />
      <button type="button" class="nav-mobile-toggle" aria-label={t.nav.menuAria} aria-expanded="false" aria-controls="primary-navigation">≡</button>
    </div>
  </div>
</nav>

<script>
  // Mobile nav toggle (co-located with the markup it drives).
  const toggle = document.querySelector<HTMLElement>('.nav-mobile-toggle');
  const links = document.querySelector<HTMLElement>('.nav-links');
  const closeMobileNav = () => {
    links?.classList.remove('open');
    if (toggle) {
      toggle.textContent = '≡';
      toggle.setAttribute('aria-expanded', 'false');
    }
    document.body.style.overflow = '';
  };
  toggle?.addEventListener('click', () => {
    const open = Boolean(links?.classList.toggle('open'));
    toggle.textContent = open ? '✕' : '≡';
    toggle.setAttribute('aria-expanded', String(open));
    // Lock background scroll while the mobile menu is open.
    document.body.style.overflow = open ? 'hidden' : '';
  });

  document.querySelectorAll<HTMLElement>('.nav-item').forEach((item) => {
    const button = item.querySelector<HTMLElement>('.nav-menu-btn');
    const setExpanded = (open: boolean) => button?.setAttribute('aria-expanded', String(open));
    item.addEventListener('mouseenter', () => setExpanded(true));
    item.addEventListener('mouseleave', () => setExpanded(false));
    item.addEventListener('focusin', () => setExpanded(true));
    item.addEventListener('focusout', (event) => {
      if (!item.contains(event.relatedTarget as Node | null)) setExpanded(false);
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    closeMobileNav();
    document.querySelectorAll<HTMLElement>('.nav-menu-btn').forEach((button) => button.setAttribute('aria-expanded', 'false'));
    toggle?.focus();
  });

  // Theme toggle — flips <html data-theme> and persists to the SAME key Starlight
  // uses ('starlight-theme'), so the choice syncs both ways with the docs. The
  // visible icon is CSS-driven off [data-theme] (set pre-paint by ThemeInit), so
  // there's no flash here. 2-state light/dark; Starlight keeps its own 'auto'.
  const themeToggle = document.querySelector<HTMLElement>('.nav-theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem('starlight-theme', next); } catch { /* ignore */ }
  });
</script>

<style>
  /* Resources-menu items are page links, not packages — keep the label in the
     sans nav font, not the mono .pkg default (which is meant for package names). */
  .nav-menu-link--page .pkg { font-family: var(--font-sans); font-weight: 500; }

  /* The English For Companies link keeps its external ↗ marker. Chinese opens
     the in-page contact dialog and therefore intentionally has no marker. */
  .nav-link--ext .ext { color: var(--oma-fg-3); font-size: 11px; margin-left: 1px; }

  /* Capability and Use Cases dropdowns share the same two-column shell. The
     capability menu keeps product surfaces grouped by build vs operate instead
     of mixing architecture, selection content, integrations, and social proof. */
  .nav-menu--capabilities .nav-col { min-width: 264px; }

  /* Use Cases dropdown: the button reads active on any /examples or /solutions
     page. Two columns — Solutions (capability shapes → /solutions/*) and Examples
     (featured workflows → /examples/*) — each a list of compact rows (label only)
     with a "view all" link separated at its foot. */
  .nav-menu-btn.is-current { color: var(--oma-fg-0); }
  .nav-menu--cols { flex-direction: row; gap: 8px; }
  .nav-col { display: flex; flex-direction: column; gap: 2px; min-width: 210px; }
  .nav-col + .nav-col { border-left: 1px solid var(--border-subtle); padding-left: 8px; }
  .nav-col-head {
    font-family: var(--font-mono); font-size: 10.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--oma-fg-3);
    padding: 4px 12px 6px;
  }
  .nav-menu-link--compact { padding-top: 7px; padding-bottom: 7px; }
  .nav-menu-link--all { margin-top: 4px; padding-top: 10px; border-top: 1px solid var(--border-subtle); }
  .nav-menu-link--all .pkg { color: var(--oma-accent); }

  @media (max-width: 1200px) {
    .nav-links.open .nav-menu--capabilities .nav-col { min-width: 0; }
  }
</style>
