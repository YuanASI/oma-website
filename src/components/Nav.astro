---
// Global top nav (§3). Shared by the landing page and /examples so the chrome
// stays in one place. `current` marks the active in-site link; `starsK` is the
// build-time star count (e.g. "6.4k") passed in by the page.
import { REPO, FORGE } from '../lib/site';

interface Props {
  current?: 'home' | 'docs' | 'examples' | 'showcase' | 'blog';
  starsK: string;
}
const { current = 'home', starsK } = Astro.props;
---

<nav class="nav">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label="Open Multi-Agent — home">
      <img class="brand-mark" src="/logo-mark-dark.svg" alt="" width="26" height="26" />
      <span class="brand-word" aria-hidden="true">open<span class="dash">-</span>multi<span class="dash">-</span>agent</span>
    </a>
    <div class="nav-links">
      <div class="nav-item">
        <button type="button" class="nav-menu-btn" aria-haspopup="true">Product <span class="nav-menu-caret">▾</span></button>
        <div class="nav-menu">
          <a class="nav-menu-link" href={REPO} target="_blank" rel="noreferrer">
            <span class="pkg">open-multi-agent <span class="ext">↗</span></span>
            <span class="desc">The multi-agent orchestration framework.</span>
          </a>
          <a class="nav-menu-link" href={FORGE} target="_blank" rel="noreferrer">
            <span class="pkg">oma-forge <span class="ext">↗</span></span>
            <span class="desc">Experimental project under the open-multi-agent org.</span>
          </a>
        </div>
      </div>
      <a class="nav-link" href="/getting-started/introduction/" aria-current={current === 'docs' ? 'page' : undefined}>Docs</a>
      <a class="nav-link" href="/examples/" aria-current={current === 'examples' ? 'page' : undefined}>Examples</a>
      <a class="nav-link" href="/showcase/" aria-current={current === 'showcase' ? 'page' : undefined}>Showcase</a>
      <a class="nav-link" href="/blog/" aria-current={current === 'blog' ? 'page' : undefined}>Blog</a>
      <a class="nav-link" href={REPO} target="_blank" rel="noreferrer" style="display:inline-flex;align-items:center;gap:7px;">
        <span>GitHub</span><span style="color:var(--oma-fg-2);">★ {starsK}</span>
      </a>
    </div>
    <div class="nav-ghost">
      <button type="button" class="nav-theme-toggle" aria-label="Toggle light/dark theme" title="Toggle theme">
        <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      </button>
      <button type="button" class="nav-mobile-toggle" aria-label="Menu">≡</button>
    </div>
  </div>
</nav>

<script>
  // Mobile nav toggle (co-located with the markup it drives).
  const toggle = document.querySelector<HTMLElement>('.nav-mobile-toggle');
  const links = document.querySelector<HTMLElement>('.nav-links');
  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    toggle.textContent = open ? '✕' : '≡';
  });

  // Theme toggle — flips <html data-theme> and persists to the SAME key Starlight
  // uses ('starlight-theme'), so the choice syncs both ways with the docs. The
  // visible icon is CSS-driven off [data-theme] (set pre-paint by ThemeInit), so
  // there's no flash here. 2-state light/dark; Starlight keeps its own 'auto'.
  const themeToggle = document.querySelector<HTMLElement>('.nav-theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem('starlight-theme', next); } catch { /* ignore */ }
  });
</script>
