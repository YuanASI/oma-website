---
// Enterprise primary button for page-hero headers — the right-side solid button
// paired with each page's H1, filling the empty space beside the title. Same
// target and label as the footer link and the closing EnterpriseCta band
// (locale-matched YuanASI delivery). Styling is the shared .btn-primary; the
// hosting page wraps this in a .hero-head-row next to its .section-head.
import { yuanasiHref } from '../lib/site';
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = useTranslations(locale).enterpriseCta;
const href = yuanasiHref(locale);
---

<a class="btn-primary hero-head-cta" href={href} target="_blank" rel="noreferrer">
  <span>{t.button}</span><span class="arrow" aria-hidden="true">→</span>
</a>
