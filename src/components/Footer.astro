---
// Global footer. Shared by every custom page. `locale` localizes the labels and
// the in-site links. External URLs (GitHub/npm/license/llms.txt/RSS) stay as-is —
// those resources have a single, English form.
import { REPO, NPM } from '../lib/site';
import { useTranslations, localizePath, type Locale } from '../i18n';
import EnterpriseLink from './EnterpriseLink.astro';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div style="max-width:280px;">
        <div class="footer-left">
          <img class="brand-mark brand-mark--dark" src="/logo-mark-dark.svg" alt="" width="26" height="26" />
          <img class="brand-mark brand-mark--light" src="/logo-mark-light.svg" alt="" width="26" height="26" />
          <span class="brand-word">open<span class="dash">-</span>multi<span class="dash">-</span>agent</span>
        </div>
        <p class="footer-blurb" set:html={t.footer.blurb}></p>
      </div>
      <div class="footer-cols">
        <div>
          <div class="footer-col-head">{t.footer.product.head}</div>
          <div class="footer-col-links">
            <a class="nav-link" href={L('/#capabilities')} style="font-size:13px;">{t.footer.product.capabilities}</a>
            <a class="nav-link" href={L('/#build')} style="font-size:13px;">{t.footer.product.useCases}</a>
            <a class="nav-link" href={L('/integrations/')} style="font-size:13px;">{t.footer.product.integrations}</a>
            <a class="nav-link" href={L('/#faq')} style="font-size:13px;">{t.footer.product.faq}</a>
          </div>
        </div>
        <div>
          <div class="footer-col-head">{t.footer.resources.head}</div>
          <div class="footer-col-links">
            <a class="nav-link" href={L('/getting-started/introduction/')} style="font-size:13px;">{t.footer.resources.docs}</a>
            <a class="nav-link" href={L('/architecture/')} style="font-size:13px;">{t.footer.resources.architecture}</a>
            <a class="nav-link" href={L('/examples/')} style="font-size:13px;">{t.footer.resources.examples}</a>
            <a class="nav-link" href={L('/showcase/')} style="font-size:13px;">{t.footer.resources.showcase}</a>
            <a class="nav-link" href={L('/compare/')} style="font-size:13px;">{t.footer.resources.compare}</a>
            <a class="nav-link" href={L('/blog/')} style="font-size:13px;">{t.footer.resources.blog}</a>
            <EnterpriseLink class="nav-link" locale={locale} style="font-size:13px;">{t.footer.resourcesEnterprise}</EnterpriseLink>
          </div>
        </div>
        <div>
          <div class="footer-col-head">{t.footer.project.head}</div>
          <div class="footer-col-links">
            <a class="nav-link" href={REPO} target="_blank" rel="noreferrer" style="font-size:13px;">{t.footer.project.github}</a>
            <a class="nav-link" href={NPM} target="_blank" rel="noreferrer" style="font-size:13px;">{t.footer.project.npm}</a>
            <a class="nav-link" href={REPO + '/blob/main/LICENSE'} target="_blank" rel="noreferrer" style="font-size:13px;">{t.footer.project.mitLicense}</a>
            <a class="nav-link" href="/llms.txt" style="font-size:13px;">{t.footer.project.llmsTxt}</a>
            <a class="nav-link" href="/rss.xml" style="font-size:13px;">{t.footer.project.rss}</a>
          </div>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-meta">{t.footer.mitLicensed}</span>
      <span class="footer-meta">{t.footer.builtBy} <a class="by" href="https://yuanasi.com" target="_blank" rel="noreferrer">元定义科技 (YuanASI)</a></span>
    </div>
  </div>
</footer>
