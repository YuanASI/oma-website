---
// Starlight <head> override. Starlight's default head emits og:* and
// twitter:card but no social-card image and no structured data, so docs links
// render a blank card and carry no JSON-LD. This wraps the default head, adds
// the shared social image (matching the custom pages in src/pages/), and emits
// a per-page TechArticle — mirroring architecture.astro's shape. Custom
// landing/blog pages set their own <head>; this only covers Starlight docs.
//
// i18n: once `locales` is configured (astro.config.mjs), Starlight's default
// head already emits the hreflang alternates and og:locale for each locale, so
// we don't — duplicating them would emit two of each. The one thing Starlight
// does NOT carry is JSON-LD, so we add `inLanguage` (from the route's BCP-47
// `lang`) to the TechArticle below.
import Default from '@astrojs/starlight/components/Head.astro';
import LangInit from './LangInit.astro';

const { entry, lang } = Astro.locals.starlightRoute;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/github-social.png', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  inLanguage: lang,
  headline: entry.data.title,
  description: entry.data.description,
  url: canonical,
  isPartOf: { '@type': 'WebSite', name: 'Open Multi-Agent', url: 'https://open-multi-agent.com' },
};
---

<Default><slot /></Default>
{/* Raster favicons for Google Search + legacy clients. The Default head already
    emits the SVG icon, so we only add the ICO/PNG set (scripts/generate-favicons.mjs). */}
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta property="og:image" content={ogImage} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1280" />
<meta property="og:image:height" content="640" />
<meta property="og:image:alt" content="Open Multi-Agent" />
<meta name="twitter:image" content={ogImage} />
<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
{/* Counterscale — first-party, cookieless analytics. Identical tag in
    BaseLayout.astro (custom pages + blog); this covers the Starlight docs. */}
<script is:inline id="counterscale-script"
  src="https://insights.open-multi-agent.com/tracker.js"
  data-site-id="open-multi-agent.com" defer></script>
{/* Baidu 百度统计 — Chinese-market analytics + Baidu site verification.
    Identical tag in BaseLayout.astro (custom pages + blog); this covers docs. */}
<script is:inline>
  var _hmt = _hmt || [];
  (function () {
    var hm = document.createElement('script');
    hm.src = 'https://hm.baidu.com/hm.js?2e6b1d4a79147dca8349670cc68f0b68';
    var s = document.getElementsByTagName('script')[0];
    s.parentNode.insertBefore(hm, s);
  })();
</script>
<LangInit />
