---
// TaskNode — the signature DAG task node. Mirrors the post-run dashboard:
// #NODE id, title, status line with duration, role + state badges, and a
// status-keyed left-rail.
import Badge from './Badge.astro';

interface Props {
  id?: string;
  title?: string;
  status?: 'done' | 'running' | 'queued' | 'failed' | 'skipped';
  duration?: string | null;
  role?: string | null;
  selected?: boolean;
}
const {
  id = '#NODE_001',
  title = 'Untitled task',
  status = 'done',
  duration = null,
  role = null,
  selected = false,
} = Astro.props;

const STATUS: Record<string, { label: string; color: string; rail: string }> = {
  done:    { label: 'DONE',    color: 'var(--oma-accent)',  rail: 'var(--oma-accent)' },
  running: { label: 'RUNNING', color: 'var(--oma-warning)', rail: 'var(--oma-warning)' },
  queued:  { label: 'QUEUED',  color: 'var(--oma-fg-2)',    rail: 'var(--oma-border-2)' },
  failed:  { label: 'FAILED',  color: 'var(--oma-danger)',  rail: 'var(--oma-danger)' },
  skipped: { label: 'SKIPPED', color: 'var(--oma-fg-3)',    rail: 'var(--oma-border-1)' },
};
const s = STATUS[status] ?? STATUS.done;
const mark = status === 'done' ? '✓' : status === 'failed' ? '✕' : status === 'running' ? '◓' : '○';
---

<div class={`ds-tasknode${selected ? ' is-selected' : ''}`}>
  <span class="ds-tasknode__rail" style={`background:${s.rail}`}></span>
  <div class="ds-tasknode__top">
    <span class="ds-tasknode__id">{id}</span>
    <span class="ds-tasknode__mark" style={`color:${s.color}`}>{mark}</span>
  </div>
  <div class="ds-tasknode__title">{title}</div>
  <div class="ds-tasknode__status">STATUS: <span style={`color:${s.color};font-weight:500`}>{s.label}</span>{duration ? ` (${duration})` : ''}</div>
  {role && (
    <div class="ds-tasknode__badges">
      <Badge tone="neutral">{role}</Badge>
      {status === 'done' && <Badge tone="accent">stable</Badge>}
      {status === 'running' && <Badge tone="warning" dot>live</Badge>}
      {status === 'failed' && <Badge tone="danger">error</Badge>}
    </div>
  )}
</div>

<style>
  .ds-tasknode {
    position: relative; width: 100%; min-width: 0;
    background: var(--oma-bg-1); border: 1px solid var(--oma-border-1);
    border-radius: var(--radius-md); padding: 14px 16px 14px 18px;
    font-family: var(--font-sans); box-shadow: none;
    transition: border-color var(--duration-base) var(--ease-out), box-shadow var(--duration-base) var(--ease-out);
  }
  .ds-tasknode:hover { border-color: var(--oma-border-2); box-shadow: var(--shadow-md); }
  .ds-tasknode.is-selected { border-color: var(--oma-accent); box-shadow: var(--shadow-accent-glow); }
  .ds-tasknode__rail { position: absolute; left: 0; top: 14px; bottom: 14px; width: 2px; border-radius: 2px; }
  .ds-tasknode__top { display: flex; align-items: center; justify-content: space-between; }
  .ds-tasknode__id { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; color: var(--oma-fg-2); }
  .ds-tasknode__mark { font-size: 13px; line-height: 1; }
  .ds-tasknode__title { color: var(--oma-fg-0); font-size: 15px; font-weight: 600; line-height: 1.3; margin: 8px 0 6px; }
  .ds-tasknode__status { font-family: var(--font-mono); font-size: 11px; color: var(--oma-fg-2); }
  .ds-tasknode__badges { display: flex; gap: 6px; margin-top: 10px; }
</style>
