---
// TaskNode — the signature DAG task node. Mirrors the post-run dashboard:
// #NODE id, title, status line with duration, and role + state badges.
import Badge from './Badge.astro';
import { useTranslations, type Locale } from '../../i18n';

type Status = 'done' | 'running' | 'queued' | 'failed' | 'skipped';

interface Props {
  id?: string;
  title?: string;
  status?: Status;
  duration?: string | null;
  role?: string | null;
  selected?: boolean;
  compact?: boolean;
  locale?: Locale;
}
const {
  id = '#NODE_001',
  title = 'Untitled task',
  status = 'done',
  duration = null,
  role = null,
  selected = false,
  compact = false,
  locale = 'en',
} = Astro.props;
const t = useTranslations(locale);

const STATUS_STYLE: Record<string, { color: string }> = {
  done:    { color: 'var(--oma-accent)' },
  running: { color: 'var(--oma-warning)' },
  queued:  { color: 'var(--oma-fg-2)' },
  failed:  { color: 'var(--oma-danger)' },
  skipped: { color: 'var(--oma-fg-3)' },
};
const s = STATUS_STYLE[status] ?? STATUS_STYLE.done;
const label = t.taskStatus[status as Status] ?? t.taskStatus.done;
const mark = status === 'done' ? '✓' : status === 'failed' ? '✕' : status === 'running' ? '◓' : '○';
---

<div class={`ds-tasknode${selected ? ' is-selected' : ''}${compact ? ' is-compact' : ''}`}>
  <div class="ds-tasknode__top">
    <span class="ds-tasknode__id">{id}</span>
    <span class="ds-tasknode__mark" style={`color:${s.color}`}>{mark}</span>
  </div>
  <div class="ds-tasknode__title">{title}</div>
  <div class="ds-tasknode__status">{t.taskStatus.statusPrefix}<span style={`color:${s.color};font-weight:500`}>{label}</span>{duration ? ` (${duration})` : ''}</div>
  {role && (
    <div class="ds-tasknode__badges">
      <Badge tone="neutral">{role}</Badge>
      {status === 'done' && <Badge tone="accent">{t.taskStatus.badge.stable}</Badge>}
      {status === 'running' && <Badge tone="warning" dot>{t.taskStatus.badge.live}</Badge>}
      {status === 'failed' && <Badge tone="danger">{t.taskStatus.badge.error}</Badge>}
    </div>
  )}
</div>

<style>
  .ds-tasknode {
    width: 100%; min-width: 0;
    background: var(--oma-bg-1); border: 1px solid var(--oma-border-1);
    border-radius: var(--radius-md); padding: 14px 16px;
    font-family: var(--font-sans); box-shadow: none;
    transition: border-color var(--duration-base) var(--ease-out), box-shadow var(--duration-base) var(--ease-out);
  }
  .ds-tasknode:hover { border-color: var(--oma-border-2); box-shadow: var(--shadow-md); }
  .ds-tasknode.is-selected { border-color: var(--oma-accent); box-shadow: var(--shadow-accent-glow); }
  .ds-tasknode__top { display: flex; align-items: center; justify-content: space-between; }
  .ds-tasknode__id { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; color: var(--oma-fg-2); }
  .ds-tasknode__mark { font-size: 13px; line-height: 1; }
  .ds-tasknode__title { color: var(--oma-fg-0); font-size: 15px; font-weight: 600; line-height: 1.3; margin: 8px 0 6px; }
  .ds-tasknode__status { font-family: var(--font-mono); font-size: 11px; color: var(--oma-fg-2); }
  .ds-tasknode__badges { display: flex; gap: 6px; margin-top: 10px; }
  .ds-tasknode.is-compact { padding: 9px 12px; }
  .ds-tasknode.is-compact .ds-tasknode__id,
  .ds-tasknode.is-compact .ds-tasknode__status { font-size: 10px; }
  .ds-tasknode.is-compact .ds-tasknode__title { margin: 4px 0; font-size: 13px; }
  .ds-tasknode.is-compact .ds-tasknode__badges { margin-top: 6px; }
</style>
