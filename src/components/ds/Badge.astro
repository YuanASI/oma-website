---
// Badge — compact status/label pill. Mono, uppercase, tracked. Tones map to
// the functional palette + emerald. `dot` adds a leading status dot.
interface Props {
  tone?: 'neutral' | 'accent' | 'warning' | 'danger' | 'info';
  dot?: boolean;
  class?: string;
}
const { tone = 'neutral', dot = false, class: cls = '' } = Astro.props;
---

<span class={`ds-badge ds-badge--${tone} ${cls}`}>
  {dot && <span class="ds-badge__dot"></span>}
  <slot />
</span>

<style>
  .ds-badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-mono); font-size: 10px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; line-height: 1;
    padding: 4px 8px; border-radius: var(--radius-xs); white-space: nowrap;
    border: 1px solid;
  }
  .ds-badge--neutral { color: var(--oma-fg-1); background: var(--oma-bg-3); border-color: var(--oma-border-1); }
  .ds-badge--accent  { color: var(--oma-accent); background: var(--oma-accent-soft); border-color: var(--oma-accent-line); }
  .ds-badge--warning { color: var(--oma-warning); background: var(--oma-warning-soft); border-color: rgba(245, 158, 11, 0.34); }
  .ds-badge--danger  { color: var(--oma-danger); background: var(--oma-danger-soft); border-color: rgba(239, 68, 68, 0.34); }
  .ds-badge--info    { color: var(--oma-info); background: var(--oma-info-soft); border-color: rgba(96, 165, 250, 0.34); }
  .ds-badge__dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex: none; }
</style>
