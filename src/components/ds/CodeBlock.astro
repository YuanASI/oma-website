---
// CodeBlock — mono code surface with title/lang bar + copy button and
// lightweight build-time token highlighting for ts / bash / json.
interface Props {
  code?: string;
  lang?: string;
  title?: string | null;
  copyable?: boolean;
  class?: string;
  /** Copy-button label + post-click confirmation (localized by the page). */
  copyLabel?: string;
  copiedLabel?: string;
  copyFailedLabel?: string;
}
const { code = '', lang = 'ts', title = null, copyable = true, class: cls = '', copyLabel = 'copy', copiedLabel = '✓ copied', copyFailedLabel = 'Copy failed — select and copy manually.' } = Astro.props;

type Tok = { t: string; c: string | null };
const KEYWORDS = ['const','let','var','function','return','await','async','import','export','from','new','type','interface','if','else','for','of','in','true','false','null','undefined','class','extends'];
const KW_RE = new RegExp('\\b(' + KEYWORDS.join('|') + ')\\b', 'g');

function pushColored(text: string, out: Tok[]): void {
  const parts = text.split(/(`[^`]*`|'[^']*'|"[^"]*")/g);
  for (const part of parts) {
    if (!part) continue;
    if (/^[`'"]/.test(part)) { out.push({ t: part, c: 'str' }); continue; }
    for (const seg of part.split(KW_RE)) {
      if (!seg) continue;
      if (KEYWORDS.includes(seg)) { out.push({ t: seg, c: 'kw' }); continue; }
      for (const n of seg.split(/(\b\d+(?:\.\d+)?\b)/g)) {
        if (!n) continue;
        out.push({ t: n, c: /^\d/.test(n) ? 'num' : null });
      }
    }
  }
}
function tokenize(line: string, lng: string): Tok[] {
  const out: Tok[] = [];
  const ci = lng === 'bash' ? line.indexOf('#') : line.indexOf('//');
  if (ci >= 0 && !/['"`]/.test(line.slice(0, ci))) {
    pushColored(line.slice(0, ci), out);
    out.push({ t: line.slice(ci), c: 'cmt' });
  } else {
    pushColored(line, out);
  }
  return out;
}
// Multi-line-string aware: a template literal (backtick) can span lines — the
// hero goal does — so we thread "inside a template" state across lines and color
// the whole span as a string, instead of per-line tokenizing that would miscolor
// its interior (leading list numbers, bare CJK) and lose the string tint.
const rawLines = String(code).replace(/\n$/, '').split('\n');
const lines: (Tok[] | null)[] = [];
let inTpl = false;
for (const raw of rawLines) {
  if (inTpl) {
    const close = raw.indexOf('`');
    if (close < 0) { lines.push([{ t: raw === '' ? ' ' : raw, c: 'str' }]); continue; }
    const toks: Tok[] = [{ t: raw.slice(0, close + 1), c: 'str' }];
    for (const tok of tokenize(raw.slice(close + 1), lang)) toks.push(tok);
    lines.push(toks);
    inTpl = false;
    continue;
  }
  if (raw === '') { lines.push(null); continue; }
  // An odd count of backticks means the last one opens a template that continues
  // on the next line; color from it to EOL and carry the open state forward.
  if ((raw.match(/`/g) ?? []).length % 2 === 1) {
    const open = raw.lastIndexOf('`');
    const toks = tokenize(raw.slice(0, open), lang);
    toks.push({ t: raw.slice(open), c: 'str' });
    lines.push(toks);
    inTpl = true;
    continue;
  }
  lines.push(tokenize(raw, lang));
}
---

<div class={`ds-codeblock ${cls}`}>
  <div class="ds-codeblock__bar">
    <span class="ds-codeblock__lang">{title || lang}</span>
    {copyable && (
      <div class="ds-codeblock__copy-wrap">
        <button type="button" class="ds-codeblock__copy" data-clip={code} data-copied={copiedLabel} data-failed={copyFailedLabel}>{copyLabel}</button>
        <span class="ds-codeblock__status" aria-live="polite"></span>
      </div>
    )}
  </div>
  <pre class="ds-codeblock__pre" tabindex="0">{lines.map((line) => <div>{line === null ? ' ' : line.map((tok) => (tok.c ? <span class={tok.c}>{tok.t}</span> : tok.t))}</div>)}</pre>
</div>

<style>
  .ds-codeblock { background: var(--oma-bg-3); border: 1px solid var(--oma-border-1); border-radius: var(--radius-md); overflow: hidden; font-family: var(--font-mono); }
  .ds-codeblock__bar { display: flex; align-items: center; justify-content: space-between; min-height: 44px; padding: 0 6px 0 12px; border-bottom: 1px solid var(--oma-border-0); background: var(--oma-bg-2); }
  .ds-codeblock__lang { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--oma-fg-2); font-weight: 600; }
  .ds-codeblock__copy-wrap { position: relative; display: flex; align-items: center; }
  .ds-codeblock__copy { min-width: 44px; min-height: 44px; font-family: var(--font-mono); font-size: 11px; color: var(--oma-fg-2); background: transparent; border: none; cursor: pointer; padding: 0 6px; }
  .ds-codeblock__copy.copied { color: var(--oma-accent); }
  .ds-codeblock__copy.copy-failed { color: var(--oma-danger); }
  .ds-codeblock__copy:focus-visible { outline: 2px solid var(--oma-accent); outline-offset: 1px; border-radius: var(--radius-sm); }
  .ds-codeblock__status { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  .ds-codeblock__pre { margin: 0; padding: 14px 16px; font-size: 13px; line-height: 1.6; color: var(--oma-fg-1); overflow-x: auto; }
  .ds-codeblock__pre :global(.kw) { color: var(--code-keyword); }
  .ds-codeblock__pre :global(.str) { color: var(--code-string); }
  .ds-codeblock__pre :global(.num) { color: var(--code-number); }
  .ds-codeblock__pre :global(.cmt) { color: var(--code-comment); }
</style>
