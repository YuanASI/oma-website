---
// Enterprise-support CTA (§3.2). One understated pointer to YuanASI's paid
// delivery, shared by the /compare pages and the /examples cookbook — placed
// where selection- and production-stage readers already are. The OSS site stays
// zero-commercial; this mirrors the footer's Enterprise-support link (same
// locale-matched target), it is not a hard sell. Strings live in the i18n dict.
import { useTranslations, type Locale } from '../i18n';
import EnterpriseLink from './EnterpriseLink.astro';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = useTranslations(locale).enterpriseCta;
---

<section class="section enterprise-cta">
  <div class="container">
    <div class="enterprise-cta-row">
      <div class="section-head enterprise-cta-inner">
        <div class="eyebrow"><span class="idx">//</span> {t.eyebrow}</div>
        <h2 class="section-title">{t.title}</h2>
        <p class="section-sub">{t.body}</p>
      </div>
      <EnterpriseLink class="btn-primary" locale={locale}><span>{t.button}</span><span class="arrow" aria-hidden="true">→</span></EnterpriseLink>
    </div>
  </div>
</section>

<style>
  /* Text block (left) + solid primary button (right), vertically centred. The
     head keeps its 680px measure; the button is pushed to the band's right edge. */
  .enterprise-cta-row {
    display: flex; align-items: center; justify-content: space-between; gap: 40px;
  }
  .enterprise-cta-inner { max-width: 680px; margin-bottom: 0; min-width: 0; }
  @media (max-width: 768px) {
    .enterprise-cta-row { flex-direction: column; align-items: flex-start; gap: 24px; }
  }
</style>
