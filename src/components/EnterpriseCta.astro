---
// Enterprise-support CTA (§3.2). One understated pointer to YuanASI's paid
// delivery, shared by the /compare pages and the /examples cookbook — placed
// where selection- and production-stage readers already are. The OSS site stays
// zero-commercial; this mirrors the footer's Enterprise-support link (same
// locale-matched target), it is not a hard sell. Strings live in the i18n dict.
import { YUANASI } from '../lib/site';
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = useTranslations(locale).enterpriseCta;
// Locale-matched landing, same contract as the footer's Enterprise-support link.
const href = locale === 'zh' ? YUANASI : `${YUANASI}/en`;
---

<section class="section enterprise-cta">
  <div class="container">
    <div class="section-head enterprise-cta-inner">
      <div class="eyebrow"><span class="idx">//</span> {t.eyebrow}</div>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-sub">{t.body}</p>
      <div class="enterprise-cta-action">
        <a class="text-link" href={href} target="_blank" rel="noreferrer"><span>{t.button}</span><span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>

<style>
  .enterprise-cta-inner { max-width: 680px; }
  .enterprise-cta-action { margin-top: 16px; }
</style>
