---
// Language switcher — a compact globe icon button that matches the theme toggle
// (.nav-theme-toggle) in size and spec: same 34×34 bordered square, same hover.
// With exactly two locales it's a single toggle — click flips to the other
// language. A 3rd locale would need a menu instead; the i18n dict + routing
// already scale, only this button assumes two. `path` is this page's
// default-locale path so the link points at the same page in the other locale;
// a route with no localized counterpart falls back to that locale's home.
import { useTranslations, localizePath, localeMeta, otherLocale, defaultLocale, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  path?: string;
}
const { locale, path } = Astro.props;
const t = useTranslations(locale);
const other = otherLocale(locale);
const target = path !== undefined ? localizePath(path, other) : other === defaultLocale ? '/' : `/${other}/`;
const aria = t.langSwitcher.toAria.replace('{lang}', localeMeta[other].label);
---

<a class="nav-lang-toggle" href={target} hreflang={localeMeta[other].lang} aria-label={aria} title={aria}>
