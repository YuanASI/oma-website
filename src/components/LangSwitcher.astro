---
// Language switcher for the custom pages — a native <select> dropdown that
// mirrors Starlight's docs-site language picker (globe icon + caret, navigate on
// change), so the two switchers look and behave the same. Starlight's component
// lives inside the docs context and can't be reused here, so this replicates its
// markup/CSS with the --sl-color-* vars mapped to our --oma-* tokens.
// `path` is this page's default-locale path so each option points at the same
// page in that locale; non-localized routes (e.g. /blog/) fall back to the home.
import { useTranslations, localizePath, localeMeta, locales, defaultLocale, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  path?: string;
}
const { locale, path } = Astro.props;
const t = useTranslations(locale);
const targetFor = (l: Locale) => (path !== undefined ? localizePath(path, l) : l === defaultLocale ? '/' : `/${l}/`);
---

<oma-lang-select class="lang-select">
  <label style="--sl-select-width: 7.5em">
    <span class="sr-only">{t.langSwitcher.label}</span>
    <svg aria-hidden="true" class="icon label-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M8.516 3a.94.94 0 0 0-.941.94v1.15H2.94a.94.94 0 1 0 0 1.882h7.362a7.422 7.422 0 0 1-1.787 3.958 7.42 7.42 0 0 1-1.422-2.425.94.94 0 1 0-1.774.627 9.303 9.303 0 0 0 1.785 3.043 7.422 7.422 0 0 1-4.164 1.278.94.94 0 1 0 0 1.881 9.303 9.303 0 0 0 5.575-1.855 9.303 9.303 0 0 0 4.11 1.74l-.763 1.525a.968.968 0 0 0-.016.034l-1.385 2.77a.94.94 0 1 0 1.683.841l1.133-2.267h5.806l1.134 2.267a.94.94 0 0 0 1.683-.841l-1.385-2.769a.95.95 0 0 0-.018-.036l-3.476-6.951a.94.94 0 0 0-1.682 0l-1.82 3.639a7.423 7.423 0 0 1-3.593-1.256 9.303 9.303 0 0 0 2.27-5.203h1.894a.94.94 0 0 0 0-1.881H9.456V3.94A.94.94 0 0 0 8.516 3Zm6.426 11.794a1.068 1.068 0 0 1-.02.039l-.703 1.407h3.924l-1.962-3.924-1.24 2.478Z" clip-rule="evenodd"/></svg>
    <select autocomplete="off">
      {locales.map((l) => (
        <option value={targetFor(l)} selected={l === locale}>{localeMeta[l].label}</option>
      ))}
    </select>
    <svg aria-hidden="true" class="icon caret" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17 9.17a1 1 0 0 0-1.41 0L12 12.71 8.46 9.17a1 1 0 1 0-1.41 1.42l4.24 4.24a1.002 1.002 0 0 0 1.42 0L17 10.59a1.002 1.002 0 0 0 0-1.42Z"/></svg>
  </label>
</oma-lang-select>

<script>
  // Navigate to the chosen locale's URL on change — mirrors Starlight's
  // StarlightLanguageSelect, including the bfcache selectedIndex resync.
  class OmaLangSelect extends HTMLElement {
    constructor() {
      super();
      const select = this.querySelector('select');
      if (!select) return;
      select.addEventListener('change', (e) => {
        if (e.currentTarget instanceof HTMLSelectElement) {
          window.location.pathname = e.currentTarget.value;
        }
      });
      window.addEventListener('pageshow', (event) => {
        if (!event.persisted) return;
        const i = select.querySelector<HTMLOptionElement>('option[selected]')?.index;
        if (i !== select.selectedIndex) select.selectedIndex = i ?? 0;
      });
    }
  }
  if (!customElements.get('oma-lang-select')) customElements.define('oma-lang-select', OmaLangSelect);
</script>

<style>
  /* Mirrors @astrojs/starlight Select.astro, with the --sl-color-* vars mapped to
     OMA tokens so the custom-page switcher matches the docs-site dropdown. */
  /* .sr-only is a Starlight global not loaded on custom pages — define it here. */
  .lang-select .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }
  .lang-select label {
    --sl-label-icon-size: 0.875rem;
    --sl-caret-size: 1.125rem;
    --sl-inline-padding: 0.5rem;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--oma-fg-2);
    font-family: var(--font-sans);
  }
  .lang-select label:hover { color: var(--oma-fg-0); }
  .lang-select .icon { position: absolute; top: 50%; transform: translateY(-50%); pointer-events: none; }
  .lang-select select {
    border: 0;
    padding-block: 0.4rem;
    padding-inline: calc(var(--sl-label-icon-size) + var(--sl-inline-padding) + 0.25rem)
      calc(var(--sl-caret-size) + var(--sl-inline-padding) + 0.1rem);
    margin-inline: calc(var(--sl-inline-padding) * -1);
    width: calc(var(--sl-select-width) + var(--sl-inline-padding) * 2);
    background-color: transparent;
    text-overflow: ellipsis;
    color: inherit;
    cursor: pointer;
    appearance: none;
    font-family: var(--font-sans);
    font-size: 13px;
  }
  .lang-select option { background-color: var(--oma-bg-1); color: var(--oma-fg-1); }
  .lang-select .label-icon { inset-inline-start: 0; }
  .lang-select .caret { inset-inline-end: 0; }
</style>
