---
// Shared Chinese enterprise-contact dialog. It is mounted once by BaseLayout;
// every locale-aware EnterpriseLink button targets this single instance.
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale).enterpriseDialog;
---

<dialog
  class="enterprise-dialog"
  id="enterprise-contact-dialog"
  aria-labelledby="enterprise-dialog-title"
  aria-describedby="enterprise-dialog-description"
>
  <div class="enterprise-dialog-shell">
    <header class="enterprise-dialog-head">
      <div class="enterprise-dialog-heading">
        <div class="enterprise-dialog-eyebrow"><span>//</span> {t.eyebrow}</div>
        <h2 id="enterprise-dialog-title">{t.title}</h2>
        <p id="enterprise-dialog-description">{t.body}</p>
      </div>
      <button class="enterprise-dialog-close" type="button" data-enterprise-close aria-label={t.closeAria}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" />
        </svg>
      </button>
    </header>

    <div class="enterprise-dialog-grid">
      <section class="enterprise-services" aria-labelledby="enterprise-services-title">
        <div class="enterprise-panel-label" id="enterprise-services-title">{t.servicesLabel}</div>
        <div class="enterprise-service-list">
          {t.services.map((service) => (
            <article class="enterprise-service">
              <div class="enterprise-service-code">{service.code}</div>
              <div>
                <h3>{service.title}</h3>
                <p>{service.body}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <aside class="enterprise-contact" aria-labelledby="enterprise-contact-title">
        <div class="enterprise-contact-head">
          <div class="enterprise-panel-label" id="enterprise-contact-title">{t.contactEyebrow}</div>
          <button
            type="button"
            class="enterprise-copy"
            data-enterprise-copy
            data-copy-value={t.wechatId}
            data-copy-label={t.copy}
            data-copied-label={t.copied}
            data-failed-label={t.copyFailed}
            aria-label={`${t.copy}: ${t.wechatId}`}
          >
            <span class="enterprise-copy-id">
              <code>{t.wechatId}</code>
              <svg class="enterprise-copy-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="6.5" y="6.5" width="9" height="10" rx="1.5" />
                <path d="M13.5 6.5V5A1.5 1.5 0 0 0 12 3.5H5A1.5 1.5 0 0 0 3.5 5v8A1.5 1.5 0 0 0 5 14.5h1.5" />
              </svg>
            </span>
            <span class="enterprise-copy-label" data-enterprise-copy-label>{t.copy}</span>
          </button>
        </div>
        <div class="enterprise-qr-frame">
          <span class="enterprise-qr-corner enterprise-qr-corner--tl" aria-hidden="true"></span>
          <span class="enterprise-qr-corner enterprise-qr-corner--br" aria-hidden="true"></span>
          <img
            src="/contact/wechat-qr.jpg"
            alt={t.qrAlt}
            width="888"
            height="1128"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="enterprise-contact-note">{t.contactNote}</p>
        <span class="enterprise-copy-feedback" data-enterprise-copy-feedback aria-live="polite"></span>
      </aside>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.querySelector<HTMLDialogElement>('#enterprise-contact-dialog');

  if (dialog) {
    const triggers = document.querySelectorAll<HTMLElement>('[data-enterprise-trigger]');
    const closeButton = dialog.querySelector<HTMLButtonElement>('[data-enterprise-close]');
    const copyButton = dialog.querySelector<HTMLButtonElement>('[data-enterprise-copy]');
    const copyLabelElement = dialog.querySelector<HTMLElement>('[data-enterprise-copy-label]');
    const copyFeedback = dialog.querySelector<HTMLElement>('[data-enterprise-copy-feedback]');
    let opener: HTMLElement | null = null;
    let previousBodyOverflow = '';
    let copyResetTimer: number | undefined;

    const closeMobileNavigation = () => {
      const links = document.querySelector<HTMLElement>('.nav-links');
      const toggle = document.querySelector<HTMLElement>('.nav-mobile-toggle');
      links?.classList.remove('open');
      if (toggle) {
        toggle.textContent = '≡';
        toggle.setAttribute('aria-expanded', 'false');
      }
      document.body.style.overflow = '';
    };

    const openDialog = (trigger: HTMLElement) => {
      if (dialog.open) return;
      opener = trigger;
      closeMobileNavigation();
      previousBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';
      dialog.showModal();
      requestAnimationFrame(() => closeButton?.focus());
    };

    const closeDialog = () => {
      if (dialog.open) dialog.close();
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => openDialog(trigger));
    });

    closeButton?.addEventListener('click', closeDialog);

    dialog.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeDialog();
    });

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) closeDialog();
    });

    dialog.addEventListener('close', () => {
      document.body.style.overflow = previousBodyOverflow;
      opener?.focus();
      opener = null;
    });

    const fallbackCopy = (value: string): boolean => {
      const textarea = document.createElement('textarea');
      textarea.value = value;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      const copied = document.execCommand('copy');
      textarea.remove();
      return copied;
    };

    copyButton?.addEventListener('click', async () => {
      const value = copyButton.dataset.copyValue ?? '';
      const defaultLabel = copyButton.dataset.copyLabel ?? '';
      const copiedLabel = copyButton.dataset.copiedLabel ?? '';
      const failedLabel = copyButton.dataset.failedLabel ?? '';
      let copied = false;

      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(value);
          copied = true;
        } else {
          copied = fallbackCopy(value);
        }
      } catch {
        copied = fallbackCopy(value);
      }

      const message = copied ? copiedLabel : failedLabel;
      if (copyLabelElement) copyLabelElement.textContent = message;
      copyButton.classList.toggle('is-copied', copied);
      copyButton.classList.toggle('is-failed', !copied);
      copyButton.setAttribute('aria-label', message);
      if (copyFeedback) copyFeedback.textContent = message;
      window.clearTimeout(copyResetTimer);
      copyResetTimer = window.setTimeout(() => {
        if (copyLabelElement) copyLabelElement.textContent = defaultLabel;
        copyButton.classList.remove('is-copied');
        copyButton.classList.remove('is-failed');
        copyButton.setAttribute('aria-label', `${defaultLabel}: ${value}`);
        if (copyFeedback) copyFeedback.textContent = '';
      }, 2200);
    });
  }
</script>

<style>
  .enterprise-dialog {
    width: min(900px, calc(100vw - 32px));
    max-width: none;
    max-height: calc(100dvh - 32px);
    margin: auto;
    padding: 0;
    overflow: auto;
    color: var(--oma-fg-0);
    background: var(--oma-bg-1);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg), 0 0 0 1px var(--oma-accent-line);
  }

  .enterprise-dialog::backdrop {
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: enterprise-backdrop-in var(--duration-slow) var(--ease-out) both;
  }

  .enterprise-dialog[open] .enterprise-dialog-shell {
    animation: enterprise-dialog-in var(--duration-slow) var(--ease-out) both;
  }

  .enterprise-dialog-shell {
    position: relative;
    padding: 32px;
    background-image: radial-gradient(var(--grid-dot) 1.2px, transparent 1.2px);
    background-size: var(--grid-size) var(--grid-size);
  }

  .enterprise-dialog-head {
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border-default);
  }

  .enterprise-dialog-heading { max-width: 700px; padding-right: 56px; }

  .enterprise-dialog-eyebrow,
  .enterprise-panel-label,
  .enterprise-service-code {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
  }

  .enterprise-dialog-eyebrow {
    margin-bottom: 12px;
    color: var(--oma-fg-2);
    font-size: 11px;
    font-weight: 600;
  }
  .enterprise-dialog-eyebrow span { color: var(--oma-accent); }

  .enterprise-dialog h2 {
    margin: 0;
    color: var(--oma-fg-0);
    font-family: var(--font-sans);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .enterprise-dialog-heading > p {
    max-width: 570px;
    margin: 12px 0 0;
    color: var(--oma-fg-1);
    font-size: 15px;
    line-height: 1.7;
  }

  .enterprise-dialog-close {
    position: absolute;
    top: 32px;
    right: 32px;
    display: inline-grid;
    place-items: center;
    width: 44px;
    height: 44px;
    flex: none;
    padding: 0;
    color: var(--oma-fg-1);
    background: var(--oma-bg-2);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }
  .enterprise-dialog-close:hover { color: var(--oma-fg-0); border-color: var(--oma-accent-line); transform: rotate(3deg); }
  .enterprise-dialog-close svg { width: 18px; height: 18px; }

  .enterprise-dialog-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(260px, 0.7fr);
    gap: 32px;
    padding-top: 28px;
  }

  .enterprise-panel-label {
    margin-bottom: 14px;
    color: var(--oma-fg-3);
    font-size: 10px;
    font-weight: 600;
  }

  .enterprise-service-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border-default);
  }

  .enterprise-service {
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr);
    gap: 14px;
    padding: 20px 0;
    border-bottom: 1px solid var(--border-default);
  }

  .enterprise-service-code {
    padding-top: 3px;
    color: var(--oma-accent);
    font-size: 10px;
    font-weight: 600;
  }

  .enterprise-service h3 {
    margin: 0;
    color: var(--oma-fg-0);
    font-family: var(--font-sans);
    font-size: 17px;
    font-weight: 600;
    line-height: 1.35;
  }

  .enterprise-service p {
    margin: 7px 0 0;
    color: var(--oma-fg-1);
    font-size: 13.5px;
    line-height: 1.65;
  }

  .enterprise-contact {
    min-width: 0;
    padding-left: 28px;
    border-left: 1px solid var(--border-default);
  }

  .enterprise-contact-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: min(100%, 220px);
    margin: 0 auto 14px;
  }
  .enterprise-contact-head .enterprise-panel-label { margin: 0; }

  .enterprise-qr-frame {
    position: relative;
    width: min(100%, 220px);
    margin: 0 auto 18px;
    padding: 8px;
    background: #fff;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
  }
  .enterprise-qr-frame img { display: block; width: 100%; height: auto; border-radius: 2px; }

  .enterprise-qr-corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: var(--oma-accent);
    pointer-events: none;
  }
  .enterprise-qr-corner--tl { top: -5px; left: -5px; border-top: 2px solid; border-left: 2px solid; }
  .enterprise-qr-corner--br { right: -5px; bottom: -5px; border-right: 2px solid; border-bottom: 2px solid; }

  .enterprise-contact-note {
    margin: 12px 0 0;
    color: var(--oma-fg-2);
    font-size: 12.5px;
    line-height: 1.55;
    text-align: center;
  }

  .enterprise-copy {
    position: relative;
    display: grid;
    place-items: center;
    flex: none;
    width: 124px;
    min-height: 28px;
    padding: 0 9px;
    overflow: hidden;
    color: var(--oma-accent);
    background: var(--oma-accent-soft);
    border: 1px solid var(--oma-accent-line);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }
  .enterprise-copy-id,
  .enterprise-copy-label {
    grid-area: 1 / 1;
    transition: opacity var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }
  .enterprise-copy-id {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .enterprise-copy-id code {
    color: inherit;
    font-family: var(--font-mono);
    font-size: 10px;
  }
  .enterprise-copy-icon { width: 12px; height: 12px; }
  .enterprise-copy-label { opacity: 0; transform: translateY(3px); }
  .enterprise-copy:hover .enterprise-copy-id,
  .enterprise-copy:focus-visible .enterprise-copy-id,
  .enterprise-copy.is-copied .enterprise-copy-id,
  .enterprise-copy.is-failed .enterprise-copy-id { opacity: 0; transform: translateY(-3px); }
  .enterprise-copy:hover .enterprise-copy-label,
  .enterprise-copy:focus-visible .enterprise-copy-label,
  .enterprise-copy.is-copied .enterprise-copy-label,
  .enterprise-copy.is-failed .enterprise-copy-label { opacity: 1; transform: translateY(0); }
  .enterprise-copy:hover,
  .enterprise-copy:focus-visible,
  .enterprise-copy.is-copied { color: var(--oma-accent-fg); background: var(--oma-accent); border-color: var(--oma-accent); }
  .enterprise-copy.is-failed { color: var(--oma-danger); background: var(--oma-bg-2); border-color: var(--oma-danger); }

  .enterprise-copy-feedback {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .enterprise-dialog-close:focus-visible,
  .enterprise-copy:focus-visible {
    outline: 2px solid var(--oma-accent);
    outline-offset: 3px;
  }

  @keyframes enterprise-dialog-in {
    from { opacity: 0; transform: translateY(16px) scale(0.985); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes enterprise-backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (max-width: 720px) {
    .enterprise-dialog { width: min(100% - 20px, 560px); max-height: calc(100dvh - 20px); }
    .enterprise-dialog-shell { padding: 22px 18px; }
    .enterprise-dialog-head { padding-bottom: 22px; }
    .enterprise-dialog-heading { padding-right: 52px; }
    .enterprise-dialog-close { top: 22px; right: 18px; }
    .enterprise-dialog h2 { font-size: clamp(26px, 8vw, 34px); }
    .enterprise-dialog-grid { grid-template-columns: 1fr; gap: 28px; padding-top: 22px; }
    .enterprise-contact { padding: 26px 0 0; border-top: 1px solid var(--border-default); border-left: 0; }
    .enterprise-qr-frame { width: min(78vw, 220px); }
  }

  @media (max-width: 420px) {
    .enterprise-service { grid-template-columns: 42px minmax(0, 1fr); gap: 10px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .enterprise-dialog::backdrop,
    .enterprise-dialog[open] .enterprise-dialog-shell { animation: none; }
    .enterprise-dialog-close,
    .enterprise-copy { transition: none; }
  }
</style>
