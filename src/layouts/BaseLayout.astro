---
// Shared document shell for the custom (non-Starlight) pages. Collapses the ~25
// lines of <head> boilerplate that index/examples/showcase/architecture each used
// to hand-write, and makes it locale-aware: <html lang>, og:locale, and the
// hreflang alternates all follow the page's locale instead of being hardcoded to
// en. Starlight emits its own head for the docs — this only covers src/pages/.
import ThemeInit from '../components/ThemeInit.astro';
import LangInit from '../components/LangInit.astro';
import { localeMeta, localizePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** Structured-data object/graph; stringified into a JSON-LD script. */
  jsonLd?: unknown;
  /** This page's path in the default (en/root) locale, e.g. '/' or '/examples/'. */
  path: string;
  /** Emit hreflang alternates — true for pages that exist in every locale. */
  localized?: boolean;
  /** og:type — defaults to 'website'; blog posts pass 'article'. */
  ogType?: string;
}
const { locale, title, description, jsonLd, path, localized = true, ogType = 'website' } = Astro.props;
const meta = localeMeta[locale];

// Canonical is the page actually being rendered (already locale-correct, e.g.
// /zh/examples/). The alternates are built from the default-locale `path`.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const enHref = new URL(path, Astro.site).href;
const zhHref = new URL(localizePath(path, 'zh'), Astro.site).href;
const ogImage = new URL('/github-social.png', Astro.site).href;
---

<!doctype html>
<html lang={meta.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeInit />
    {/* Favicon set — SVG for modern browsers, ICO/PNG raster so Google Search
        and legacy clients render a real icon (see scripts/generate-favicons.mjs). */}
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {localized && (
      <Fragment>
        <link rel="alternate" hreflang="en" href={enHref} />
        <link rel="alternate" hreflang="zh-CN" href={zhHref} />
        <link rel="alternate" hreflang="x-default" href={enHref} />
      </Fragment>
    )}
    <LangInit />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Open Multi-Agent" />
    <meta property="og:locale" content={meta.ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="640" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}

    {/* Counterscale — first-party, cookieless analytics (self-hosted CF Worker).
        Same tag lives in StarlightHead.astro so Starlight docs pages are covered.
        is:inline stops Astro from bundling/rewriting the vendor script. */}
    <script is:inline id="counterscale-script"
      src="https://insights.open-multi-agent.com/tracker.js"
      data-site-id="open-multi-agent.com" defer></script>

    {/* Baidu 百度统计 — Chinese-market analytics + Baidu site verification.
        Same tag lives in StarlightHead.astro so Starlight docs pages are
        covered. is:inline stops Astro from bundling/rewriting the async loader. */}
    <script is:inline>
      var _hmt = _hmt || [];
      (function () {
        var hm = document.createElement('script');
        hm.src = 'https://hm.baidu.com/hm.js?2e6b1d4a79147dca8349670cc68f0b68';
        var s = document.getElementsByTagName('script')[0];
        s.parentNode.insertBefore(hm, s);
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
